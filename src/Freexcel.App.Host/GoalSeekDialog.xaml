<Window x:Class="Freexcel.App.Host.GoalSeekDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Goal Seek" Width="320" Height="200"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: Set cell -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Set cell:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="SetCellBox" Margin="0,4"/>

        <!-- Row 1: To value -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="To value:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="ToValueBox" Margin="0,4"/>

        <!-- Row 2: By changing cell -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="By changing cell:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="ChangingCellBox" Margin="0,4"/>

        <!-- Row 4: Buttons -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK"     Width="75" IsDefault="True"  Click="OkBtn_Click"     Margin="0,0,6,0"/>
            <Button Content="Cancel" Width="75" IsCancel="True"   Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
