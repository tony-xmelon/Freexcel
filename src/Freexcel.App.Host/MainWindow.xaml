                                        local:RibbonTooltip.Description="Keep rows or columns visible while scrolling; creating frozen panes clears split panes.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Freeze Panes" local:RibbonTooltip.KeyTip="F" Click="FreezeAtSelectionMenuItem_Click"/>
                                            <MenuItem Header="Freeze Top Row" local:RibbonTooltip.KeyTip="R" Click="FreezeTopRowMenuItem_Click"/>
                                            <MenuItem Header="Freeze First Column" local:RibbonTooltip.KeyTip="C" Click="FreezeFirstColMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Unfreeze All" local:RibbonTooltip.KeyTip="U" Click="UnfreezeAllMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <ToggleButton x:Name="SplitViewBtn" Content="Split" Height="22" Margin="1,1" Style="{StaticResource RibbonToggleBtn}" Click="SplitViewBtn_Click"
                                              local:RibbonTooltip.Title="Split"
                                              local:RibbonTooltip.KeyTip="S"
                                              local:RibbonTooltip.Description="Split the worksheet at the selected cell, or remove the current split; creating a split clears frozen panes."/>
                                <Button Content="New Window" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ViewWindowDeferredBtn_Click"
                                        local:RibbonTooltip.Title="New Window"
                                        local:RibbonTooltip.KeyTip="NW"
                                        local:RibbonTooltip.Description="Deferred: requires multiple live windows over the same workbook session."/>
                                <Button Content="Arrange All" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ArrangeAllPickerBtn_Click"
                                        local:RibbonTooltip.Title="Arrange All"
                                        local:RibbonTooltip.KeyTip="A"
                                        local:RibbonTooltip.Description="Store the workbook-window arrangement to use when multi-window hosting is available.">
                                    <Button.ContextMenu>
                                        <ContextMenu Opened="ArrangeAllContextMenu_Opened">
                                            <MenuItem Header="Tiled"      Tag="Tiled"      IsCheckable="True" local:RibbonTooltip.KeyTip="T" Click="ArrangeAllMenuItem_Click"/>
                                            <MenuItem Header="Horizontal" Tag="Horizontal" IsCheckable="True" local:RibbonTooltip.KeyTip="H" Click="ArrangeAllMenuItem_Click"/>
                                            <MenuItem Header="Vertical"   Tag="Vertical"   IsCheckable="True" local:RibbonTooltip.KeyTip="V" Click="ArrangeAllMenuItem_Click"/>
                                            <MenuItem Header="Cascade"    Tag="Cascade"    IsCheckable="True" local:RibbonTooltip.KeyTip="C" Click="ArrangeAllMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Side by Side" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ViewWindowDeferredBtn_Click"
                                        local:RibbonTooltip.Title="Side by Side"
                                        local:RibbonTooltip.KeyTip="B"
                                        local:RibbonTooltip.Description="Deferred: requires multi-window workbook hosting and synchronized scroll routing."/>
                                <Button Content="Sync Scrolling" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ViewWindowDeferredBtn_Click"
                                        local:RibbonTooltip.Title="Sync Scrolling"
                                        local:RibbonTooltip.KeyTip="SS"
                                        local:RibbonTooltip.Description="Deferred: requires paired workbook windows with synchronized viewport state."/>
                                <Button Content="Reset Position" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ViewWindowDeferredBtn_Click"
                                        local:RibbonTooltip.Title="Reset Position"
                                        local:RibbonTooltip.KeyTip="RP"
                                        local:RibbonTooltip.Description="Deferred: requires paired workbook windows and side-by-side layout state."/>
                                <Button Content="Switch Windows" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ViewWindowDeferredBtn_Click"
                                        local:RibbonTooltip.Title="Switch Windows"
                                        local:RibbonTooltip.KeyTip="W"
                                        local:RibbonTooltip.Description="Deferred: requires a multi-window workbook registry."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Window" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Macros ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Macros" Width="82" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" IsEnabled="False"
                                        local:RibbonTooltip.Title="Macros"
                                        local:RibbonTooltip.KeyTip="M"
                                        local:RibbonTooltip.Description="VBA macro recording and playback are deferred in Freexcel."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Macros" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── HELP ──────────────────────────────────────────────── -->
            <TabItem x:Name="PivotTableAnalyzeTab" Header="PivotTable Analyze" Visibility="Collapsed" local:RibbonTooltip.KeyTip="JA">
                <Border Background="{StaticResource FreexcelRibbonSurfaceBrush}" Padding="6,4,6,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                        <StackPanel Orientation="Horizontal" MinHeight="88">
                            <Grid Style="{StaticResource RibbonGroupPanel}">
                                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                    <Button Content="Field List" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotFieldListBtn_Click"
                                            local:RibbonTooltip.Title="Field List"
                                            local:RibbonTooltip.KeyTip="FL"
                                            local:RibbonTooltip.Description="Show or hide the PivotTable Fields task pane."/>
                                    <Button Content="Refresh" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="RefreshPivotTableBtn_Click"
                                            local:RibbonTooltip.Title="Refresh"
                                            local:RibbonTooltip.KeyTip="R"
                                            local:RibbonTooltip.Description="Refresh the selected PivotTable."/>
                                    <Button Content="Show Details" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotTableShowDetailsBtn_Click"
                                            local:RibbonTooltip.Title="Show Details"
                                            local:RibbonTooltip.KeyTip="D"
                                            local:RibbonTooltip.Description="Create a detail sheet for the selected PivotTable value cell."/>
                                    <Button Content="Group Field" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotGroupFieldBtn_Click"
                                            local:RibbonTooltip.Title="Group Field"
                                            local:RibbonTooltip.KeyTip="GF"
                                            local:RibbonTooltip.Description="Open grouping options for the selected PivotTable field."/>
                                    <Button Content="Ungroup" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotUngroupFieldBtn_Click"
                                            local:RibbonTooltip.Title="Ungroup"
                                            local:RibbonTooltip.KeyTip="UG"
                                            local:RibbonTooltip.Description="Remove grouping from the selected PivotTable field."/>
                                </StackPanel>
                                <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="PivotTable" Style="{StaticResource GroupLbl}"/></Border>
                            </Grid>
                            <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>
                            <Grid Style="{StaticResource RibbonGroupPanel}">
                                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                    <Button Content="PivotChart" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotChartBtn_Click"
                                            local:RibbonTooltip.Title="PivotChart"
                                            local:RibbonTooltip.KeyTip="C"
                                            local:RibbonTooltip.Description="Insert a chart bound to the selected PivotTable."/>
                                    <Button Content="Change Chart" Width="104" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotChartChangeTypeBtn_Click"
                                            local:RibbonTooltip.Title="Change Chart Type"
                                            local:RibbonTooltip.KeyTip="CT"
                                            local:RibbonTooltip.Description="Change the bound PivotChart type while preserving its PivotTable connection."/>
                                    <Button Content="Chart Options" Width="104" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotChartOptionsBtn_Click"
                                            local:RibbonTooltip.Title="PivotChart Options"
                                            local:RibbonTooltip.KeyTip="CO"
                                            local:RibbonTooltip.Description="Change PivotChart style and field button visibility."/>
                                    <Button Content="Insert Slicer" Width="104" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotInsertSlicerBtn_Click"
                                            local:RibbonTooltip.Title="Insert Slicer"
                                            local:RibbonTooltip.KeyTip="IS"
                                            local:RibbonTooltip.Description="Create a slicer connected to the selected PivotTable field."/>
                                    <Button Content="Insert Timeline" Width="104" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotInsertTimelineBtn_Click"
                                            local:RibbonTooltip.Title="Insert Timeline"
                                            local:RibbonTooltip.KeyTip="IT"
                                            local:RibbonTooltip.Description="Create a timeline connected to the selected PivotTable date field."/>
                                    <Button Content="Change Source" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotChangeDataSourceBtn_Click"
                                            local:RibbonTooltip.Title="Change Data Source"
                                            local:RibbonTooltip.KeyTip="S"
                                            local:RibbonTooltip.Description="Change the source range for the selected PivotTable."/>
                                    <Button Content="Calc Field" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotCalculatedFieldBtn_Click"
                                            local:RibbonTooltip.Title="Calculated Field"
                                            local:RibbonTooltip.KeyTip="CF"
                                            local:RibbonTooltip.Description="Create or replace a calculated field in the selected PivotTable."/>
                                    <Button Content="Calc Item" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotCalculatedItemBtn_Click"
                                            local:RibbonTooltip.Title="Calculated Item"
                                            local:RibbonTooltip.KeyTip="CI"
                                            local:RibbonTooltip.Description="Create or replace a calculated item in the selected PivotTable."/>
                                </StackPanel>
                                <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Data" Style="{StaticResource GroupLbl}"/></Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem x:Name="PivotTableDesignTab" Header="Design" Visibility="Collapsed" local:RibbonTooltip.KeyTip="JD">
                <Border Background="{StaticResource FreexcelRibbonSurfaceBrush}" Padding="6,4,6,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                        <StackPanel Orientation="Horizontal" MinHeight="88">
                            <Grid Style="{StaticResource RibbonGroupPanel}">
                                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                    <Button Content="Grand Totals" Width="104" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotGrandTotalsBtn_Click"
                                            local:RibbonTooltip.Title="Grand Totals"
                                            local:RibbonTooltip.KeyTip="G"
                                            local:RibbonTooltip.Description="Open PivotTable layout and style options."/>
                                    <Button Content="Subtotals" Width="104" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotSubtotalsBtn_Click"
                                            local:RibbonTooltip.Title="Subtotals"
                                            local:RibbonTooltip.KeyTip="S"
                                            local:RibbonTooltip.Description="Open PivotTable layout and style options."/>
                                    <Button Content="Report Layout" Width="104" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotReportLayoutBtn_Click"
                                            local:RibbonTooltip.Title="Report Layout"
                                            local:RibbonTooltip.KeyTip="L"
                                            local:RibbonTooltip.Description="Open PivotTable layout and style options."/>
                                    <Button Content="Blank Rows" Width="104" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotBlankRowsBtn_Click"
                                            local:RibbonTooltip.Title="Blank Rows"
                                            local:RibbonTooltip.KeyTip="B"
                                            local:RibbonTooltip.Description="Toggle blank lines after PivotTable items."/>
                                </StackPanel>
                                <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Layout" Style="{StaticResource GroupLbl}"/></Border>
                            </Grid>
                            <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>
                            <Grid Style="{StaticResource RibbonGroupPanel}">
                                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                    <StackPanel>
                                        <Button Content="Styles" Width="92" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotStyleGalleryBtn_Click"
                                                local:RibbonTooltip.Title="PivotTable Styles"
                                                local:RibbonTooltip.KeyTip="Y"
                                                local:RibbonTooltip.Description="Open PivotTable layout and style options."/>
                                        <Button Content="Banded Rows" Width="92" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotBandedRowsBtn_Click"
                                                local:RibbonTooltip.Title="Banded Rows"
                                                local:RibbonTooltip.KeyTip="R"
                                                local:RibbonTooltip.Description="Toggle banded row formatting for the selected PivotTable."/>
                                        <Button Content="Banded Cols" Width="92" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotBandedColumnsBtn_Click"
                                                local:RibbonTooltip.Title="Banded Columns"
                                                local:RibbonTooltip.KeyTip="C"
                                                local:RibbonTooltip.Description="Toggle banded column formatting for the selected PivotTable."/>
                                    </StackPanel>
                                    <StackPanel>
                                        <Button Content="Row Headers" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotRowHeadersBtn_Click"
                                                local:RibbonTooltip.Title="Row Headers"
                                                local:RibbonTooltip.KeyTip="H"
                                                local:RibbonTooltip.Description="Toggle row header styling for the selected PivotTable."/>
                                        <Button Content="Column Headers" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotColumnHeadersBtn_Click"
                                                local:RibbonTooltip.Title="Column Headers"
                                                local:RibbonTooltip.KeyTip="O"
                                                local:RibbonTooltip.Description="Toggle column header styling for the selected PivotTable."/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="PivotTable Style Options" Style="{StaticResource GroupLbl}"/></Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="Help" local:RibbonTooltip.KeyTip="Y">
                <Border Background="{StaticResource FreexcelRibbonSurfaceBrush}" Padding="6,4,6,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal" MinHeight="88">

                        <!-- ▌Help ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Help Online"   Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="HelpOnlineBtn_Click"
                                        local:RibbonTooltip.Title="Help Online"
                                        local:RibbonTooltip.KeyTip="HO"
                                        local:RibbonTooltip.Description="Open the Freexcel help documentation in a web browser."/>
                                <local:AutomationInvokeButton x:Name="HelpAboutFreexcelButton"
                                                              Content="About Freexcel" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="AboutBtn_Click"
                                                              AutomationProperties.Name="About Freexcel"
                                                              AutomationProperties.AutomationId="HelpAboutFreexcelButton"
                                                              local:RibbonTooltip.Title="About Freexcel"
                                                              local:RibbonTooltip.KeyTip="AB"
                                                              local:RibbonTooltip.Description="View version and license information about Freexcel."/>
                                <Button Content="Send Feedback"  Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SendFeedbackBtn_Click"
                                        local:RibbonTooltip.Title="Send Feedback"
                                        local:RibbonTooltip.KeyTip="FE"
                                        local:RibbonTooltip.Description="Send suggestions or report issues with Freexcel."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Help" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

        </TabControl>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 2  Formula bar
             ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="FormulaBarBorder" Grid.Row="2" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Background="White" Padding="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="CellAddressBox" Grid.Column="0" Text="A1"
                         FontFamily="Consolas" FontSize="13"
                         TextOptions.TextFormattingMode="Display"
                         TextOptions.TextRenderingMode="ClearType"
                         TextOptions.TextHintingMode="Fixed"
                         VerticalContentAlignment="Center"
                         BorderBrush="#C0C0C0" Padding="4,2"
                         AutomationProperties.Name="Name Box"
                         AutomationProperties.HelpText="Go to a cell or named range"/>

                <!-- fx button opens Insert Function dialog -->
                <Button Grid.Column="1" Content=" fx " FontWeight="Bold" Foreground="#444"
                        Background="Transparent" BorderThickness="0"
                        Padding="2,0" VerticalAlignment="Center" Margin="2,0" Cursor="Hand"
                        FontSize="12" FontStyle="Italic"
                        Click="InsertFunctionBtn_Click"
                        local:RibbonTooltip.Title="Insert Function"
                        local:RibbonTooltip.KeyTip="FX"
                        local:RibbonTooltip.Description="Search for and insert a function into the selected cell."/>

                <Grid Grid.Column="2">
                    <TextBlock x:Name="FormulaBarReferenceOverlay"
                               Margin="6,3,4,2"
                               FontFamily="Calibri"
                               FontSize="15"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               TextOptions.TextFormattingMode="Display"
                               TextOptions.TextRenderingMode="ClearType"
                               TextOptions.TextHintingMode="Fixed"/>
                    <TextBox x:Name="FormulaBar" FontFamily="Calibri" FontSize="15"
                             TextOptions.TextFormattingMode="Display"
                             TextOptions.TextRenderingMode="ClearType"
                             TextOptions.TextHintingMode="Fixed"
                             AcceptsReturn="True"
                             Background="Transparent"
                             CaretBrush="Black"
                             VerticalContentAlignment="Center" BorderBrush="#C0C0C0" Padding="4,2"
                             AutomationProperties.Name="Formula Bar"
                             AutomationProperties.HelpText="Edit the active cell value or formula"
                             PreviewKeyDown="FormulaBar_KeyDown"/>
                </Grid>

                <!-- Expand/collapse chevron -->
                <Button x:Name="FormulaBarExpandBtn" Grid.Column="3"
                        Content="▼" Width="18" Height="18"
                        Background="Transparent" BorderThickness="0"
                        FontSize="9" Padding="0" Margin="2,0,0,0"
                        VerticalAlignment="Top" Cursor="Hand"
                        Click="FormulaBarExpandBtn_Click"
                        local:RibbonTooltip.Title="Expand Formula Bar"
                        local:RibbonTooltip.KeyTip="BX"
                        local:RibbonTooltip.Description="Expand or collapse the formula bar."/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 3  Spreadsheet grid
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:GridView x:Name="SheetGrid" Grid.Column="0"/>
            <!-- Inline cell edit overlay: a Canvas with a positioned TextBox -->
            <Canvas x:Name="EditOverlay" Grid.Column="0"
                    IsHitTestVisible="False" Panel.ZIndex="20"/>

            <ScrollBar x:Name="VerticalScroll" Grid.Column="1"
                       Orientation="Vertical" Minimum="1" Maximum="1000000" Value="1" SmallChange="1"
                       AutomationProperties.Name="Vertical Worksheet Scroll Bar"
                       AutomationProperties.HelpText="Scroll worksheet rows"/>

            <Border x:Name="PivotFieldListPane"
                    Grid.Column="2"
                    Width="320"
                    Background="#F7F7F7"
                    BorderBrush="#C8C8C8"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed"
                    KeyboardNavigation.TabNavigation="Cycle"
                    AutomationProperties.Name="PivotTable Fields">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <Button Content="X"
                                Width="22"
                                Height="22"
                                DockPanel.Dock="Right"
                                Padding="0"
                                Click="PivotFieldListCloseBtn_Click"
                                AutomationProperties.Name="Close PivotTable Fields"/>
                        <TextBlock Text="PivotTable Fields"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Text="Choose fields to add to report:"
                               FontSize="12"
                               Margin="0,12,0,4"/>
                    <TextBox x:Name="PivotFieldListSearchBox"
                             Grid.Row="2"
                             Height="24"
                             Margin="0,0,0,6"
                             VerticalContentAlignment="Center"
                             TextChanged="PivotFieldListSearchBox_TextChanged"
                             AutomationProperties.Name="Search PivotTable Fields"/>
                    <ListBox x:Name="PivotAvailableFieldsList"
                             Grid.Row="3"
                             MinHeight="120"
                             SelectionMode="Single"
                             AllowDrop="True"
                             PreviewMouseMove="PivotFieldList_PreviewMouseMove"
                             Drop="PivotFieldList_Drop"
                             AutomationProperties.Name="Available PivotTable Fields">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Caption}"
                                          IsChecked="{Binding IsChecked}"
                                          Click="PivotAvailableFieldCheckBox_Click"
                                          local:RibbonTooltip.Title="{Binding Caption}"
                                          local:RibbonTooltip.KeyTip="F"
                                          local:RibbonTooltip.Description="Add or remove this field from the active PivotTable layout."
                                          AutomationProperties.Name="{Binding Caption}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Sort A to Z" local:RibbonTooltip.KeyTip="S" Click="PivotFieldSortAscendingMenuItem_Click"/>
                                <MenuItem Header="Sort Z to A" local:RibbonTooltip.KeyTip="O" Click="PivotFieldSortDescendingMenuItem_Click"/>
                                <MenuItem Header="Select Items..." local:RibbonTooltip.KeyTip="I" Click="PivotFieldSelectItemsMenuItem_Click"/>
                                <MenuItem Header="Label Filter..." local:RibbonTooltip.KeyTip="L" Click="PivotFieldLabelFilterMenuItem_Click"/>
                                <MenuItem Header="Value Filter..." local:RibbonTooltip.KeyTip="F" Click="PivotFieldValueFilterMenuItem_Click"/>
                                <MenuItem Header="Clear Filter" local:RibbonTooltip.KeyTip="C" Click="PivotFieldClearFilterMenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="Value Field Settings..." local:RibbonTooltip.KeyTip="V" Click="PivotFieldValueSettingsMenuItem_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>

                    <StackPanel Grid.Row="4" Margin="0,8,0,8">
                        <UniformGrid Columns="5">
                            <Button Content="Rows" Click="PivotFieldToRowsBtn_Click" Margin="1" MinHeight="24" AutomationProperties.Name="Add selected PivotTable field to Rows"/>
                            <Button Content="Columns" Click="PivotFieldToColumnsBtn_Click" Margin="1" MinHeight="24" AutomationProperties.Name="Add selected PivotTable field to Columns"/>
                            <Button Content="Values" Click="PivotFieldToValuesBtn_Click" Margin="1" MinHeight="24" AutomationProperties.Name="Add selected PivotTable field to Values"/>
                            <Button Content="Filters" Click="PivotFieldToFiltersBtn_Click" Margin="1" MinHeight="24" AutomationProperties.Name="Add selected PivotTable field to Filters"/>
                            <Button Content="_Remove" Click="PivotFieldRemoveBtn_Click" Margin="1" MinHeight="24" AutomationProperties.Name="Remove selected PivotTable field"/>
                        </UniformGrid>
                        <DockPanel Margin="0,6,0,0" LastChildFill="False">
                            <CheckBox x:Name="PivotFieldListDeferLayoutCheckBox"
                                      Content="Defer Layout Update"
                                      VerticalAlignment="Center"
                                      DockPanel.Dock="Left"
                                      Click="PivotFieldListDeferLayoutCheckBox_Click"
                                      local:RibbonTooltip.Title="Defer Layout Update"
                                      local:RibbonTooltip.Description="Queue PivotTable field layout changes until you choose Update."
                                      local:RibbonTooltip.KeyTip="DU"
                                      AutomationProperties.Name="Defer PivotTable Layout Update"/>
                            <Button x:Name="PivotFieldListUpdateBtn"
                                    Content="Update"
                                    MinWidth="72"
                                    MinHeight="24"
                                    DockPanel.Dock="Right"
                                    Click="PivotFieldListUpdateBtn_Click"
                                    AutomationProperties.Name="Update PivotTable Layout"/>
                        </DockPanel>
                    </StackPanel>

                    <Grid Grid.Row="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Filters" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Columns" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <ListBox x:Name="PivotFiltersList"
                                 Grid.Row="1"
                                 Grid.Column="0"
                                 MinHeight="80"
                                 SelectionMode="Single"
                                 AllowDrop="True"
                                 PreviewMouseMove="PivotFieldList_PreviewMouseMove"
                                 Drop="PivotFieldList_Drop"
                                 AutomationProperties.Name="PivotTable Filters Area">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Sort A to Z" local:RibbonTooltip.KeyTip="S" Click="PivotFieldSortAscendingMenuItem_Click"/>
                                    <MenuItem Header="Sort Z to A" local:RibbonTooltip.KeyTip="O" Click="PivotFieldSortDescendingMenuItem_Click"/>
                                    <MenuItem Header="Select Items..." local:RibbonTooltip.KeyTip="I" Click="PivotFieldSelectItemsMenuItem_Click"/>
                                    <MenuItem Header="Label Filter..." local:RibbonTooltip.KeyTip="L" Click="PivotFieldLabelFilterMenuItem_Click"/>
                                    <MenuItem Header="Value Filter..." local:RibbonTooltip.KeyTip="F" Click="PivotFieldValueFilterMenuItem_Click"/>
                                    <MenuItem Header="Clear Filter" local:RibbonTooltip.KeyTip="C" Click="PivotFieldClearFilterMenuItem_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Value Field Settings..." local:RibbonTooltip.KeyTip="V" Click="PivotFieldValueSettingsMenuItem_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                        <ListBox x:Name="PivotColumnsList"
                                 Grid.Row="1"
                                 Grid.Column="2"
                                 MinHeight="80"
                                 SelectionMode="Single"
                                 AllowDrop="True"
                                 PreviewMouseMove="PivotFieldList_PreviewMouseMove"
                                 Drop="PivotFieldList_Drop"
                                 AutomationProperties.Name="PivotTable Columns Area">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Sort A to Z" local:RibbonTooltip.KeyTip="S" Click="PivotFieldSortAscendingMenuItem_Click"/>
                                    <MenuItem Header="Sort Z to A" local:RibbonTooltip.KeyTip="O" Click="PivotFieldSortDescendingMenuItem_Click"/>
                                    <MenuItem Header="Select Items..." local:RibbonTooltip.KeyTip="I" Click="PivotFieldSelectItemsMenuItem_Click"/>
                                    <MenuItem Header="Label Filter..." local:RibbonTooltip.KeyTip="L" Click="PivotFieldLabelFilterMenuItem_Click"/>
                                    <MenuItem Header="Value Filter..." local:RibbonTooltip.KeyTip="F" Click="PivotFieldValueFilterMenuItem_Click"/>
                                    <MenuItem Header="Clear Filter" local:RibbonTooltip.KeyTip="C" Click="PivotFieldClearFilterMenuItem_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Value Field Settings..." local:RibbonTooltip.KeyTip="V" Click="PivotFieldValueSettingsMenuItem_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Rows" FontWeight="SemiBold" Margin="0,8,0,3"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Values" FontWeight="SemiBold" Margin="0,8,0,3"/>
                        <ListBox x:Name="PivotRowsList"
                                 Grid.Row="3"
                                 Grid.Column="0"
                                 MinHeight="80"
                                 SelectionMode="Single"
                                 AllowDrop="True"
                                 PreviewMouseMove="PivotFieldList_PreviewMouseMove"
                                 Drop="PivotFieldList_Drop"
                                 AutomationProperties.Name="PivotTable Rows Area">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Sort A to Z" local:RibbonTooltip.KeyTip="S" Click="PivotFieldSortAscendingMenuItem_Click"/>
                                    <MenuItem Header="Sort Z to A" local:RibbonTooltip.KeyTip="O" Click="PivotFieldSortDescendingMenuItem_Click"/>
                                    <MenuItem Header="Select Items..." local:RibbonTooltip.KeyTip="I" Click="PivotFieldSelectItemsMenuItem_Click"/>
                                    <MenuItem Header="Label Filter..." local:RibbonTooltip.KeyTip="L" Click="PivotFieldLabelFilterMenuItem_Click"/>
                                    <MenuItem Header="Value Filter..." local:RibbonTooltip.KeyTip="F" Click="PivotFieldValueFilterMenuItem_Click"/>
                                    <MenuItem Header="Clear Filter" local:RibbonTooltip.KeyTip="C" Click="PivotFieldClearFilterMenuItem_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Value Field Settings..." local:RibbonTooltip.KeyTip="V" Click="PivotFieldValueSettingsMenuItem_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                        <ListBox x:Name="PivotValuesList"
                                 Grid.Row="3"
                                 Grid.Column="2"
                                 MinHeight="80"
                                 SelectionMode="Single"
                                 AllowDrop="True"
                                 PreviewMouseMove="PivotFieldList_PreviewMouseMove"
                                 Drop="PivotFieldList_Drop"
                                 AutomationProperties.Name="PivotTable Values Area">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Sort A to Z" local:RibbonTooltip.KeyTip="S" Click="PivotFieldSortAscendingMenuItem_Click"/>
                                    <MenuItem Header="Sort Z to A" local:RibbonTooltip.KeyTip="O" Click="PivotFieldSortDescendingMenuItem_Click"/>
                                    <MenuItem Header="Select Items..." local:RibbonTooltip.KeyTip="I" Click="PivotFieldSelectItemsMenuItem_Click"/>
                                    <MenuItem Header="Label Filter..." local:RibbonTooltip.KeyTip="L" Click="PivotFieldLabelFilterMenuItem_Click"/>
                                    <MenuItem Header="Value Filter..." local:RibbonTooltip.KeyTip="F" Click="PivotFieldValueFilterMenuItem_Click"/>
                                    <MenuItem Header="Clear Filter" local:RibbonTooltip.KeyTip="C" Click="PivotFieldClearFilterMenuItem_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Value Field Settings..." local:RibbonTooltip.KeyTip="V" Click="PivotFieldValueSettingsMenuItem_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="SlicerTimelinePane"
                    Grid.Column="3"
                    Width="280"
                    Background="#FFFFFF"
                    BorderBrush="#C8C8C8"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed"
                    KeyboardNavigation.TabNavigation="Cycle"
                    AutomationProperties.Name="Slicers and Timelines">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <DockPanel LastChildFill="True" Margin="0,0,0,8">
                            <Button Content="X"
                                    Width="22"
                                    Height="22"
                                    DockPanel.Dock="Right"
                                    Padding="0"
                                    Click="SlicerTimelinePaneCloseBtn_Click"
                                    AutomationProperties.Name="Close Slicers and Timelines"/>
                            <TextBlock Text="Slicers and Timelines"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <ItemsControl x:Name="SlicerItemsControl"
                                      AutomationProperties.Name="Workbook Slicers">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,10" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding FieldName}" FontSize="11" Foreground="#666" Margin="0,1,0,6"/>
                                            <ItemsControl ItemsSource="{Binding Tiles}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Caption}"
                                                                Tag="{Binding SlicerName}"
                                                                Click="SlicerTileButton_Click"
                                                                MinHeight="24"
                                                                Margin="0,1"
                                                                HorizontalContentAlignment="Left"
                                                                AutomationProperties.Name="{Binding Caption}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Content="Clear Filter"
                                                    Tag="{Binding Name}"
                                                    Click="SlicerClearButton_Click"
                                                    Margin="0,6,0,0"
                                                    MinHeight="24"
                                                    AutomationProperties.Name="Clear Slicer Filter"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl x:Name="TimelineItemsControl"
                                      AutomationProperties.Name="Workbook Timelines">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,10" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding FieldName}" FontSize="11" Foreground="#666" Margin="0,1,0,6"/>
                                            <UniformGrid Columns="2">
                                                <TextBox x:Name="TimelineStartBox" Text="{Binding SelectedStartDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,3,0"/>
                                                <TextBox x:Name="TimelineEndBox" Text="{Binding SelectedEndDate, UpdateSourceTrigger=PropertyChanged}" Margin="3,0,0,0"/>
                                            </UniformGrid>
                                            <UniformGrid Columns="2" Margin="0,6,0,0">
                                            <Button Content="Apply" Click="TimelineApplyButton_Click" MinHeight="24" Margin="0,0,3,0"
                                                    AutomationProperties.Name="Apply timeline filter"/>
                                            <Button Content="Clear" Click="TimelineClearButton_Click" MinHeight="24" Margin="3,0,0,0"
                                                    AutomationProperties.Name="Clear timeline filter"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 4  Sheet tabs
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="{StaticResource FreexcelSheetSurfaceBrush}" BorderBrush="{StaticResource FreexcelBorderBrush}"
                BorderThickness="0" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="SheetNavLeftBtn" Grid.Column="0" Content="&lt;" Width="20" Height="20" Padding="0"
                        FontSize="11" Background="Transparent" BorderBrush="{StaticResource FreexcelBorderStrongBrush}" BorderThickness="1"
                        Cursor="Hand" Click="SheetNavLeftBtn_Click" Visibility="Hidden" Margin="2,0,0,0"
                        local:RibbonTooltip.Title="Scroll Tabs Left"
                        local:RibbonTooltip.KeyTip="SL"
                        local:RibbonTooltip.Description="Scroll the sheet tab list to the left."/>

                <!-- Sheet tabs in a clipped, scrollbar-free viewport -->
                <ScrollViewer x:Name="SheetTabsScroller" Grid.Column="1"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              ScrollChanged="SheetTabsScroller_ScrollChanged"
                              SizeChanged="SheetTabsScroller_SizeChanged"
                              Loaded="SheetTabsScroller_Loaded">
                        <ItemsControl x:Name="SheetTabsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="TabBorder"
                                            CornerRadius="3,3,0,0" Padding="10,3,10,1"
                                            Cursor="Hand"
                                            Focusable="True"
                                            MouseLeftButtonDown="SheetTab_MouseLeftButtonDown"
                                            MouseMove="SheetTab_MouseMove"
                                            MouseLeftButtonUp="SheetTab_MouseLeftButtonUp"
                                            MouseRightButtonDown="SheetTab_MouseRightButtonDown">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"       Value="{Binding TabBrush}"/>
                                                <Setter Property="BorderBrush"      Value="{StaticResource FreexcelBorderBrush}"/>
                                                <Setter Property="BorderThickness"  Value="1"/>
                                                <Setter Property="Margin"           Value="2,0,0,0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGrouped}" Value="True">
                                                        <Setter Property="Background"      Value="{StaticResource FreexcelRibbonSurfaceBrush}"/>
                                                        <Setter Property="BorderBrush"     Value="{StaticResource FreexcelRibbonSurfaceBrush}"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Margin"          Value="2,-1,0,0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background"      Value="{StaticResource FreexcelRibbonSurfaceBrush}"/>
                                                        <Setter Property="BorderBrush"     Value="{StaticResource FreexcelRibbonSurfaceBrush}"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Margin"          Value="2,-1,0,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Rename…"         local:RibbonTooltip.KeyTip="R" Click="SheetCtxRename_Click"/>
                                                <MenuItem Header="Insert Sheet"    local:RibbonTooltip.KeyTip="I" Click="SheetCtxInsert_Click"/>
                                                <MenuItem Header="Duplicate"       local:RibbonTooltip.KeyTip="D" Click="SheetCtxDuplicate_Click"/>
                                                <MenuItem Header="Delete Sheet"    local:RibbonTooltip.KeyTip="E" Click="SheetCtxDelete_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Hide"            local:RibbonTooltip.KeyTip="H" Click="SheetCtxHide_Click"/>
                                                <MenuItem Header="Unhide…"         local:RibbonTooltip.KeyTip="U" Click="SheetCtxUnhide_Click"/>
                                                <MenuItem Header="Tab Color…"      local:RibbonTooltip.KeyTip="T" Click="SheetCtxTabColor_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Select All Sheets" local:RibbonTooltip.KeyTip="A" Click="SheetCtxSelectAllSheets_Click"/>
                                                <MenuItem Header="Ungroup Sheets"    local:RibbonTooltip.KeyTip="G" Click="SheetCtxUngroupSheets_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Move Left"       local:RibbonTooltip.KeyTip="L" Click="SheetCtxMoveLeft_Click"/>
                                                <MenuItem Header="Move Right"      local:RibbonTooltip.KeyTip="M" Click="SheetCtxMoveRight_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid MouseDown="SheetTab_LabelMouseDown">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="2"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding Name}" FontSize="13">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsGrouped}" Value="True">
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Border Grid.Row="1" Height="2" Margin="0,1,0,0"
                                                    Background="{StaticResource FreexcelGreenBrush}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsGrouped}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                </ScrollViewer>

                <Button x:Name="SheetNavRightBtn" Grid.Column="2" Content="&gt;" Width="20" Height="20" Padding="0"
                        FontSize="11" Background="Transparent" BorderBrush="{StaticResource FreexcelBorderStrongBrush}" BorderThickness="1"
                        Cursor="Hand" Click="SheetNavRightBtn_Click" Visibility="Hidden" Margin="2,0,0,0"
                        local:RibbonTooltip.Title="Scroll Tabs Right"
                        local:RibbonTooltip.KeyTip="SR"
                        local:RibbonTooltip.Description="Scroll the sheet tab list to the right."/>

                <Button x:Name="AddSheetButton" Grid.Column="3" Content="+" Width="26" Height="22"
                        FontSize="14" Margin="4,0" Padding="0"
                        Background="Transparent" BorderBrush="{StaticResource FreexcelBorderStrongBrush}" BorderThickness="1"
                        VerticalAlignment="Center" Cursor="Hand"
                        Click="AddSheetButton_Click"
                        local:RibbonTooltip.Title="Insert Sheet"
                        local:RibbonTooltip.KeyTip="IS"
                        local:RibbonTooltip.Description="Add a new sheet to the workbook."/>

                <!-- Horizontal scrollbar (Excel-style, right of sheet tabs) -->
                <ScrollBar x:Name="HorizontalScroll" Grid.Column="4"
                           Orientation="Horizontal" Minimum="1" Maximum="16384" Value="1"
                           SmallChange="1" VerticalAlignment="Center" Margin="2,0"
                           AutomationProperties.Name="Horizontal Worksheet Scroll Bar"
                           AutomationProperties.HelpText="Scroll worksheet columns"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 5  Status bar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="5" Background="{StaticResource FreexcelStatusSurfaceBrush}" Padding="8,3"
                ClipToBounds="True">
            <Grid x:Name="StatusBarGrid" ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusReadyText" Grid.Column="0" Text="Ready" Foreground="White"
                           FontSize="12" VerticalAlignment="Center"/>

                <Border x:Name="StatusStatsViewport" Grid.Column="1"
                        Margin="8,0,12,0"
                        ClipToBounds="True">
                    <StackPanel x:Name="StatusStatsPanel" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Visibility="Collapsed"
                                ClipToBounds="True">
                        <TextBlock x:Name="StatusAvgText" Foreground="White" FontSize="12"
                                   Margin="0,0,16,0" MaxWidth="140" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="StatusCountText" Foreground="White" FontSize="12"
                                   Margin="0,0,16,0" MaxWidth="110" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="StatusSumText" Foreground="White" FontSize="12"
                                   Margin="0,0,16,0" MaxWidth="140" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="StatusMinText" Foreground="White" FontSize="12"
                                   Margin="0,0,16,0" MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="StatusMaxText" Foreground="White" FontSize="12"
                                   MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <!-- Zoom controls on the right -->
                <StackPanel x:Name="StatusZoomControls" Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            MinWidth="210"
                            Background="{StaticResource FreexcelStatusSurfaceBrush}"
                            Panel.ZIndex="1">
                    <Button x:Name="StatusZoomOutButton" Content="−" Width="18" Height="18" Margin="0,0,2,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="14" Padding="0"
                            VerticalAlignment="Center" Cursor="Hand" Click="ZoomOutBtn_Click"
                            local:RibbonTooltip.Title="Zoom Out"
                            local:RibbonTooltip.KeyTip="SZ"/>
                    <Slider x:Name="ZoomSlider" Width="120" Minimum="0" Maximum="200" Value="100"
                            VerticalAlignment="Center" Margin="0,0,2,0"
                            AutomationProperties.Name="Zoom Slider"
                            AutomationProperties.HelpText="Adjust worksheet zoom from 10% to 400%"
                            ToolTip="Zoom"
                            SmallChange="5" LargeChange="10"
                            TickPlacement="BottomRight" Ticks="100" IsSnapToTickEnabled="False"
                            ValueChanged="ZoomSlider_ValueChanged"/>
                    <Button x:Name="StatusZoomInButton" Content="+" Width="18" Height="18" Margin="0,0,6,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="14" Padding="0"
                            VerticalAlignment="Center" Cursor="Hand" Click="ZoomInBtn_Click"
                            local:RibbonTooltip.Title="Zoom In"
                            local:RibbonTooltip.KeyTip="SX"/>
                    <TextBlock x:Name="StatusZoomText" Text="100%" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" Width="38"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             START SCREEN — full-window overlay shown at launch / via ← Home
             ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="OpenProgressOverlay"
                Grid.Row="1" Grid.RowSpan="5"
                Panel.ZIndex="260"
                Background="#80FFFFFF"
                Visibility="Collapsed">
            <Border Width="360" Padding="22" Background="White"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="OpenProgressTitle"
                               Text="Opening workbook"
                               FontSize="16" Foreground="#1F1F1F"
                               Margin="0,0,0,10"/>
                    <ProgressBar x:Name="OpenProgressBar"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 IsIndeterminate="True"
                                 Foreground="#217346"
                                 AutomationProperties.Name="Opening Progress"/>
                    <TextBlock x:Name="OpenProgressDetail"
                               Text="Reading file..."
                               FontSize="12" Foreground="#666"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Border>

        <Grid x:Name="StartScreenOverlay"
              Grid.Row="1" Grid.RowSpan="5"
              Panel.ZIndex="200"
              PreviewKeyDown="StartScreenOverlay_PreviewKeyDown"
              KeyboardNavigation.TabNavigation="Cycle"
              KeyboardNavigation.ControlTabNavigation="Cycle"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left sidebar ─────────────────────────────────────────── -->
            <DockPanel x:Name="StartScreenSidebar" Grid.Column="0" Background="#1C3E2E" LastChildFill="True">

                <!-- Back arrow -->
	                <Button x:Name="SsBackBtn" DockPanel.Dock="Top"
	                        HorizontalAlignment="Left"
	                        Style="{StaticResource SsNavBtn}"
	                        Padding="18,11" FontSize="18"
	                        Click="SsBackBtn_Click"
	                        ToolTip="Back to workbook"
	                        local:RibbonTooltip.Title="Back"
	                        local:RibbonTooltip.KeyTip="B">
                    <local:RibbonIcon Kind="Previous" IconSize="18" Foreground="{StaticResource FreexcelWhiteBrush}"/>
                </Button>

                <!-- Home (active/selected when showing home view) -->
                <Button x:Name="SsHomeNavBtn" DockPanel.Dock="Top"
                        Content="Home" HorizontalAlignment="Stretch"
                        Style="{StaticResource SsNavBtnActive}"
                        Click="SsHomeNavBtn_Click"
                        local:RibbonTooltip.Title="Home"
                        local:RibbonTooltip.KeyTip="H"/>

                <!-- Account / Options pinned to bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,10">
                    <Rectangle Height="1" Fill="#2C5C40" Margin="0,0,0,6"/>
                    <local:AutomationInvokeButton x:Name="SsAccountNavBtn"
                                                  Content="Account" HorizontalAlignment="Stretch"
                                                  Style="{StaticResource SsNavBtn}"
                                                  Click="SsAccountBtn_Click"
                                                  IsTabStop="True"
                                                  AutomationProperties.Name="Account"
                                                  AutomationProperties.AutomationId="BackstageAccountButton"
                                                  AutomationProperties.HelpText="Show local account information for Freexcel."
                                                  local:RibbonTooltip.Title="Local Account"
                                                  local:RibbonTooltip.KeyTip="AC"
                                                  local:RibbonTooltip.Description="Microsoft account integration is not implemented; Freexcel uses local files and local options."/>
                    <local:AutomationInvokeButton x:Name="SsOptionsNavBtn"
                                                  Content="Options" HorizontalAlignment="Stretch"
                                                  Style="{StaticResource SsNavBtn}"
                                                  Click="SsOptionsBtn_Click"
                                                  IsTabStop="True"
                                                  AutomationProperties.Name="Options"
                                                  AutomationProperties.AutomationId="BackstageOptionsButton"
                                                  AutomationProperties.HelpText="Open Freexcel settings and formula error checking options."
                                                  local:RibbonTooltip.Title="Options"
                                                  local:RibbonTooltip.KeyTip="T"/>
                </StackPanel>

                <!-- Navigation items -->
                <StackPanel>
                    <Button Content="New" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SsNewBtn_Click"
                            local:RibbonTooltip.Title="New"
                            local:RibbonTooltip.KeyTip="N"/>
                    <Button Content="Open" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SsOpenBtn_Click"
                            local:RibbonTooltip.Title="Open"
                            local:RibbonTooltip.KeyTip="O"/>
                    <Button Content="Share" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SsShareBtn_Click"
                            local:RibbonTooltip.Title="Share"
                            local:RibbonTooltip.KeyTip="SH"
                            local:RibbonTooltip.Description="Save the workbook if needed and open Windows Share for the file."/>

                    <Rectangle Height="1" Fill="#2C5C40" Margin="0,6"/>

                    <Button x:Name="SsInfoNavBtn" Content="Info"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SsInfoBtn_Click"
                            local:RibbonTooltip.Title="Info"
                            local:RibbonTooltip.KeyTip="I"/>
                    <Button Content="_Save" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SaveButton_Click"
                            local:RibbonTooltip.Title="Save"
                            local:RibbonTooltip.KeyTip="S"/>
                    <Button Content="Save _As" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SaveAsButton_Click"
                            local:RibbonTooltip.Title="Save As"
                            local:RibbonTooltip.KeyTip="A"/>
                    <Button x:Name="SsPrintNavBtn" Content="Print" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="PrintButton_Click"
                            local:RibbonTooltip.Title="Print"
                            local:RibbonTooltip.KeyTip="P"
                            local:RibbonTooltip.Description="Open the print preview and native print dialog for the rendered worksheet."/>
                    <Button Content="Export" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="ExportPdfButton_Click"
                            local:RibbonTooltip.Title="Export PDF/XPS"
                            local:RibbonTooltip.KeyTip="E"
                            local:RibbonTooltip.Description="Save sheets, the current selection, or the workbook as a PDF file or an XPS package."/>
                    <Button Content="_Close" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SsCloseBtn_Click"
                            local:RibbonTooltip.Title="Close"
                            local:RibbonTooltip.KeyTip="C"/>
                </StackPanel>
            </DockPanel>

            <!-- ── Right content area ───────────────────────────────────── -->
            <Grid Grid.Column="1" Background="White">

                <!-- ══ HOME VIEW ════════════════════════════════════════════ -->
                <Grid x:Name="SsHomeView">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Greeting -->
                    <RowDefinition Height="Auto"/>  <!-- New section -->
                    <RowDefinition Height="*"/>     <!-- Recent files -->
                </Grid.RowDefinitions>

                <!-- Greeting -->
                <TextBlock x:Name="SsGreeting" Grid.Row="0"
                           FontSize="28" FontWeight="Light" Foreground="#1F1F1F"
                           Margin="40,36,40,0"/>

                <!-- New section -->
                <Border Grid.Row="1" Padding="40,18,40,6">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,10">
                            <TextBlock DockPanel.Dock="Left" Text="New"
                                       FontSize="14" FontWeight="SemiBold" Foreground="#1F1F1F"/>
                            <Button DockPanel.Dock="Right" Content="More templates (Excluded) →"
                                    Background="Transparent" BorderThickness="0" Padding="0"
                                    FontSize="12" Foreground="#217346"
                                    VerticalAlignment="Center" Cursor="Hand"
                                    Click="SsMoreTemplatesBtn_Click"
                                    local:RibbonTooltip.Title="More Templates Excluded"
                                    local:RibbonTooltip.KeyTip="MT"
                                    local:RibbonTooltip.Description="Online template discovery depends on an external Microsoft template service and is excluded."/>
                        </DockPanel>

                        <StackPanel Orientation="Horizontal">
                            <!-- Blank workbook card -->
                            <Button Click="SsBlankWorkbook_Click" Cursor="Hand" Margin="0,0,16,0"
                                    local:RibbonTooltip.Title="Blank Workbook"
                                    local:RibbonTooltip.KeyTip="B1">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="cardBg" Background="Transparent" Padding="4">
                                            <StackPanel Width="108">
                                                <!-- Mini spreadsheet thumbnail -->
                                                <Border Width="108" Height="80"
                                                        BorderBrush="#C8C8C8" BorderThickness="1"
                                                        Background="White" ClipToBounds="True">
                                                    <Canvas Width="108" Height="80">
                                                        <!-- Row-header strip -->
                                                        <Rectangle Canvas.Left="0" Canvas.Top="0"
                                                                   Width="18" Height="80" Fill="#F0F0F0"/>
                                                        <!-- Column-header strip -->
                                                        <Rectangle Canvas.Left="0" Canvas.Top="0"
                                                                   Width="108" Height="14" Fill="#F0F0F0"/>
                                                        <!-- Horizontal grid lines -->
                                                        <Line X1="0" Y1="27" X2="108" Y2="27"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <Line X1="0" Y1="40" X2="108" Y2="40"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <Line X1="0" Y1="53" X2="108" Y2="53"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <Line X1="0" Y1="66" X2="108" Y2="66"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <!-- Vertical grid lines -->
                                                        <Line X1="42" Y1="14" X2="42" Y2="80"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <Line X1="66" Y1="14" X2="66" Y2="80"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <Line X1="90" Y1="14" X2="90" Y2="80"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <!-- Selected cell A1 -->
                                                        <Rectangle Canvas.Left="18" Canvas.Top="14"
                                                                   Width="24" Height="13"
                                                                   Fill="#E8F5EC"/>
                                                        <Rectangle Canvas.Left="18" Canvas.Top="14"
                                                                   Width="24" Height="13"
                                                                   Stroke="#217346" StrokeThickness="1.5"
                                                                   Fill="Transparent"/>
                                                    </Canvas>
                                                </Border>
                                                <TextBlock Text="Blank workbook"
                                                           FontSize="12" Margin="0,6,0,2"
                                                           TextAlignment="Center"
                                                           Foreground="#1F1F1F"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="cardBg" Property="Background"
                                                        Value="#F0F6F2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Recent files -->
                <Grid Grid.Row="2" Margin="40,0,40,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Tabs + search -->
                        <RowDefinition Height="Auto"/> <!-- Column headers -->
                        <RowDefinition Height="*"/>    <!-- File list -->
                    </Grid.RowDefinitions>

                    <!-- Tabs row + search box -->
                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,0">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Button Background="Transparent" BorderThickness="0" Padding="0"
                                    Cursor="Hand" Click="SsRecentTab_Click"
                                    local:RibbonTooltip.Title="Recent"
                                    local:RibbonTooltip.KeyTip="RC">
                                <Border x:Name="SsRecentTab" Padding="0,8,22,8"
                                        BorderThickness="0,0,0,2" BorderBrush="#217346">
                                <TextBlock x:Name="SsRecentTabText" Text="Recent" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#217346"/>
                                </Border>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="0"
                                    Cursor="Hand" Click="SsPinnedTab_Click"
                                    local:RibbonTooltip.Title="Pinned"
                                    local:RibbonTooltip.KeyTip="PN">
                                <Border x:Name="SsPinnedTab" Padding="0,8,22,8"
                                        BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                <TextBlock x:Name="SsPinnedTabText" Text="Pinned" FontSize="13"
                                           Foreground="#888"/>
                                </Border>
                            </Button>
                        </StackPanel>
                        <Border DockPanel.Dock="Right"
                                Background="#F5F5F5" BorderBrush="#D8D8D8" BorderThickness="1"
                                CornerRadius="2" Padding="8,4" VerticalAlignment="Center">
                            <TextBox x:Name="SsSearchBox" Width="180" FontSize="12"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     AutomationProperties.Name="Search Recent Files"
                                     AutomationProperties.HelpText="Filter recent and pinned files"
                                     TextChanged="SsSearchBox_TextChanged"/>
                        </Border>
                    </DockPanel>

                    <!-- Column headers -->
                    <Border Grid.Row="1" BorderThickness="0,1,0,1" BorderBrush="#E4E4E4"
                            Padding="0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Name" FontSize="11" Foreground="#888"/>
                            <TextBlock Grid.Column="1" Text="Date modified" FontSize="11" Foreground="#888"/>
                        </Grid>
                    </Border>

                    <!-- File list (Recent) -->
                    <ScrollViewer x:Name="SsRecentScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="SsRecentList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button HorizontalContentAlignment="Stretch"
                                            BorderThickness="0" Padding="0,7"
                                            Click="SsRecentItem_Click"
                                            Cursor="Hand"
                                            AutomationProperties.Name="{Binding FileName}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Pin to list" local:RibbonTooltip.KeyTip="P" Click="SsPinItem_Click"/>
                                                <MenuItem Header="Remove from list" local:RibbonTooltip.KeyTip="R" Click="SsRemoveRecentItem_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="rowBg" Background="Transparent"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="rowBg" Property="Background"
                                                                Value="#F3F6F9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Border Width="26" Height="30" Background="#217346"
                                                        CornerRadius="2" Margin="0,0,10,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="X" Foreground="White"
                                                               FontSize="11" FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontSize="13" Foreground="#1F1F1F"/>
                                                    <TextBlock Text="{Binding Directory}"
                                                               FontSize="11" Foreground="#888"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LastOpenedText}"
                                                       FontSize="12" Foreground="#666"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Width="24" Height="24"
                                                    Style="{StaticResource RibbonBtn}"
                                                    Click="SsPinItem_Click"
                                                    local:RibbonTooltip.Title="Pin File"
                                                    local:RibbonTooltip.KeyTip="PI"
                                                    local:RibbonTooltip.Description="Pin or unpin this workbook in the recent files list."
                                                    AutomationProperties.Name="Pin file"
                                                    ToolTip="Pin to list">
                                                <local:RibbonIcon Kind="Pin" IconSize="12" HorizontalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- File list (Pinned) -->
                    <ScrollViewer x:Name="SsPinnedScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <ItemsControl x:Name="SsPinnedList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button HorizontalContentAlignment="Stretch"
                                            BorderThickness="0" Padding="0,7"
                                            Click="SsRecentItem_Click"
                                            Cursor="Hand"
                                            AutomationProperties.Name="{Binding FileName}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Unpin from list" local:RibbonTooltip.KeyTip="U" Click="SsUnpinItem_Click"/>
                                                <MenuItem Header="Remove from list" local:RibbonTooltip.KeyTip="R" Click="SsRemoveRecentItem_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="rowBg" Background="Transparent"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="rowBg" Property="Background"
                                                                Value="#F3F6F9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Border Width="26" Height="30" Background="#217346"
                                                        CornerRadius="2" Margin="0,0,10,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="X" Foreground="White"
                                                               FontSize="11" FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontSize="13" Foreground="#1F1F1F"/>
                                                    <TextBlock Text="{Binding Directory}"
                                                               FontSize="11" Foreground="#888"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LastOpenedText}"
                                                       FontSize="12" Foreground="#666"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Width="24" Height="24"
                                                    Style="{StaticResource RibbonBtn}"
                                                    Click="SsUnpinItem_Click"
                                                    local:RibbonTooltip.Title="Unpin File"
                                                    local:RibbonTooltip.KeyTip="UP"
                                                    local:RibbonTooltip.Description="Remove this workbook from the pinned files list."
                                                    AutomationProperties.Name="Unpin file"
                                                    ToolTip="Unpin from list">
                                                <local:RibbonIcon Kind="Pin" IconSize="12" HorizontalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
                </Grid><!-- end SsHomeView -->

                <!-- ══ INFO VIEW ════════════════════════════════════════════ -->
                <Grid x:Name="SsInfoView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Info"
                               FontSize="28" FontWeight="Light" Foreground="#1F1F1F"
                               Margin="40,36,40,0"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="40,24,40,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Workbook actions (left) -->
                            <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                <TextBlock Text="Protect Workbook"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Control what types of changes others can make."
                                           FontSize="12" Foreground="#555" TextWrapping="Wrap"
                                           Margin="0,0,0,20"/>
                                <TextBlock Text="Check Accessibility"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Find merged cells and objects missing alt text."
                                           FontSize="12" Foreground="#555" TextWrapping="Wrap"
                                           Margin="0,0,0,20"/>
                                <TextBlock Text="Manage Workbook"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Review local file status and unsupported workbook feature warnings."
                                           FontSize="12" Foreground="#555" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Properties (right) -->
                            <Border Grid.Column="1"
                                    BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                                    Padding="24,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Properties"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#555"
                                               Margin="0,0,0,14"/>

                                    <TextBlock Text="Workbook name" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoWorkbookName" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,12"/>

                                    <TextBlock Text="File path" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoFilePath" FontSize="12" Foreground="#555"
                                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                                    <TextBlock Text="Sheets" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoSheetCount" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,12"/>

                                    <TextBlock Text="Format" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoFormat" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,20"/>

                                    <TextBlock Text="Workbook statistics" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoStatisticsSummary" FontSize="12" Foreground="#555"
                                               TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,12"/>

                                    <TextBlock Text="Accessibility" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoAccessibilitySummary" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,20"/>

                                    <TextBlock Text="Formula errors" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoFormulaErrorSummary" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,20"/>

                                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,20"/>

                                    <TextBlock Text="About Freexcel"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#555"
                                               Margin="0,0,0,10"/>
                                    <TextBlock FontSize="12" Foreground="#555"
                                               TextWrapping="Wrap" LineHeight="20"
                                               Margin="0,0,0,6">Freexcel is a lightweight, open-format spreadsheet built on .NET 10 and WPF. Supports XLSX, formula calculation, cell styling, charts, and freeze panes.</TextBlock>
                                    <TextBlock Text="Version 0.5 (Phase 5)"
                                               FontSize="11" Foreground="#888"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid><!-- end SsInfoView -->

            </Grid>
        </Grid>

        <Canvas x:Name="KeyTipOverlay"
                Grid.RowSpan="6"
                Panel.ZIndex="1000"
                IsHitTestVisible="False"
                Visibility="Collapsed"/>

    </Grid>
</Window>

