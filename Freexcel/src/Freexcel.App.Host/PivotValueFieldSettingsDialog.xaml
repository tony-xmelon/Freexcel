<Window x:Class="Freexcel.App.Host.PivotValueFieldSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Value Field Settings"
        Width="430"
        Height="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="OkButton"
                    Content="OK"
                    Width="78"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Content="Cancel"
                    Width="78"
                    IsCancel="True"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="118"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Custom Name:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox x:Name="CustomNameBox"
                         Grid.Column="1"
                         AutomationProperties.Name="Custom name"/>
            </Grid>

            <TabControl Grid.Row="1">
                <TabItem Header="Summarize Values By">
                    <StackPanel Margin="10">
                        <TextBlock Text="Summarize value field by:" Margin="0,0,0,6"/>
                        <ComboBox x:Name="SummaryFunctionBox"
                                  Height="24"
                                  AutomationProperties.Name="Summarize value field by"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Show Values As">
                    <StackPanel Margin="10">
                        <TextBlock Text="Show values as:" Margin="0,0,0,6"/>
                        <ComboBox x:Name="ShowValuesAsBox"
                                  Height="24"
                                  AutomationProperties.Name="Show values as"/>
                        <TextBlock Text="Base field:" Margin="0,10,0,6"/>
                        <ComboBox x:Name="BaseFieldBox"
                                  Height="24"
                                  AutomationProperties.Name="Base field"/>
                        <TextBlock Text="Base item:" Margin="0,10,0,6"/>
                        <TextBox x:Name="BaseItemBox"
                                 Height="24"
                                 AutomationProperties.Name="Base item"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Number Format">
                    <StackPanel Margin="10">
                        <TextBlock Text="Format preset:" Margin="0,0,0,6"/>
                        <ComboBox x:Name="NumberFormatPresetBox"
                                  Height="24"
                                  AutomationProperties.Name="Number format preset"
                                  SelectionChanged="NumberFormatPresetBox_SelectionChanged"/>
                        <TextBlock Text="Number format ID:" Margin="0,10,0,6"/>
                        <TextBox x:Name="NumberFormatBox"
                                 Height="24"
                                 AutomationProperties.Name="Number format ID"/>
                        <TextBlock Text="Custom format code:" Margin="0,10,0,6"/>
                        <TextBox x:Name="NumberFormatCodeBox"
                                 Height="24"
                                 AutomationProperties.Name="Custom format code"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
