<Window x:Class="Freexcel.App.Host.PageSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Page Setup"
        Width="460" Height="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="_Page">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Orientation:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <ComboBox x:Name="OrientationBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                        <ComboBoxItem Content="Portrait" Tag="Portrait"/>
                        <ComboBoxItem Content="Landscape" Tag="Landscape"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Paper size:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <ComboBox x:Name="PaperSizeBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                        <ComboBoxItem Content="Letter (8.5 x 11)" Tag="Letter"/>
                        <ComboBoxItem Content="A4 (210 x 297 mm)" Tag="A4"/>
                        <ComboBoxItem Content="Legal (8.5 x 14)" Tag="Legal"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Scaling:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="ScaleBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="First page number:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="FirstPageNumberBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Print quality:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="PrintQualityBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"/>
                </Grid>
            </TabItem>

            <TabItem Header="_Margins">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Left:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="LeftMarginBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Right:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="RightMarginBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Top:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="TopMarginBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Bottom:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="BottomMarginBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Header:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="HeaderMarginBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Footer:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="FooterMarginBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,8"/>
                    <CheckBox x:Name="CenterHorizontallyBox" Grid.Row="6" Grid.Column="1" Content="_Center horizontally" Margin="0,4,0,8"/>
                    <CheckBox x:Name="CenterVerticallyBox" Grid.Row="7" Grid.Column="1" Content="Center _vertically"/>
                </Grid>
            </TabItem>

            <TabItem Header="_Sheet">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Rows to repeat:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="RowsRepeatBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Columns to repeat:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="ColumnsRepeatBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>
                    <CheckBox x:Name="PrintGridlinesBox" Grid.Row="2" Grid.Column="1" Content="_Print gridlines" Margin="0,0,0,8"/>
                    <CheckBox x:Name="PrintHeadingsBox" Grid.Row="3" Grid.Column="1" Content="Print row and column _headings" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Page order:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="PageOrderBox" Grid.Row="4" Grid.Column="1">
                        <ComboBoxItem Content="Down, then over" Tag="DownThenOver"/>
                        <ComboBoxItem Content="Over, then down" Tag="OverThenDown"/>
                    </ComboBox>
                    <CheckBox x:Name="PrintBlackAndWhiteBox" Grid.Row="5" Grid.Column="1" Content="_Black and white" Margin="0,8,0,8"/>
                    <CheckBox x:Name="PrintDraftQualityBox" Grid.Row="6" Grid.Column="1" Content="_Draft quality"/>
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Cell errors as:" VerticalAlignment="Center" Margin="0,8,8,0"/>
                    <ComboBox x:Name="PrintErrorValueBox" Grid.Row="7" Grid.Column="1" Margin="0,8,0,0">
                        <ComboBoxItem Content="Displayed" Tag="Displayed"/>
                        <ComboBoxItem Content="Blank" Tag="Blank"/>
                        <ComboBoxItem Content="--" Tag="Dash"/>
                        <ComboBoxItem Content="#N/A" Tag="NotAvailable"/>
                    </ComboBox>
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Comments:" VerticalAlignment="Center" Margin="0,8,8,0"/>
                    <ComboBox x:Name="PrintCommentsBox" Grid.Row="8" Grid.Column="1" Margin="0,8,0,0">
                        <ComboBoxItem Content="None" Tag="None"/>
                        <ComboBoxItem Content="At end of sheet" Tag="AtEnd"/>
                        <ComboBoxItem Content="As displayed on sheet" Tag="AsDisplayed"/>
                    </ComboBox>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="_OK" Width="72" Margin="0,0,8,0" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="_Cancel" Width="72" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
