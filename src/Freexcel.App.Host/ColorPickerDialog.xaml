<Window x:Class="Freexcel.App.Host.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Color"
        Width="460"
        Height="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="NoColorButton"
                    MinWidth="76"
                    Margin="0,0,8,0"
                    Content="_No Color"
                    Click="NoColorButton_Click"/>
            <Button MinWidth="76"
                    Margin="0,0,8,0"
                    Content="_OK"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button MinWidth="76"
                    Content="_Cancel"
                    IsCancel="True"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Theme Colors" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <UniformGrid x:Name="ThemeColorsPanel"
                         Columns="10"
                         Rows="6"
                         Margin="0,0,0,12"/>

            <TextBlock Text="Standard Colors" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <UniformGrid x:Name="StandardColorsPanel"
                         Columns="10"
                         Rows="1"
                         Margin="0,0,0,12"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Current" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Border Height="54"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CurrentForegroundPreview"
                                       Grid.Column="0"
                                       Text="Text"
                                       Background="White"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       VerticalAlignment="Stretch"
                                       Padding="4,16,4,0"/>
                            <Border x:Name="CurrentBackgroundPreview"
                                    Grid.Column="1">
                                <TextBlock x:Name="CurrentBackgroundText"
                                           Text="Fill"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           VerticalAlignment="Stretch"
                                           Padding="4,16,4,0"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="New" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Border Height="54"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NewForegroundPreview"
                                       Grid.Column="0"
                                       Text="Text"
                                       Background="White"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       VerticalAlignment="Stretch"
                                       Padding="4,16,4,0"/>
                            <Border x:Name="NewBackgroundPreview"
                                    Grid.Column="1">
                                <TextBlock x:Name="NewBackgroundText"
                                           Text="Fill"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           VerticalAlignment="Stretch"
                                           Padding="4,16,4,0"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Label Content="Custom _color"
                   Target="{Binding ElementName=CustomColorTextBox}"
                   FontWeight="SemiBold"
                   Padding="0"
                   Margin="0,0,0,6"/>
            <TextBox x:Name="CustomColorTextBox" TextChanged="CustomColorTextBox_TextChanged"/>
            <TextBlock Text="#RRGGBB or R, G, B"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       FontSize="11"
                       Margin="0,4,0,0"/>
        </StackPanel>
    </DockPanel>
</Window>
