<Window x:Class="FreeX.App.Host.GoalSeekDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FreeX.App.Host"
        Title="{local:Loc Key=GoalSeek_GoalSeek}" Width="380" Height="210"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="34"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: Set cell -->
        <Label Grid.Row="0" Grid.Column="0" Content="{local:Loc Key=GoalSeek_SetCell}" Target="{Binding ElementName=SetCellBox}" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="SetCellBox" Margin="0,4"
                 AutomationProperties.Name="{local:Loc Key=GoalSeek_SetCellAutomationName}"
                 AutomationProperties.AutomationId="GoalSeekSetCellBox"
                 AutomationProperties.HelpText="{local:Loc Key=GoalSeek_SetCellHelpText}"/>
        <Button Grid.Row="0" Grid.Column="2" Content="..." CommandParameter="SetCellBox"
                Click="RangePickerButton_Click" Margin="6,4,0,4" ToolTip="{local:Loc Key=GoalSeek_CollapseDialogAndSelectSetCellReference}"
                AutomationProperties.Name="{local:Loc Key=GoalSeek_SelectSetCellReference}"
                AutomationProperties.HelpText="{local:Loc Key=GoalSeek_CollapseDialogAndSelectTheSetCellReferenceFromTheWorkshe}"
                MinWidth="26" Padding="0"/>

        <!-- Row 1: To value -->
        <Label Grid.Row="1" Grid.Column="0" Content="{local:Loc Key=GoalSeek_ToValue}" Target="{Binding ElementName=ToValueBox}" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="ToValueBox" Margin="0,4"
                 AutomationProperties.Name="{local:Loc Key=GoalSeek_ToValueAutomationName}"
                 AutomationProperties.AutomationId="GoalSeekToValueBox"
                 AutomationProperties.HelpText="{local:Loc Key=GoalSeek_ToValueHelpText}"/>

        <!-- Row 2: By changing cell -->
        <Label Grid.Row="2" Grid.Column="0" Content="{local:Loc Key=GoalSeek_ByChangingCell}" Target="{Binding ElementName=ChangingCellBox}" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="ChangingCellBox" Margin="0,4"
                 AutomationProperties.Name="{local:Loc Key=GoalSeek_ByChangingCellAutomationName}"
                 AutomationProperties.AutomationId="GoalSeekChangingCellBox"
                 AutomationProperties.HelpText="{local:Loc Key=GoalSeek_ByChangingCellHelpText}"/>
        <Button Grid.Row="2" Grid.Column="2" Content="..." CommandParameter="ChangingCellBox"
                Click="RangePickerButton_Click" Margin="6,4,0,4" ToolTip="{local:Loc Key=GoalSeek_CollapseDialogAndSelectChangingCellReference}"
                AutomationProperties.Name="{local:Loc Key=GoalSeek_SelectChangingCellReference}"
                AutomationProperties.HelpText="{local:Loc Key=GoalSeek_CollapseDialogAndSelectTheChangingCellReferenceFromTheWo}"
                MinWidth="26" Padding="0"/>

        <!-- Row 4: Buttons -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{local:Loc Key=Common_Ok}"     Width="75" IsDefault="True"  Click="OkBtn_Click"     Margin="0,0,6,0"/>
            <Button Content="{local:Loc Key=Common_Cancel}" Width="75" IsCancel="True"   Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
