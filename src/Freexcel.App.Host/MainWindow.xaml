<Window x:Class="Freexcel.App.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:Freexcel.App.UI;assembly=Freexcel.App.UI"
        xmlns:local="clr-namespace:Freexcel.App.Host"
        mc:Ignorable="d"
        Title="Freexcel"
        Height="720" Width="1280"
        WindowState="Maximized"
        Background="#F0F0F0">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- ── Ribbon button styles ─────────────────────────────────────── -->

        <Style x:Key="RibbonBtn" TargetType="Button">
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="1,1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                    <Setter Property="BorderBrush" Value="#B8CFF0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C0D4F0"/>
                    <Setter Property="BorderBrush" Value="#6090C8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RibbonToggleBtn" TargetType="ToggleButton">
            <Setter Property="Padding" Value="3,2"/>
            <Setter Property="Margin" Value="1,1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                    <Setter Property="BorderBrush" Value="#B8CFF0"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#CCDEf8"/>
                    <Setter Property="BorderBrush" Value="#4080CC"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsChecked" Value="True"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#BBCEF5"/>
                    <Setter Property="BorderBrush" Value="#3070BB"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- Group label text style -->
        <Style x:Key="GroupLbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Ribbon tab item style — flat, green underline when selected -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="Transparent"
                                BorderThickness="0,0,0,3" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}" Margin="0,0,1,0"
                                Cursor="Hand">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#217346"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#EEF4EE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── System (caption) buttons ──────────────────────────────────── -->
        <Style x:Key="SysBtnStyle" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush"  Value="Transparent"/>
            <Setter Property="FontFamily"   Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="Width"        Value="46"/>
            <Setter Property="Padding"      Value="0"/>
            <Setter Property="Cursor"       Value="Arrow"/>
            <Setter Property="VerticalAlignment"        Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20000000"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#33000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseSysBtnStyle" BasedOn="{StaticResource SysBtnStyle}" TargetType="Button">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#F1707A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox: keep background white to match Excel toolbar -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- ── Start-screen sidebar buttons ─────────────────────────────── -->
        <Style x:Key="SsNavBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="24,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#265C40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SsNavBtnActive" BasedOn="{StaticResource SsNavBtn}" TargetType="Button">
            <Setter Property="Background" Value="#2D7254"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title / quick-access bar (QAT) -->
            <RowDefinition Height="Auto"/>
            <!-- Ribbon (tab strip + tab content) -->
            <RowDefinition Height="Auto"/>
            <!-- Formula bar -->
            <RowDefinition Height="Auto"/>
            <!-- Spreadsheet grid -->
            <RowDefinition Height="*"/>
            <!-- Sheet tabs -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 0  Title bar / Quick Access Toolbar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="6,3">
            <DockPanel>
                <!-- App icon -->
                <Border DockPanel.Dock="Left" Width="22" Height="22"
                        Background="#217346" CornerRadius="2" Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="X" Foreground="White" FontWeight="Bold" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <!-- QAT buttons -->
                <Button DockPanel.Dock="Left" Content="💾" Width="26" Height="22" Margin="0,0,2,0"
                        Style="{StaticResource RibbonBtn}" FontSize="13"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="SaveButton_Click"
                        local:RibbonTooltip.Title="Save"
                        local:RibbonTooltip.Description="Save the workbook."/>
                <Button x:Name="UndoQatBtn" DockPanel.Dock="Left" Content="↩" Width="26" Height="22" Margin="0,0,2,0"
                        Style="{StaticResource RibbonBtn}" FontSize="14"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="UndoQatBtn_Click"
                        local:RibbonTooltip.Title="Undo"
                        local:RibbonTooltip.Description="Undo the last action."/>
                <Button x:Name="RedoQatBtn" DockPanel.Dock="Left" Content="↪" Width="26" Height="22" Margin="0,0,8,0"
                        Style="{StaticResource RibbonBtn}" FontSize="14"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="RedoQatBtn_Click"
                        local:RibbonTooltip.Title="Redo"
                        local:RibbonTooltip.Description="Redo the last undone action."/>
                <!-- System buttons — must be docked Right before the fill element -->
                <!-- Order in XAML (Right-docked) is right-to-left, so Close first -->
                <Button x:Name="CloseSysBtn"    DockPanel.Dock="Right" Content="&#xE8BB;"
                        Style="{StaticResource CloseSysBtnStyle}" Click="CloseSysBtn_Click"/>
                <Button x:Name="MaxRestoreBtn"  DockPanel.Dock="Right" Content="&#xE739;"
                        Style="{StaticResource SysBtnStyle}"      Click="MaxRestoreBtn_Click"/>
                <Button                         DockPanel.Dock="Right" Content="&#xE949;"
                        Style="{StaticResource SysBtnStyle}"      Click="MinimizeBtn_Click"/>
                <!-- Workbook name centred -->
                <TextBlock x:Name="WorkbookNameText"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12" Foreground="#333"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 1  Ribbon  (tabbed, groups with labels)
             ═══════════════════════════════════════════════════════════════ -->
        <TabControl x:Name="RibbonTabs" Grid.Row="1" Background="White"
                    BorderThickness="0,0,0,1" BorderBrush="#D0D0D0"
                    Padding="0" TabStripPlacement="Top" SelectedIndex="1"
                    SelectionChanged="RibbonTabs_SelectionChanged">

            <!-- ── FILE — clicking opens the overlay; handler immediately switches back to Home -->
            <TabItem x:Name="FileTab" Header="File"/>

            <!-- ── HOME ──────────────────────────────────────────────── -->
            <TabItem Header="Home">
                <Border Background="White" Padding="4,3,4,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal">


                        <!-- ▌Clipboard ▌ -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="2,2,2,0">
                                <Button Click="PasteBtn_Click"
                                        Width="54" Height="36" Margin="1"
                                        Style="{StaticResource RibbonBtn}"
                                        local:RibbonTooltip.Title="Paste"
                                        local:RibbonTooltip.Description="Paste the contents of the Clipboard into the document.">
                                    <StackPanel>
                                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Paste" FontSize="10" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✂ Cut"  Click="CutBtn_Click"
                                            Width="54" Height="20" Margin="1,1"
                                            Style="{StaticResource RibbonBtn}" FontSize="10"
                                            local:RibbonTooltip.Title="Cut"
                                            local:RibbonTooltip.Description="Cut the selection and put it on the Clipboard."/>
                                    <Button Content="⧉ Copy" Click="CopyBtn_Click"
                                            Width="56" Height="20" Margin="1,1"
                                            Style="{StaticResource RibbonBtn}" FontSize="10"
                                            local:RibbonTooltip.Title="Copy"
                                            local:RibbonTooltip.Description="Copy the selection and put it on the Clipboard."/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
                                <TextBlock Text="Clipboard" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Font ▌ -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="FontNameBox" Width="116" Height="22" Margin="1,1,2,1"
                                              SelectionChanged="FontNameBox_SelectionChanged"
                                              local:RibbonTooltip.Title="Font"
                                              local:RibbonTooltip.Description="Change the font of the selected text."/>
                                    <ComboBox x:Name="FontSizeBox" Width="48" Height="22" Margin="1" IsEditable="True"
                                              SelectionChanged="FontSizeBox_SelectionChanged"
                                              local:RibbonTooltip.Title="Font Size"
                                              local:RibbonTooltip.Description="Change the font size of the selected text."/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <ToggleButton x:Name="BoldButton"      Width="24" Height="22"
                                                  Style="{StaticResource RibbonToggleBtn}" FontWeight="Bold"
                                                  Click="BoldButton_Click"
                                                  local:RibbonTooltip.Title="Bold"
                                                  local:RibbonTooltip.Description="Make the selected text bold.">B</ToggleButton>
                                    <ToggleButton x:Name="ItalicButton"    Width="24" Height="22"
                                                  Style="{StaticResource RibbonToggleBtn}" FontStyle="Italic"
                                                  Click="ItalicButton_Click"
                                                  local:RibbonTooltip.Title="Italic"
                                                  local:RibbonTooltip.Description="Italicize the selected text.">I</ToggleButton>
                                    <ToggleButton x:Name="UnderlineButton" Width="24" Height="22"
                                                  Style="{StaticResource RibbonToggleBtn}"
                                                  Click="UnderlineButton_Click"
                                                  local:RibbonTooltip.Title="Underline"
                                                  local:RibbonTooltip.Description="Underline the selected text.">
                                        <TextBlock Text="U" TextDecorations="Underline"/>
                                    </ToggleButton>
                                    <ToggleButton x:Name="StrikeButton"    Width="24" Height="22"
                                                  Style="{StaticResource RibbonToggleBtn}"
                                                  Click="StrikeButton_Click"
                                                  local:RibbonTooltip.Title="Strikethrough"
                                                  local:RibbonTooltip.Description="Draw a line through the middle of the selected text.">
                                        <TextBlock Text="S" TextDecorations="Strikethrough"/>
                                    </ToggleButton>
                                    <Rectangle Width="1" Fill="#CCCCCC" Margin="3,3"/>
                                    <Button x:Name="FontColorBtn" Width="28" Height="22"
                                            Style="{StaticResource RibbonBtn}"
                                            Click="FontColorBtn_Click"
                                            local:RibbonTooltip.Title="Font Color"
                                            local:RibbonTooltip.Description="Change the color of the text.">A</Button>
                                    <Button x:Name="FillColorBtn" Width="28" Height="22"
                                            Style="{StaticResource RibbonBtn}"
                                            Click="FillColorBtn_Click"
                                            local:RibbonTooltip.Title="Fill Color"
                                            local:RibbonTooltip.Description="Color the background of the selected cells.">H</Button>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
                                <TextBlock Text="Font" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Alignment ▌ -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="AlignLeftBtn"   Width="28" Height="22"
                                                  Style="{StaticResource RibbonToggleBtn}"
                                                  Click="AlignLeftBtn_Click"
                                                  local:RibbonTooltip.Title="Align Left"
                                                  local:RibbonTooltip.Description="Align the contents of the selected cells to the left edge.">L</ToggleButton>
                                    <ToggleButton x:Name="AlignCenterBtn" Width="28" Height="22"
                                                  Style="{StaticResource RibbonToggleBtn}"
                                                  Click="AlignCenterBtn_Click"
                                                  local:RibbonTooltip.Title="Center"
                                                  local:RibbonTooltip.Description="Center the contents of the selected cells.">C</ToggleButton>
                                    <ToggleButton x:Name="AlignRightBtn"  Width="28" Height="22"
                                                  Style="{StaticResource RibbonToggleBtn}"
                                                  Click="AlignRightBtn_Click"
                                                  local:RibbonTooltip.Title="Align Right"
                                                  local:RibbonTooltip.Description="Align the contents of the selected cells to the right edge.">R</ToggleButton>
                                    <Rectangle Width="1" Fill="#CCCCCC" Margin="3,3"/>
                                    <ToggleButton x:Name="WrapTextBtn" Width="46" Height="22"
                                                  Style="{StaticResource RibbonToggleBtn}"
                                                  Click="WrapTextBtn_Click"
                                                  local:RibbonTooltip.Title="Wrap Text"
                                                  local:RibbonTooltip.Description="Make all content visible within a cell by displaying it on multiple lines.">Wrap</ToggleButton>
                                </StackPanel>
                                <Button Content="Merge &amp; Center" Width="117" Height="22" Margin="1,2"
                                        Style="{StaticResource RibbonBtn}"
                                        Click="MergeCenterBtn_Click"
                                        local:RibbonTooltip.Title="Merge &amp; Center"
                                        local:RibbonTooltip.Description="Join the selected cells into one larger cell and center the contents."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
                                <TextBlock Text="Alignment" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Number ▌ -->
                        <Grid Width="112">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                            </Grid.RowDefinitions>
                            <ComboBox x:Name="NumberFormatBox" Grid.Row="0" Height="22"
                                      VerticalAlignment="Top" Margin="1,6,1,0"
                                      SelectionChanged="NumberFormatBox_SelectionChanged"
                                      local:RibbonTooltip.Title="Number Format"
                                      local:RibbonTooltip.Description="Choose how to display the values in the selected cells."/>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
                                <TextBlock Text="Number" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Styles ▌ -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="CF Rule"    Width="72" Height="22" Margin="1,1"
                                        Style="{StaticResource RibbonBtn}" Click="CfRuleButton_Click"
                                        local:RibbonTooltip.Title="Conditional Formatting"
                                        local:RibbonTooltip.Description="Highlight cells based on their values using rules, color scales, or data bars."/>
                                <Button Content="Validation" Width="72" Height="22" Margin="1,1"
                                        Style="{StaticResource RibbonBtn}" Click="ValidationButton_Click"
                                        local:RibbonTooltip.Title="Data Validation"
                                        local:RibbonTooltip.Description="Control what data can be entered in the selected cells."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
                                <TextBlock Text="Styles" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Cells ▌ -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Button Grid.Row="0" Grid.Column="0" Content="+ Row" Width="52" Height="22" Margin="1"
                                        Style="{StaticResource RibbonBtn}" FontSize="10"
                                        Click="InsertRowBtn_Click"
                                        local:RibbonTooltip.Title="Insert Row"
                                        local:RibbonTooltip.Description="Insert a blank row above the selected row."/>
                                <Button Grid.Row="0" Grid.Column="1" Content="− Row" Width="52" Height="22" Margin="1"
                                        Style="{StaticResource RibbonBtn}" FontSize="10"
                                        Click="DeleteRowBtn_Click"
                                        local:RibbonTooltip.Title="Delete Row"
                                        local:RibbonTooltip.Description="Delete the selected rows from the sheet."/>
                                <Button Grid.Row="1" Grid.Column="0" Content="+ Col" Width="52" Height="22" Margin="1"
                                        Style="{StaticResource RibbonBtn}" FontSize="10"
                                        Click="InsertColBtn_Click"
                                        local:RibbonTooltip.Title="Insert Column"
                                        local:RibbonTooltip.Description="Insert a blank column to the left of the selected column."/>
                                <Button Grid.Row="1" Grid.Column="1" Content="− Col" Width="52" Height="22" Margin="1"
                                        Style="{StaticResource RibbonBtn}" FontSize="10"
                                        Click="DeleteColBtn_Click"
                                        local:RibbonTooltip.Title="Delete Column"
                                        local:RibbonTooltip.Description="Delete the selected columns from the sheet."/>
                            </Grid>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
                                <TextBlock Text="Cells" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Editing ▌ -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Width="72" Height="22" Margin="1,1"
                                        Style="{StaticResource RibbonBtn}" Click="FindButton_Click"
                                        local:RibbonTooltip.Title="Find"
                                        local:RibbonTooltip.Description="Find text, numbers, or formulas in the workbook.">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <TextBlock Text="Find" VerticalAlignment="Center" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                                <Button Width="72" Height="22" Margin="1,1"
                                        Style="{StaticResource RibbonBtn}" Click="ReplaceButton_Click"
                                        local:RibbonTooltip.Title="Replace"
                                        local:RibbonTooltip.Description="Replace text or data in the workbook with different content.">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <TextBlock Text="Replace" VerticalAlignment="Center" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="FlashFillMenuItem" Width="72" Height="22" Margin="1,1"
                                        Style="{StaticResource RibbonBtn}" Click="FlashFillMenuItem_Click"
                                        local:RibbonTooltip.Title="Flash Fill"
                                        local:RibbonTooltip.Description="Automatically fill values based on a pattern you type. Ctrl+E">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <TextBlock Text="Flash Fill" VerticalAlignment="Center" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
                                <TextBlock Text="Editing" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── INSERT ────────────────────────────────────────────── -->
            <TabItem Header="Insert">
                <Border Background="White" Padding="4,3,4,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal">

                        <!-- ▌Tables ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="PivotTable" Width="82" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotTableBtn_Click"
                                        local:RibbonTooltip.Title="PivotTable"
                                        local:RibbonTooltip.Description="Analyze data by inserting a PivotTable to summarize, group, and filter your data."/>
                                <Button Content="Table"      Width="82" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="TableBtn_Click"
                                        local:RibbonTooltip.Title="Table"
                                        local:RibbonTooltip.Description="Create a table to manage and analyze related data."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Tables" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Charts ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Column" Width="66" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ChartColumnMenuItem_Click"
                                        local:RibbonTooltip.Title="Column Chart"
                                        local:RibbonTooltip.Description="Insert a column chart to compare values across categories."/>
                                <Button Content="Line"   Width="66" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ChartLineMenuItem_Click"
                                        local:RibbonTooltip.Title="Line Chart"
                                        local:RibbonTooltip.Description="Insert a line chart to show trends over time."/>
                                <Button Content="Pie"    Width="66" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ChartPieMenuItem_Click"
                                        local:RibbonTooltip.Title="Pie Chart"
                                        local:RibbonTooltip.Description="Insert a pie chart to show proportions of a whole."/>
                                <Button Content="Bar"    Width="66" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ChartBarMenuItem_Click"
                                        local:RibbonTooltip.Title="Bar Chart"
                                        local:RibbonTooltip.Description="Insert a horizontal bar chart to compare values across categories."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Charts" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Sparklines ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Line"    Width="70" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SparklineLineBtn_Click"
                                        local:RibbonTooltip.Title="Line Sparkline"
                                        local:RibbonTooltip.Description="Insert a line sparkline — a tiny chart in a single cell showing a trend."/>
                                <Button Content="Column"  Width="70" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SparklineColumnBtn_Click"
                                        local:RibbonTooltip.Title="Column Sparkline"
                                        local:RibbonTooltip.Description="Insert a column sparkline showing relative values as small bars."/>
                                <Button Content="Win/Loss" Width="70" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SparklineWinLossBtn_Click"
                                        local:RibbonTooltip.Title="Win/Loss Sparkline"
                                        local:RibbonTooltip.Description="Insert a win/loss sparkline showing positive and negative results."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Sparklines" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Links / Text / Symbols ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <UniformGrid Grid.Row="0" Rows="3" Columns="2" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Link"      Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="InsertLinkBtn_Click"
                                        local:RibbonTooltip.Title="Insert Link"
                                        local:RibbonTooltip.Description="Insert a hyperlink to a web page, file, or location in the workbook."/>
                                <Button Content="Comment"   Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="InsertCommentBtn_Click"
                                        local:RibbonTooltip.Title="New Comment"
                                        local:RibbonTooltip.Description="Add a note or annotation to the selected cell."/>
                                <Button Content="Symbol"    Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SymbolPickerBtn_Click"
                                        local:RibbonTooltip.Title="Insert Symbol"
                                        local:RibbonTooltip.Description="Insert a special character or symbol at the cursor position."/>
                                <Button Content="Picture"   Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="InsertPictureBtn_Click"
                                        local:RibbonTooltip.Title="Insert Picture"
                                        local:RibbonTooltip.Description="Insert a picture from a local image file."/>
                                <Button Content="Pic Size"  Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PictureSizeBtn_Click"
                                        local:RibbonTooltip.Title="Picture Size"
                                        local:RibbonTooltip.Description="Resize the selected or most recent picture."/>
                                <Button Content="Rotate"    Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PictureRotateBtn_Click"
                                        local:RibbonTooltip.Title="Rotate Picture"
                                        local:RibbonTooltip.Description="Rotate the selected or most recent picture."/>
                            </UniformGrid>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Links &amp; Objects" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── DRAW ──────────────────────────────────────────────── -->
            <TabItem Header="Draw">
                <Border Background="White" Padding="4,3,4,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal">

                        <!-- ▌Draw ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Rectangle" Width="70" Height="46" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DrawRectBtn_Click"
                                        local:RibbonTooltip.Title="Rectangle"
                                        local:RibbonTooltip.Description="Draw a rectangle shape on the sheet."/>
                                <Button Content="Ellipse"   Width="70" Height="46" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DrawEllipseBtn_Click"
                                        local:RibbonTooltip.Title="Ellipse"
                                        local:RibbonTooltip.Description="Draw an ellipse or circle on the sheet."/>
                                <Button Content="Line"      Width="70" Height="46" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DrawLineBtn_Click"
                                        local:RibbonTooltip.Title="Line"
                                        local:RibbonTooltip.Description="Draw a straight line on the sheet."/>
                                <Button Content="Text Box"  Width="70" Height="46" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DrawTextBtn_Click"
                                        local:RibbonTooltip.Title="Text Box"
                                        local:RibbonTooltip.Description="Insert a text box you can position and resize anywhere on the sheet."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Draw" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Arrange ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <UniformGrid Grid.Row="0" Rows="2" Columns="2" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Bring Forward" Width="100" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="BringForwardBtn_Click"
                                        local:RibbonTooltip.Title="Bring Forward"
                                        local:RibbonTooltip.Description="Move the selected shape one step closer to the front."/>
                                <Button Content="Send Backward" Width="100" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SendBackwardBtn_Click"
                                        local:RibbonTooltip.Title="Send Backward"
                                        local:RibbonTooltip.Description="Move the selected shape one step closer to the back."/>
                                <Button Content="Size" Width="100" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectSizeBtn_Click"
                                        local:RibbonTooltip.Title="Object Size"
                                        local:RibbonTooltip.Description="Resize the selected or most recent drawing object."/>
                                <Button Content="Rotate" Width="100" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectRotateBtn_Click"
                                        local:RibbonTooltip.Title="Rotate Object"
                                        local:RibbonTooltip.Description="Rotate the selected or most recent drawing object."/>
                            </UniformGrid>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Arrange" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- â–ŒFormat â–Œ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Fill" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectFillBtn_Click"
                                        local:RibbonTooltip.Title="Object Fill"
                                        local:RibbonTooltip.Description="Change the fill color of the selected drawing object."/>
                                <Button Content="Outline" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectOutlineBtn_Click"
                                        local:RibbonTooltip.Title="Object Outline"
                                        local:RibbonTooltip.Description="Change the outline color of the selected drawing object."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Format" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── PAGE LAYOUT ───────────────────────────────────────── -->
            <TabItem Header="Page Layout">
                <Border Background="White" Padding="4,3,4,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal">

                        <!-- Themes -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Themes" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageLayoutDeferredBtn_Click"
                                        local:RibbonTooltip.Title="Themes"
                                        local:RibbonTooltip.Description="Deferred: full workbook theme colors, fonts, and effects require a theme model."/>
                                <Button Content="Colors" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageLayoutDeferredBtn_Click"
                                        local:RibbonTooltip.Title="Theme Colors"
                                        local:RibbonTooltip.Description="Deferred: theme palette editing is not implemented yet."/>
                                <Button Content="Fonts" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageLayoutDeferredBtn_Click"
                                        local:RibbonTooltip.Title="Theme Fonts"
                                        local:RibbonTooltip.Description="Deferred: theme font pairs are not implemented yet."/>
                                <Button Content="Effects" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageLayoutDeferredBtn_Click"
                                        local:RibbonTooltip.Title="Theme Effects"
                                        local:RibbonTooltip.Description="Deferred: theme effect sets are not implemented yet."/>
                                <Button Content="Background" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageLayoutDeferredBtn_Click"
                                        local:RibbonTooltip.Title="Background"
                                        local:RibbonTooltip.Description="Deferred: worksheet background images are not implemented yet."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Themes" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Page Setup ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Margins" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageMarginsBtn_Click"
                                        local:RibbonTooltip.Title="Margins"
                                        local:RibbonTooltip.Description="Select the margin sizes for the printed page.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Normal"   Click="MarginNormalMenuItem_Click"/>
                                            <MenuItem Header="Wide"     Click="MarginWideMenuItem_Click"/>
                                            <MenuItem Header="Narrow"   Click="MarginNarrowMenuItem_Click"/>
                                            <MenuItem Header="Custom…"  Click="MarginCustomMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Orientation" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageOrientBtn_Click"
                                        local:RibbonTooltip.Title="Orientation"
                                        local:RibbonTooltip.Description="Change the page orientation to Portrait or Landscape.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Portrait"  Click="OrientPortraitMenuItem_Click"/>
                                            <MenuItem Header="Landscape" Click="OrientLandscapeMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Size" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageSizeBtn_Click"
                                        local:RibbonTooltip.Title="Paper Size"
                                        local:RibbonTooltip.Description="Choose a paper size for the printed page.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Letter (8.5x11)"  Click="SizeLetter_Click"/>
                                            <MenuItem Header="A4 (210x297 mm)"  Click="SizeA4_Click"/>
                                            <MenuItem Header="Legal (8.5x14)"   Click="SizeLegal_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Print Area" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PrintAreaBtn_Click"
                                        local:RibbonTooltip.Title="Print Area"
                                        local:RibbonTooltip.Description="Set or clear the print area for the current sheet.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Set Print Area"   Click="PrintAreaSetMenuItem_Click"/>
                                            <MenuItem Header="Clear Print Area" Click="PrintAreaClearMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Scale" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ScaleToFitBtn_Click"
                                        local:RibbonTooltip.Title="Scale to Fit"
                                        local:RibbonTooltip.Description="Scale printed output by percentage or fit it to a fixed page count."/>
                                <Button Content="Breaks" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageBreaksBtn_Click"
                                        local:RibbonTooltip.Title="Breaks"
                                        local:RibbonTooltip.Description="Insert or clear manual page breaks for printing."/>
                                <Button Content="Print Titles" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PrintTitlesBtn_Click"
                                        local:RibbonTooltip.Title="Print Titles"
                                        local:RibbonTooltip.Description="Repeat selected rows or columns on every printed page."/>
                                <Button Content="Header/Footer" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="HeaderFooterBtn_Click"
                                        local:RibbonTooltip.Title="Header &amp; Footer"
                                        local:RibbonTooltip.Description="Edit printed page headers and footers."/>
                                <Button Content="Page Setup" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageSetupDialogBtn_Click"
                                        local:RibbonTooltip.Title="Page Setup"
                                        local:RibbonTooltip.Description="Open the Page Setup dialog for page, margin, and sheet print options."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Page Setup" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Sheet Options ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,8,0">
                                <CheckBox Content="Print Gridlines" Margin="4,3" Click="PrintGridlinesChk_Click"/>
                                <CheckBox Content="Print Headings"  Margin="4,3" Click="PrintHeadingsChk_Click"/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Sheet Options" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── FORMULAS ──────────────────────────────────────────── -->
            <TabItem Header="Formulas">
                <Border Background="White" Padding="4,3,4,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal">

                        <!-- ▌Function Library ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Insert Function" Width="116" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="InsertFunctionBtn_Click"
                                        local:RibbonTooltip.Title="Insert Function"
                                        local:RibbonTooltip.Description="Search for and insert a function into the selected cell."/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="AutoSum" Width="70" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulasAutoSumPickerBtn_Click"
                                            local:RibbonTooltip.Title="AutoSum"
                                            local:RibbonTooltip.Description="Automatically insert a SUM, AVERAGE, COUNT, MAX, or MIN formula.">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Sum"           Click="AutoSumSumMenuItem_Click"/>
                                                <MenuItem Header="Average"       Click="AutoSumAvgMenuItem_Click"/>
                                                <MenuItem Header="Count Numbers" Click="AutoSumCountMenuItem_Click"/>
                                                <MenuItem Header="Max"           Click="AutoSumMaxMenuItem_Click"/>
                                                <MenuItem Header="Min"           Click="AutoSumMinMenuItem_Click"/>
                                                <MenuItem Header="More…"         Click="AutoSumMoreMenuItem_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                    <Button Content="Recently Used" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="InsertFunctionBtn_Click"
                                            local:RibbonTooltip.Title="Recently Used"
                                            local:RibbonTooltip.Description="Insert a function you have used recently."/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Math"     Width="48" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaMathBtn_Click"
                                            local:RibbonTooltip.Title="Math &amp; Trig"
                                            local:RibbonTooltip.Description="Browse and insert math and trigonometry functions."/>
                                    <Button Content="Text"     Width="48" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaTextBtn_Click"
                                            local:RibbonTooltip.Title="Text Functions"
                                            local:RibbonTooltip.Description="Browse and insert text manipulation functions like LEFT, MID, and TRIM."/>
                                    <Button Content="Date"     Width="48" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaDateBtn_Click"
                                            local:RibbonTooltip.Title="Date &amp; Time"
                                            local:RibbonTooltip.Description="Browse and insert date and time functions like TODAY and NOW."/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Logical"  Width="56" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaLogicalBtn_Click"
                                            local:RibbonTooltip.Title="Logical Functions"
                                            local:RibbonTooltip.Description="Browse and insert logical functions like IF, AND, OR, and NOT."/>
                                    <Button Content="Lookup"   Width="56" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaLookupBtn_Click"
                                            local:RibbonTooltip.Title="Lookup &amp; Reference"
                                            local:RibbonTooltip.Description="Browse and insert lookup functions like VLOOKUP, HLOOKUP, and INDEX."/>
                                    <Button Content="More…"    Width="40" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaMoreBtn_Click"
                                            local:RibbonTooltip.Title="More Functions"
                                            local:RibbonTooltip.Description="Browse all available functions organized by category."/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Function Library" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Defined Names ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Define Name"    Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DefineNameBtn_Click"
                                        local:RibbonTooltip.Title="Define Name"
                                        local:RibbonTooltip.Description="Assign a name to a cell or range so you can refer to it in formulas."/>
                                <Button Content="Use in Formula" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="UseInFormulaBtn_Click"
                                        local:RibbonTooltip.Title="Use in Formula"
                                        local:RibbonTooltip.Description="Insert a defined name into the formula you are currently editing."/>
                                <Button Content="Name Manager"   Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="NamedRangesButton_Click"
                                        local:RibbonTooltip.Title="Name Manager"
                                        local:RibbonTooltip.Description="View, create, edit, and delete all named ranges in the workbook."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Defined Names" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Formula Auditing ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Trace Precedents"  Width="118" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="TracePrecedentsBtn_Click"
                                        local:RibbonTooltip.Title="Trace Precedents"
                                        local:RibbonTooltip.Description="Show arrows pointing to the cells that supply values to the selected formula."/>
                                <Button Content="Trace Dependents"  Width="118" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="TraceDependentsBtn_Click"
                                        local:RibbonTooltip.Title="Trace Dependents"
                                        local:RibbonTooltip.Description="Show arrows pointing to the cells that depend on the selected cell."/>
                                <Button Content="Remove Arrows"     Width="118" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="RemoveArrowsBtn_Click"
                                        local:RibbonTooltip.Title="Remove Arrows"
                                        local:RibbonTooltip.Description="Remove the tracer arrows added by Trace Precedents or Trace Dependents."/>
                                <Button Content="Show Formulas"     Width="118" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ShowFormulasBtn_Click"
                                        local:RibbonTooltip.Title="Show Formulas"
                                        local:RibbonTooltip.Description="Display formulas in all cells instead of their calculated results."/>
                                <Button Content="Error Checking"    Width="118" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ErrorCheckBtn_Click"
                                        local:RibbonTooltip.Title="Error Checking"
                                        local:RibbonTooltip.Description="Check for common errors in the formulas on this sheet."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Formula Auditing" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Calculation ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Calculate Now"   Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="CalcNowBtn_Click"
                                        local:RibbonTooltip.Title="Calculate Now"
                                        local:RibbonTooltip.Description="Recalculate all formulas in all open workbooks now."/>
                                <Button Content="Calculate Sheet" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="CalcSheetBtn_Click"
                                        local:RibbonTooltip.Title="Calculate Sheet"
                                        local:RibbonTooltip.Description="Recalculate all formulas in the active sheet."/>
                                <Button Content="Calc Options" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="CalcOptionsBtn_Click"
                                        local:RibbonTooltip.Title="Calculation Options"
                                        local:RibbonTooltip.Description="Choose whether formulas are recalculated automatically or manually.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Automatic" Click="CalcAutoMenuItem_Click"/>
                                            <MenuItem Header="Manual"    Click="CalcManualMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Calculation" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── DATA ──────────────────────────────────────────────── -->
            <TabItem Header="Data">
                <Border Background="White" Padding="4,3,4,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal">

                        <!-- ▌Get &amp; Transform ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Get Data"    Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="GetDataBtn_Click"
                                        local:RibbonTooltip.Title="Get Data"
                                        local:RibbonTooltip.Description="Import data from an external source such as a file, database, or web page."/>
                                <Button Content="Refresh All" Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="RefreshAllBtn_Click"
                                        local:RibbonTooltip.Title="Refresh All"
                                        local:RibbonTooltip.Description="Refresh all data connections and queries in the workbook."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Get &amp; Transform" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Sort &amp; Filter ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="&#x2191; A&#x2192;Z" Width="64" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SortAscButton_Click"
                                            local:RibbonTooltip.Title="Sort Ascending"
                                            local:RibbonTooltip.Description="Sort the selected column from smallest to largest (A to Z)."/>
                                    <Button Content="&#x2193; Z&#x2192;A" Width="64" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SortDescButton_Click"
                                            local:RibbonTooltip.Title="Sort Descending"
                                            local:RibbonTooltip.Description="Sort the selected column from largest to smallest (Z to A)."/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Width="64" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FilterButton_Click"
                                            local:RibbonTooltip.Title="Filter"
                                            local:RibbonTooltip.Description="Enable dropdown filters on each column to show only the rows you want.">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       VerticalAlignment="Center" Margin="0,0,2,0"/>
                                            <TextBlock Text="Filter" VerticalAlignment="Center" FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ClearFilterButton_Click"
                                            local:RibbonTooltip.Title="Clear Filter"
                                            local:RibbonTooltip.Description="Remove all active filters and show all rows in the current range.">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       VerticalAlignment="Center" Margin="0,0,2,0"/>
                                            <TextBlock Text="Clear Filter" VerticalAlignment="Center" FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Sort &amp; Filter" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Data Tools ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Text to Columns"   Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="TextToColumnsBtn_Click"
                                        local:RibbonTooltip.Title="Text to Columns"
                                        local:RibbonTooltip.Description="Split text in one column into multiple columns using a delimiter such as a comma or space."/>
                                <Button Content="Remove Duplicates" Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="RemoveDuplicatesBtn_Click"
                                        local:RibbonTooltip.Title="Remove Duplicates"
                                        local:RibbonTooltip.Description="Delete duplicate rows from the selected range."/>
                                <Button Content="Data Validation"   Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ValidationButton_Click"
                                        local:RibbonTooltip.Title="Data Validation"
                                        local:RibbonTooltip.Description="Control what data can be entered in the selected cells."/>
                                <Button Content="Consolidate"       Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ConsolidateBtn_Click"
                                        local:RibbonTooltip.Title="Consolidate"
                                        local:RibbonTooltip.Description="Combine values from multiple ranges into a single summary range."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Data Tools" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Named Ranges ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <Button Grid.Row="0" Content="Name Manager" Width="90" Height="46"
                                    Style="{StaticResource RibbonBtn}" FontSize="12"
                                    VerticalAlignment="Center" Margin="1,2,1,0"
                                    Click="NamedRangesButton_Click"
                                    local:RibbonTooltip.Title="Name Manager"
                                    local:RibbonTooltip.Description="View, create, edit, and delete all named ranges in the workbook."/>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Named Ranges" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── REVIEW ────────────────────────────────────────────── -->
            <TabItem Header="Review">
                <Border Background="White" Padding="4,3,4,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal">

                        <!-- ▌Proofing ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Spelling" Width="104" Height="22"
                                        Style="{StaticResource RibbonBtn}" FontSize="12"
                                        Margin="1,1"
                                        Click="SpellCheckBtn_Click"
                                        local:RibbonTooltip.Title="Spelling"
                                        local:RibbonTooltip.Description="Check the spelling of text in the active sheet."/>
                                <Button Content="Workbook Stats" Width="104" Height="22"
                                        Style="{StaticResource RibbonBtn}" FontSize="12"
                                        Margin="1,1"
                                        Click="WorkbookStatisticsBtn_Click"
                                        local:RibbonTooltip.Title="Workbook Statistics"
                                        local:RibbonTooltip.Description="Show workbook counts for sheets, cells, formulas, comments, and objects."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Proofing" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Comments ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="New"    Width="50" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewNewCommentBtn_Click"
                                            local:RibbonTooltip.Title="New Comment"
                                            local:RibbonTooltip.Description="Add a note or annotation to the selected cell."/>
                                    <Button Content="Delete" Width="50" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewDeleteCommentBtn_Click"
                                            local:RibbonTooltip.Title="Delete Comment"
                                            local:RibbonTooltip.Description="Remove the comment from the selected cell."/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Prev"   Width="50" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewPrevCommentBtn_Click"
                                            local:RibbonTooltip.Title="Previous Comment"
                                            local:RibbonTooltip.Description="Navigate to the previous comment in the sheet."/>
                                    <Button Content="Next"   Width="50" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewNextCommentBtn_Click"
                                            local:RibbonTooltip.Title="Next Comment"
                                            local:RibbonTooltip.Description="Navigate to the next comment in the sheet."/>
                                </StackPanel>
                                <Button Content="Show Comments" Width="102" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewShowCommentsBtn_Click"
                                        local:RibbonTooltip.Title="Show All Comments"
                                        local:RibbonTooltip.Description="Show or hide all comment indicators in the sheet."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Comments" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Protect ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Protect Sheet"    Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ProtectSheetBtn_Click"
                                        local:RibbonTooltip.Title="Protect Sheet"
                                        local:RibbonTooltip.Description="Prevent unwanted changes to this sheet by locking it with an optional password."/>
                                <Button Content="Protect Workbook"  Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ProtectWorkbookBtn_Click"
                                        local:RibbonTooltip.Title="Protect Workbook"
                                        local:RibbonTooltip.Description="Prevent structural changes to the workbook such as adding, deleting, or renaming sheets."/>
                                <Button Content="Allow Edit Ranges" Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="AllowEditRangesBtn_Click"
                                        local:RibbonTooltip.Title="Allow Edit Ranges"
                                        local:RibbonTooltip.Description="Allow specific ranges to remain editable when the sheet is protected."/>
                                <Button Content="Share (Excluded)" Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ShareWorkbookBtn_Click"
                                        local:RibbonTooltip.Title="Share Excluded"
                                        local:RibbonTooltip.Description="Microsoft 365 Share and cloud co-authoring are excluded; save the file and share it outside Freexcel."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Protect" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── VIEW ──────────────────────────────────────────────── -->
            <TabItem Header="View">
                <Border Background="White" Padding="4,3,4,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal">

                        <!-- ▌Show ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Normal" Width="118" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="NormalViewBtn_Click"
                                        local:RibbonTooltip.Title="Normal"
                                        local:RibbonTooltip.Description="Show the worksheet in the standard editing view."/>
                                <Button Content="Page Break Preview" Width="118" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageBreakPreviewBtn_Click"
                                        local:RibbonTooltip.Title="Page Break Preview"
                                        local:RibbonTooltip.Description="Show manual page breaks and print area boundaries while editing."/>
                                <Button Content="Page Layout" Width="118" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageLayoutViewBtn_Click"
                                        local:RibbonTooltip.Title="Page Layout"
                                        local:RibbonTooltip.Description="Show the sheet with print layout boundaries."/>
                                <Button Content="Custom Views" Width="118" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="CustomViewsBtn_Click"
                                        local:RibbonTooltip.Title="Custom Views"
                                        local:RibbonTooltip.Description="View, add, show, and delete saved workbook views."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Workbook Views" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,8,0">
                                <CheckBox Content="Gridlines"              Margin="4,3" IsChecked="True" Checked="ViewGridlinesChk_Changed" Unchecked="ViewGridlinesChk_Changed"/>
                                <CheckBox Content="Row and Column Headers" Margin="4,3" IsChecked="True" Checked="ViewHeadersChk_Changed"   Unchecked="ViewHeadersChk_Changed"/>
                                <CheckBox Content="Formula Bar"            Margin="4,3" IsChecked="True" Checked="ViewFormulaBarChk_Changed" Unchecked="ViewFormulaBarChk_Changed"/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Show" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Freeze Panes ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Freeze Panes" Width="106" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FreezePanesPickerBtn_Click"
                                        local:RibbonTooltip.Title="Freeze Panes"
                                        local:RibbonTooltip.Description="Keep rows or columns visible while scrolling through the rest of the sheet.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Freeze Panes"         Click="FreezeAtSelectionMenuItem_Click"/>
                                            <MenuItem Header="Freeze Top Row"       Click="FreezeTopRowMenuItem_Click"/>
                                            <MenuItem Header="Freeze First Column"  Click="FreezeFirstColMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Unfreeze All"         Click="UnfreezeAllMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Split" Width="106" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SplitViewBtn_Click"
                                        local:RibbonTooltip.Title="Split"
                                        local:RibbonTooltip.Description="Split the worksheet at the selected cell, or remove the current split."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Freeze Panes" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Zoom ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="-"    Width="28" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ZoomOutBtn_Click"
                                            local:RibbonTooltip.Title="Zoom Out"
                                            local:RibbonTooltip.Description="Decrease the zoom level to see more of the sheet."/>
                                    <Button Content="100%" Width="44" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="Zoom100Btn_Click"
                                            local:RibbonTooltip.Title="Zoom to 100%"
                                            local:RibbonTooltip.Description="Reset the zoom level to 100%."/>
                                    <Button Content="+"    Width="28" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ZoomInBtn_Click"
                                            local:RibbonTooltip.Title="Zoom In"
                                            local:RibbonTooltip.Description="Increase the zoom level for a closer look at cells."/>
                                </StackPanel>
                                <Button Content="Zoom to Selection" Width="102" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ZoomSelectionBtn_Click"
                                        local:RibbonTooltip.Title="Zoom to Selection"
                                        local:RibbonTooltip.Description="Zoom in so the selected cells fill the screen."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Zoom" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── HELP ──────────────────────────────────────────────── -->
            <TabItem Header="Help">
                <Border Background="White" Padding="4,3,4,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal">

                        <!-- ▌Help ▌ -->
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Help Online"   Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="HelpOnlineBtn_Click"
                                        local:RibbonTooltip.Title="Help Online"
                                        local:RibbonTooltip.Description="Open the Freexcel help documentation in a web browser."/>
                                <Button Content="About Freexcel" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="AboutBtn_Click"
                                        local:RibbonTooltip.Title="About Freexcel"
                                        local:RibbonTooltip.Description="View version and license information about Freexcel."/>
                                <Button Content="Send Feedback"  Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SendFeedbackBtn_Click"
                                        local:RibbonTooltip.Title="Send Feedback"
                                        local:RibbonTooltip.Description="Send suggestions or report issues with Freexcel."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Help" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

        </TabControl>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 2  Formula bar
             ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="FormulaBarBorder" Grid.Row="2" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Background="White" Padding="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="CellAddressBox" Grid.Column="0" Text="A1"
                         FontFamily="Consolas" FontSize="13" VerticalContentAlignment="Center"
                         BorderBrush="#C0C0C0" Padding="4,2"/>

                <!-- fx button opens Insert Function dialog -->
                <Button Grid.Column="1" Content=" fx " FontWeight="Bold" Foreground="#444"
                        Background="Transparent" BorderThickness="0"
                        Padding="2,0" VerticalAlignment="Center" Margin="2,0" Cursor="Hand"
                        FontSize="12" FontStyle="Italic"
                        Click="InsertFunctionBtn_Click"
                        local:RibbonTooltip.Title="Insert Function"
                        local:RibbonTooltip.Description="Search for and insert a function into the selected cell."/>

                <TextBox x:Name="FormulaBar" Grid.Column="2" FontFamily="Consolas" FontSize="13"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Center" BorderBrush="#C0C0C0" Padding="4,2"
                         PreviewKeyDown="FormulaBar_KeyDown"/>

                <!-- Expand/collapse chevron -->
                <Button x:Name="FormulaBarExpandBtn" Grid.Column="3"
                        Content="▼" Width="18" Height="18"
                        Background="Transparent" BorderThickness="0"
                        FontSize="9" Padding="0" Margin="2,0,0,0"
                        VerticalAlignment="Center" Cursor="Hand"
                        Click="FormulaBarExpandBtn_Click"
                        local:RibbonTooltip.Title="Expand Formula Bar"
                        local:RibbonTooltip.Description="Expand or collapse the formula bar."/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 3  Spreadsheet grid
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:GridView x:Name="SheetGrid" Grid.Column="0"/>
            <!-- Inline cell edit overlay: a Canvas with a positioned TextBox -->
            <Canvas x:Name="EditOverlay" Grid.Column="0"
                    IsHitTestVisible="False" Panel.ZIndex="20"/>

            <ScrollBar x:Name="VerticalScroll" Grid.Column="1"
                       Orientation="Vertical" Minimum="1" Maximum="1000000" Value="1" SmallChange="1"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 4  Sheet tabs
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="#E8E8E8" BorderBrush="#D0D0D0"
                BorderThickness="0,1,0,0" Padding="0,2,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- Nav arrows -->
                    <ColumnDefinition Width="*"/>      <!-- Scrolling tabs + Add button -->
                    <ColumnDefinition Width="160"/>    <!-- Horizontal scrollbar -->
                </Grid.ColumnDefinitions>

                <!-- Sheet navigation arrows -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0">
                    <Button x:Name="SheetNavLeftBtn" Content="&lt;" Width="20" Height="20" Padding="0"
                            FontSize="11" Background="Transparent" BorderBrush="#B0B0B0" BorderThickness="1"
                            Cursor="Hand" Click="SheetNavLeftBtn_Click"
                            local:RibbonTooltip.Title="Scroll Tabs Left"
                            local:RibbonTooltip.Description="Scroll the sheet tab list to the left."/>
                    <Button x:Name="SheetNavRightBtn" Content="&gt;" Width="20" Height="20" Padding="0"
                            FontSize="11" Background="Transparent" BorderBrush="#B0B0B0" BorderThickness="1"
                            Cursor="Hand" Click="SheetNavRightBtn_Click" Margin="2,0,0,0"
                            local:RibbonTooltip.Title="Scroll Tabs Right"
                            local:RibbonTooltip.Description="Scroll the sheet tab list to the right."/>
                </StackPanel>

                <!-- Sheet tabs + Add button in a horizontal ScrollViewer -->
                <ScrollViewer x:Name="SheetTabsScroller" Grid.Column="1"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <ItemsControl x:Name="SheetTabsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="TabBorder"
                                            CornerRadius="3,3,0,0" Padding="10,3"
                                            Background="{Binding TabBrush}"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="SheetTab_MouseLeftButtonDown"
                                            MouseMove="SheetTab_MouseMove"
                                            MouseLeftButtonUp="SheetTab_MouseLeftButtonUp"
                                            MouseRightButtonDown="SheetTab_MouseRightButtonDown">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush"      Value="#D0D0D0"/>
                                                <Setter Property="BorderThickness"  Value="1"/>
                                                <Setter Property="Margin"           Value="2,0,0,0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background"      Value="White"/>
                                                        <Setter Property="BorderBrush"     Value="#217346"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,3"/>
                                                        <Setter Property="Margin"          Value="2,-1,0,0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsGrouped}" Value="True">
                                                        <Setter Property="BorderBrush"     Value="#217346"/>
                                                        <Setter Property="Background"      Value="#E8F5EC"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Rename…"         Click="SheetCtxRename_Click"/>
                                                <MenuItem Header="Insert Sheet"    Click="SheetCtxInsert_Click"/>
                                                <MenuItem Header="Duplicate"       Click="SheetCtxDuplicate_Click"/>
                                                <MenuItem Header="Delete Sheet"    Click="SheetCtxDelete_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Hide"            Click="SheetCtxHide_Click"/>
                                                <MenuItem Header="Unhide…"         Click="SheetCtxUnhide_Click"/>
                                                <MenuItem Header="Tab Color…"      Click="SheetCtxTabColor_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Select All Sheets" Click="SheetCtxSelectAllSheets_Click"/>
                                                <MenuItem Header="Ungroup Sheets"    Click="SheetCtxUngroupSheets_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Move Left"       Click="SheetCtxMoveLeft_Click"/>
                                                <MenuItem Header="Move Right"      Click="SheetCtxMoveRight_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   MouseDown="SheetTab_LabelMouseDown">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Add sheet button immediately after the last tab -->
                        <Button x:Name="AddSheetButton" Content="+" Width="26" Height="22"
                                FontSize="14" Margin="4,0" Padding="0"
                                Background="Transparent" BorderBrush="#C0C0C0" BorderThickness="1"
                                VerticalAlignment="Center" Cursor="Hand"
                                Click="AddSheetButton_Click"
                                local:RibbonTooltip.Title="Insert Sheet"
                                local:RibbonTooltip.Description="Add a new sheet to the workbook."/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Horizontal scrollbar (Excel-style, right of sheet tabs) -->
                <ScrollBar x:Name="HorizontalScroll" Grid.Column="2"
                           Orientation="Horizontal" Minimum="1" Maximum="16384" Value="1"
                           SmallChange="1" VerticalAlignment="Center" Margin="2,0"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 5  Status bar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="5" Background="#217346" Padding="8,3">
            <Grid>
                <TextBlock x:Name="StatusReadyText" Text="Ready" Foreground="White"
                           FontSize="12" VerticalAlignment="Center"/>
                <StackPanel x:Name="StatusStatsPanel" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock x:Name="StatusSumText"   Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock x:Name="StatusCountText" Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock x:Name="StatusAvgText"   Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock x:Name="StatusMinText"   Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock x:Name="StatusMaxText"   Foreground="White" FontSize="12"/>
                </StackPanel>
                <!-- Zoom controls on the right -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="−" Width="18" Height="18" Margin="0,0,2,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="14" Padding="0"
                            VerticalAlignment="Center" Cursor="Hand" Click="ZoomOutBtn_Click"/>
                    <Slider x:Name="ZoomSlider" Width="80" Minimum="10" Maximum="400" Value="100"
                            VerticalAlignment="Center" Margin="0,0,2,0"
                            SmallChange="10" LargeChange="25"
                            TickPlacement="BottomRight" Ticks="100" IsSnapToTickEnabled="False"
                            ValueChanged="ZoomSlider_ValueChanged"/>
                    <Button Content="+" Width="18" Height="18" Margin="0,0,6,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="14" Padding="0"
                            VerticalAlignment="Center" Cursor="Hand" Click="ZoomInBtn_Click"/>
                    <TextBlock x:Name="StatusZoomText" Text="100%" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" Width="38"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             START SCREEN — full-window overlay shown at launch / via ← Home
             ═══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="StartScreenOverlay"
              Grid.Row="0" Grid.RowSpan="6"
              Panel.ZIndex="200"
              Visibility="Collapsed"
              WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left sidebar ─────────────────────────────────────────── -->
            <DockPanel Grid.Column="0" Background="#1C3E2E" LastChildFill="True">

                <!-- Back arrow -->
                <Button x:Name="SsBackBtn" DockPanel.Dock="Top"
                        Content="&#x2190;" HorizontalAlignment="Left"
                        Style="{StaticResource SsNavBtn}"
                        Padding="18,11" FontSize="18"
                        Click="SsBackBtn_Click"
                        ToolTip="Back to workbook"/>

                <!-- Home (active/selected when showing home view) -->
                <Button x:Name="SsHomeNavBtn" DockPanel.Dock="Top"
                        Content="Home" HorizontalAlignment="Stretch"
                        Style="{StaticResource SsNavBtnActive}"
                        Click="SsHomeNavBtn_Click"/>

                <!-- Account / Options pinned to bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,10">
                    <Rectangle Height="1" Fill="#2C5C40" Margin="0,0,0,6"/>
                    <Button Content="Account" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"/>
                    <Button Content="Options" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SsOptionsBtn_Click"/>
                </StackPanel>

                <!-- Navigation items -->
                <StackPanel>
                    <Button Content="New" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SsNewBtn_Click"/>
                    <Button Content="Open" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SsOpenBtn_Click"/>
                    <Button Content="Share" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SsShareBtn_Click"/>

                    <Rectangle Height="1" Fill="#2C5C40" Margin="0,6"/>

                    <Button x:Name="SsInfoNavBtn" Content="Info"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SsInfoBtn_Click"/>
                    <Button Content="Save" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SaveButton_Click"/>
                    <Button Content="Save As" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SaveButton_Click"/>
                    <Button Content="Print" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="PrintButton_Click"/>
                    <Button Content="Export" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="ExportPdfButton_Click"/>
                    <Button Content="Close" HorizontalAlignment="Stretch"
                            Style="{StaticResource SsNavBtn}"
                            Click="SsCloseBtn_Click"/>
                </StackPanel>
            </DockPanel>

            <!-- ── Right content area ───────────────────────────────────── -->
            <Grid Grid.Column="1" Background="White">

                <!-- ══ HOME VIEW ════════════════════════════════════════════ -->
                <Grid x:Name="SsHomeView">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Greeting -->
                    <RowDefinition Height="Auto"/>  <!-- New section -->
                    <RowDefinition Height="*"/>     <!-- Recent files -->
                </Grid.RowDefinitions>

                <!-- Greeting -->
                <TextBlock x:Name="SsGreeting" Grid.Row="0"
                           FontSize="28" FontWeight="Light" Foreground="#1F1F1F"
                           Margin="40,36,40,0"/>

                <!-- New section -->
                <Border Grid.Row="1" Padding="40,18,40,6">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,10">
                            <TextBlock DockPanel.Dock="Left" Text="New"
                                       FontSize="14" FontWeight="SemiBold" Foreground="#1F1F1F"/>
                            <TextBlock DockPanel.Dock="Right" Text="More templates &#x2192;"
                                       FontSize="12" Foreground="#217346"
                                       VerticalAlignment="Center" Cursor="Hand"
                                       MouseDown="SsMoreTemplates_MouseDown"/>
                        </DockPanel>

                        <StackPanel Orientation="Horizontal">
                            <!-- Blank workbook card -->
                            <Button Click="SsBlankWorkbook_Click" Cursor="Hand" Margin="0,0,16,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="cardBg" Background="Transparent" Padding="4">
                                            <StackPanel Width="108">
                                                <!-- Mini spreadsheet thumbnail -->
                                                <Border Width="108" Height="80"
                                                        BorderBrush="#C8C8C8" BorderThickness="1"
                                                        Background="White" ClipToBounds="True">
                                                    <Canvas Width="108" Height="80">
                                                        <!-- Row-header strip -->
                                                        <Rectangle Canvas.Left="0" Canvas.Top="0"
                                                                   Width="18" Height="80" Fill="#F0F0F0"/>
                                                        <!-- Column-header strip -->
                                                        <Rectangle Canvas.Left="0" Canvas.Top="0"
                                                                   Width="108" Height="14" Fill="#F0F0F0"/>
                                                        <!-- Horizontal grid lines -->
                                                        <Line X1="0" Y1="27" X2="108" Y2="27"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <Line X1="0" Y1="40" X2="108" Y2="40"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <Line X1="0" Y1="53" X2="108" Y2="53"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <Line X1="0" Y1="66" X2="108" Y2="66"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <!-- Vertical grid lines -->
                                                        <Line X1="42" Y1="14" X2="42" Y2="80"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <Line X1="66" Y1="14" X2="66" Y2="80"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <Line X1="90" Y1="14" X2="90" Y2="80"
                                                              Stroke="#DCDCDC" StrokeThickness="0.5"/>
                                                        <!-- Selected cell A1 -->
                                                        <Rectangle Canvas.Left="18" Canvas.Top="14"
                                                                   Width="24" Height="13"
                                                                   Fill="#E8F5EC"/>
                                                        <Rectangle Canvas.Left="18" Canvas.Top="14"
                                                                   Width="24" Height="13"
                                                                   Stroke="#217346" StrokeThickness="1.5"
                                                                   Fill="Transparent"/>
                                                    </Canvas>
                                                </Border>
                                                <TextBlock Text="Blank workbook"
                                                           FontSize="12" Margin="0,6,0,2"
                                                           TextAlignment="Center"
                                                           Foreground="#1F1F1F"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="cardBg" Property="Background"
                                                        Value="#F0F6F2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Recent files -->
                <Grid Grid.Row="2" Margin="40,0,40,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Tabs + search -->
                        <RowDefinition Height="Auto"/> <!-- Column headers -->
                        <RowDefinition Height="*"/>    <!-- File list -->
                    </Grid.RowDefinitions>

                    <!-- Tabs row + search box -->
                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,0">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Border Padding="0,8,22,8"
                                    BorderThickness="0,0,0,2" BorderBrush="#217346">
                                <TextBlock Text="Recent" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#217346"/>
                            </Border>
                            <Border Padding="0,8,22,8">
                                <TextBlock Text="Pinned" FontSize="13"
                                           Foreground="#888" Cursor="Hand"/>
                            </Border>
                        </StackPanel>
                        <Border DockPanel.Dock="Right"
                                Background="#F5F5F5" BorderBrush="#D8D8D8" BorderThickness="1"
                                CornerRadius="2" Padding="8,4" VerticalAlignment="Center">
                            <TextBox x:Name="SsSearchBox" Width="180" FontSize="12"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     TextChanged="SsSearchBox_TextChanged"/>
                        </Border>
                    </DockPanel>

                    <!-- Column headers -->
                    <Border Grid.Row="1" BorderThickness="0,1,0,1" BorderBrush="#E4E4E4"
                            Padding="0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Name" FontSize="11" Foreground="#888"/>
                            <TextBlock Grid.Column="1" Text="Date modified" FontSize="11" Foreground="#888"/>
                        </Grid>
                    </Border>

                    <!-- File list -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="SsRecentList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button HorizontalContentAlignment="Stretch"
                                            BorderThickness="0" Padding="0,7"
                                            Click="SsRecentItem_Click"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="rowBg" Background="Transparent"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="rowBg" Property="Background"
                                                                Value="#F3F6F9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <!-- Green Excel-style file icon -->
                                                <Border Width="26" Height="30" Background="#217346"
                                                        CornerRadius="2" Margin="0,0,10,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="X" Foreground="White"
                                                               FontSize="11" FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontSize="13" Foreground="#1F1F1F"/>
                                                    <TextBlock Text="{Binding Directory}"
                                                               FontSize="11" Foreground="#888"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LastOpenedText}"
                                                       FontSize="12" Foreground="#666"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
                </Grid><!-- end SsHomeView -->

                <!-- ══ INFO VIEW ════════════════════════════════════════════ -->
                <Grid x:Name="SsInfoView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Info"
                               FontSize="28" FontWeight="Light" Foreground="#1F1F1F"
                               Margin="40,36,40,0"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="40,24,40,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Workbook actions (left) -->
                            <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                <TextBlock Text="Protect Workbook"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Control what types of changes others can make."
                                           FontSize="12" Foreground="#555" TextWrapping="Wrap"
                                           Margin="0,0,0,20"/>
                                <TextBlock Text="Inspect Workbook"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Check for hidden properties or personal information."
                                           FontSize="12" Foreground="#555" TextWrapping="Wrap"
                                           Margin="0,0,0,20"/>
                                <TextBlock Text="Manage Workbook"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Check in, check out, or discard unsaved changes."
                                           FontSize="12" Foreground="#555" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Properties (right) -->
                            <Border Grid.Column="1"
                                    BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                                    Padding="24,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Properties"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#555"
                                               Margin="0,0,0,14"/>

                                    <TextBlock Text="Workbook name" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoWorkbookName" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,12"/>

                                    <TextBlock Text="File path" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoFilePath" FontSize="12" Foreground="#555"
                                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                                    <TextBlock Text="Sheets" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoSheetCount" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,12"/>

                                    <TextBlock Text="Format" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoFormat" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,20"/>

                                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,20"/>

                                    <TextBlock Text="About Freexcel"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#555"
                                               Margin="0,0,0,10"/>
                                    <TextBlock FontSize="12" Foreground="#555"
                                               TextWrapping="Wrap" LineHeight="20"
                                               Margin="0,0,0,6">Freexcel is a lightweight, open-format spreadsheet built on .NET 10 and WPF. Supports XLSX, formula calculation, cell styling, charts, and freeze panes.</TextBlock>
                                    <TextBlock Text="Version 0.1 · Phase 3"
                                               FontSize="11" Foreground="#888"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid><!-- end SsInfoView -->

            </Grid>
        </Grid>

    </Grid>
</Window>
