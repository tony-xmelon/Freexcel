<Window x:Class="Freexcel.App.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:Freexcel.App.UI;assembly=Freexcel.App.UI"
        xmlns:local="clr-namespace:Freexcel.App.Host"
        mc:Ignorable="d"
        Title="Freexcel"
        Icon="Resources/Freexcel.ico"
        Height="720" Width="1280"
        WindowState="Maximized"
        Background="{DynamicResource FreexcelSheetSurfaceBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary Source="Resources/MainWindowResources.xaml"/>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <!-- Title / quick-access bar (QAT) -->
            <RowDefinition Height="Auto"/>
            <!-- Ribbon (tab strip + tab content) -->
            <RowDefinition Height="Auto"/>
            <!-- Formula bar -->
            <RowDefinition Height="Auto"/>
            <!-- Spreadsheet grid -->
            <RowDefinition Height="*"/>
            <!-- Sheet tabs -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 0  Title bar / Quick Access Toolbar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource FreexcelTitleBarBrush}" BorderBrush="{StaticResource FreexcelGreenDarkBrush}"
                BorderThickness="0,0,0,1" Padding="6,3">
            <DockPanel>
                <!-- App icon -->
                <Border x:Name="TitleBarAppIcon"
                        DockPanel.Dock="Left"
                        Width="22" Height="22"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Background="{StaticResource FreexcelGreenDarkBrush}"
                        BorderBrush="#66FFFFFF"
                        BorderThickness="1"
                        CornerRadius="2"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                    <Grid SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          TextOptions.TextFormattingMode="Display"
                          TextOptions.TextRenderingMode="ClearType"
                          TextOptions.TextHintingMode="Fixed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="TitleBarAppFreeBand"
                                Grid.Row="0"
                                Background="#2FA466"
                                CornerRadius="1,1,0,0"
                                Margin="0"/>
                        <TextBlock x:Name="TitleBarAppXOutlineTop"
                                   Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Panel.ZIndex="3"
                                   Text="X"
                                   Foreground="#155C38"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="14.5"
                                   Margin="0,-3,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TitleBarAppXOutlineBottom"
                                   Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Panel.ZIndex="3"
                                   Text="X"
                                   Foreground="#155C38"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="14.5"
                                   Margin="0,-1,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TitleBarAppXOutlineLeft"
                                   Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Panel.ZIndex="3"
                                   Text="X"
                                   Foreground="#155C38"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="14.5"
                                   Margin="-1,-2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TitleBarAppXOutlineRight"
                                   Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Panel.ZIndex="3"
                                   Text="X"
                                   Foreground="#155C38"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="14.5"
                                   Margin="1,-2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TitleBarAppX"
                                   Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Panel.ZIndex="4"
                                   Text="X"
                                   Foreground="{StaticResource FreexcelWhiteBrush}"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="14.5"
                                   Margin="0,-2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="FREE"
                                   Grid.Row="0"
                                   Panel.ZIndex="2"
                                   Foreground="{StaticResource FreexcelWhiteBrush}"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="6.6"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                    </Grid>
                </Border>
                <!-- QAT buttons -->
                <Button x:Name="SaveQatBtn" DockPanel.Dock="Left" Width="26" Height="22" Margin="0,0,2,0"
                        Style="{StaticResource TitleBarQatButton}" FontSize="13"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="SaveButton_Click"
                        local:RibbonTooltip.Title="Save"
                        local:RibbonTooltip.KeyTip="1"
                        local:RibbonTooltip.Description="Save the workbook.">
                    <local:RibbonIcon Kind="Save" IconSize="16"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button x:Name="UndoQatBtn" DockPanel.Dock="Left" Width="26" Height="22" Margin="0,0,2,0"
                        Style="{StaticResource TitleBarQatButton}" FontSize="14"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="UndoQatBtn_Click"
                        local:RibbonTooltip.Title="Undo"
                        local:RibbonTooltip.KeyTip="2"
                        local:RibbonTooltip.Description="Undo the last action.">
                    <local:RibbonIcon Kind="Undo" IconSize="16"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button x:Name="RedoQatBtn" DockPanel.Dock="Left" Width="26" Height="22" Margin="0,0,8,0"
                        Style="{StaticResource TitleBarQatButton}" FontSize="14"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="RedoQatBtn_Click"
                        local:RibbonTooltip.Title="Redo"
                        local:RibbonTooltip.KeyTip="3"
                        local:RibbonTooltip.Description="Redo the last undone action.">
                    <local:RibbonIcon Kind="Redo" IconSize="16"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <!-- System buttons — must be docked Right before the fill element -->
                <!-- Order in XAML (Right-docked) is right-to-left, so Close first -->
                <Button x:Name="CloseSysBtn"    DockPanel.Dock="Right"
                        Style="{StaticResource CloseSysBtnStyle}" Click="CloseSysBtn_Click"
                        AutomationProperties.Name="Close">
                    <local:RibbonIcon Kind="WindowClose" IconSize="18"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button x:Name="MaxRestoreBtn"  DockPanel.Dock="Right"
                        Style="{StaticResource SysBtnStyle}"      Click="MaxRestoreBtn_Click"
                        AutomationProperties.Name="Maximize or Restore">
                    <local:RibbonIcon Kind="WindowMaximize" IconSize="18"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button                         DockPanel.Dock="Right"
                        Style="{StaticResource SysBtnStyle}"      Click="MinimizeBtn_Click"
                        AutomationProperties.Name="Minimize">
                    <local:RibbonIcon Kind="WindowMinimize" IconSize="18"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <!-- Workbook name centred -->
                <TextBlock x:Name="WorkbookNameText"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource FreexcelWhiteBrush}" FontWeight="SemiBold"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 1  Ribbon  (tabbed, groups with labels)
             ═══════════════════════════════════════════════════════════════ -->
        <TabControl x:Name="RibbonTabs" Grid.Row="1" Background="{StaticResource FreexcelRibbonSurfaceBrush}"
                    BorderThickness="0,0,0,1" BorderBrush="{StaticResource FreexcelBorderBrush}"
                    Padding="0" TabStripPlacement="Top" SelectedIndex="1" MinHeight="132"
                    Focusable="True" IsTabStop="True"
                    KeyboardNavigation.TabNavigation="Continue"
                    KeyboardNavigation.ControlTabNavigation="Continue"
                    KeyboardNavigation.DirectionalNavigation="Contained"
                    SelectionChanged="RibbonTabs_SelectionChanged">

            <!-- ── FILE — clicking opens the overlay; handler immediately switches back to Home -->
            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>
            <TabItem x:Name="FileTab" Header="File" local:RibbonTooltip.KeyTip="F"/>

            <!-- ── HOME ──────────────────────────────────────────────── -->
            <TabItem Header="Home" local:RibbonTooltip.KeyTip="H">
                <Border Background="{StaticResource FreexcelRibbonSurfaceBrush}" Padding="6,4,6,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel x:Name="HomeRibbonPanel" Orientation="Horizontal" MinHeight="88">

                        <!-- ▌Clipboard ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="18"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Click="PasteBtn_Click"
                                        Style="{StaticResource RibbonLargeButton}"
                                        local:RibbonTooltip.Title="Paste"
                                        local:RibbonTooltip.KeyTip="V"
                                        local:RibbonTooltip.Description="Paste the contents of the Clipboard (Ctrl+V).">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Paste" InputGestureText="P"
                                                      local:RibbonTooltip.KeyTip="P"
                                                      Click="PasteMenuItem_Click"/>
                                            <MenuItem Header="Values" InputGestureText="V"
                                                      local:RibbonTooltip.KeyTip="V"
                                                      Click="PasteValuesMenuItem_Click"/>
                                            <MenuItem Header="Formulas" InputGestureText="F"
                                                      local:RibbonTooltip.KeyTip="F"
                                                      Click="PasteFormulasMenuItem_Click"/>
                                            <MenuItem Header="Formatting" InputGestureText="R"
                                                      local:RibbonTooltip.KeyTip="R"
                                                      Click="PasteFormattingMenuItem_Click"/>
                                            <MenuItem Header="Transpose" InputGestureText="T"
                                                      local:RibbonTooltip.KeyTip="T"
                                                      Click="PasteTransposeMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Paste Special..." InputGestureText="S"
                                                      local:RibbonTooltip.KeyTip="S"
                                                      Click="PasteSpecialBtn_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel>
                                        <local:RibbonIcon Kind="Paste" IconSize="22"
                                                          HorizontalAlignment="Center"/>
                                        <TextBlock Text="Paste" Tag="RibbonLabel" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>
                                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="2,1,0,0">
                                    <Button Click="CutBtn_Click" Width="126" Height="20" Margin="1,0"
                                            Style="{StaticResource RibbonBtn}" HorizontalContentAlignment="Left"
                                            local:RibbonTooltip.Title="Cut"
                                            local:RibbonTooltip.KeyTip="X"
                                            local:RibbonTooltip.Description="Cut the selection and put it on the Clipboard (Ctrl+X).">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <local:RibbonIcon Kind="Cut" IconSize="10"
                                                              VerticalAlignment="Center" Margin="0,0,2,0"/>
                                            <TextBlock Text="Cut" VerticalAlignment="Center" FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="CopyBtn_Click" Width="126" Height="20" Margin="1,1,0,0"
                                            Style="{StaticResource RibbonBtn}" HorizontalContentAlignment="Left"
                                            local:RibbonTooltip.Title="Copy"
                                            local:RibbonTooltip.KeyTip="C"
                                            local:RibbonTooltip.Description="Copy the selection and put it on the Clipboard (Ctrl+C).">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <local:RibbonIcon Kind="Copy" IconSize="10"
                                                              VerticalAlignment="Center" Margin="0,0,2,0"/>
                                            <TextBlock Text="Copy" VerticalAlignment="Center" FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="FormatPainterBtn_Click" PreviewMouseLeftButtonDown="FormatPainterBtn_PreviewMouseLeftButtonDown" Width="126" Height="20" Margin="1,1,0,0"
                                            Style="{StaticResource RibbonBtn}" HorizontalContentAlignment="Left"
                                            local:RibbonTooltip.Title="Format Painter"
                                            local:RibbonTooltip.KeyTip="FP"
                                            local:RibbonTooltip.Description="Copy formatting from one place and apply it to another.">
                                        <StackPanel Orientation="Horizontal">
                                            <local:RibbonIcon Kind="FormatPainter" IconSize="11"
                                                              VerticalAlignment="Center" Margin="0,0,3,0"/>
                                            <TextBlock Text="Format Painter" Tag="RibbonLabel" VerticalAlignment="Center" FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <Border Grid.Row="1" Style="{StaticResource RibbonGroupLabelBorder}">
                                <TextBlock Text="Clipboard" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                        <Rectangle Style="{StaticResource RibbonGroupDivider}"/>

                        <!-- ▌Font ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="18"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="0,2,2,0">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="FontNameBox" Width="110" Height="22" Margin="1" Background="White"
                                              SelectionChanged="FontNameBox_SelectionChanged"
                                              AutomationProperties.Name="Font"
                                              local:RibbonTooltip.Title="Font"
                                              local:RibbonTooltip.KeyTip="FF"
                                              local:RibbonTooltip.Description="Change the font of the selected cells."/>
                                    <ComboBox x:Name="FontSizeBox" Width="40" Height="22" Margin="1" IsEditable="True" Background="White"
                                              SelectionChanged="FontSizeBox_SelectionChanged"
                                              AutomationProperties.Name="Font Size"
                                              local:RibbonTooltip.Title="Font Size"
                                              local:RibbonTooltip.KeyTip="FS"
                                              local:RibbonTooltip.Description="Change the font size of the selected cells."/>
                                    <Button Width="30" Height="22" Style="{StaticResource RibbonIconButton}"
                                            Click="IncreaseFontSizeBtn_Click"
                                            local:RibbonTooltip.Title="Increase Font Size"
                                            local:RibbonTooltip.KeyTip="FG"
                                            local:RibbonTooltip.Description="Make the font larger.">
                                        <Grid Width="26" Height="18" SnapsToDevicePixels="True">
                                            <TextBlock Text="A" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" Margin="0,-1,7,0"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       TextAlignment="Center"/>
                                            <TextBlock Text="A" FontFamily="Segoe UI" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,1,1"/>
                                            <Path Data="M 17 6 L 21 2 L 25 6" Stroke="#217346" StrokeThickness="1.3"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        </Grid>
                                    </Button>
                                    <Button Width="30" Height="22" Style="{StaticResource RibbonIconButton}"
                                            Click="DecreaseFontSizeBtn_Click"
                                            local:RibbonTooltip.Title="Decrease Font Size"
                                            local:RibbonTooltip.KeyTip="FK"
                                            local:RibbonTooltip.Description="Make the font smaller.">
                                        <Grid Width="26" Height="18" SnapsToDevicePixels="True">
                                            <TextBlock Text="A" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" Margin="0,-1,7,0"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       TextAlignment="Center"/>
                                            <TextBlock Text="A" FontFamily="Segoe UI" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,1,1,0"/>
                                            <Path Data="M 17 12 L 21 16 L 25 12" Stroke="#217346" StrokeThickness="1.3"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <ToggleButton x:Name="BoldButton"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="BoldButton_Click"
                                                  local:RibbonTooltip.Title="Bold"
                                                  local:RibbonTooltip.KeyTip="1"
                                                  local:RibbonTooltip.Description="Make the selected text bold (Ctrl+B).">
                                        <TextBlock Text="B" FontFamily="Segoe UI" FontSize="19" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <ToggleButton x:Name="ItalicButton"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="ItalicButton_Click"
                                                  local:RibbonTooltip.Title="Italic"
                                                  local:RibbonTooltip.KeyTip="2"
                                                  local:RibbonTooltip.Description="Italicize the selected text (Ctrl+I).">
                                        <TextBlock Text="I" FontFamily="Segoe UI" FontSize="19" FontStyle="Italic" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <ToggleButton x:Name="UnderlineButton"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="UnderlineButton_Click"
                                                  local:RibbonTooltip.Title="Underline"
                                                  local:RibbonTooltip.KeyTip="3"
                                                  local:RibbonTooltip.Description="Underline the selected text (Ctrl+U).">
                                        <Grid Width="20" Height="18" SnapsToDevicePixels="True">
                                            <TextBlock Text="U" FontFamily="Segoe UI" FontSize="17" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                            <Rectangle Width="13" Height="1" Fill="#242424"
                                                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                        </Grid>
                                    </ToggleButton>
                                    <ToggleButton x:Name="StrikeButton"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="StrikeButton_Click"
                                                  local:RibbonTooltip.Title="Strikethrough"
                                                  local:RibbonTooltip.KeyTip="4"
                                                  local:RibbonTooltip.Description="Draw a line through the middle of the selected text.">
                                        <TextBlock Text="S" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.TextDecorations>
                                                <TextDecorationCollection>
                                                    <TextDecoration Location="Strikethrough"/>
                                                </TextDecorationCollection>
                                            </TextBlock.TextDecorations>
                                        </TextBlock>
                                    </ToggleButton>
                                    <Rectangle Width="1" Fill="#CCCCCC" Margin="3,3"/>
                                    <Button Width="30" Height="22" Style="{StaticResource RibbonIconButton}"
                                            Click="BorderPickerBtn_Click"
                                            local:RibbonTooltip.Title="Borders"
                                            local:RibbonTooltip.KeyTip="B"
                                            local:RibbonTooltip.Description="Apply or change borders on the selected cells.">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="All Borders"          local:RibbonTooltip.KeyTip="A" Click="BorderAllMenuItem_Click"/>
                                                <MenuItem Header="Outside Borders"      local:RibbonTooltip.KeyTip="O" Click="BorderOutsideMenuItem_Click"/>
                                                <MenuItem Header="Inside Borders"       local:RibbonTooltip.KeyTip="I" Click="BorderInsideMenuItem_Click"/>
                                                <MenuItem Header="No Border"            local:RibbonTooltip.KeyTip="N" Click="BorderNoneMenuItem_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Bottom Border"        local:RibbonTooltip.KeyTip="B" Click="BorderBottomMenuItem_Click"/>
                                                <MenuItem Header="Top Border"           local:RibbonTooltip.KeyTip="T" Click="BorderTopMenuItem_Click"/>
                                                <MenuItem Header="Left Border"          local:RibbonTooltip.KeyTip="L" Click="BorderLeftMenuItem_Click"/>
                                                <MenuItem Header="Right Border"         local:RibbonTooltip.KeyTip="R" Click="BorderRightMenuItem_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Thick Bottom Border"  local:RibbonTooltip.KeyTip="K" Click="BorderThickBottomMenuItem_Click"/>
                                                <MenuItem Header="Bottom Double Border" local:RibbonTooltip.KeyTip="D" Click="BorderBottomDoubleMenuItem_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Thick Box Border" local:RibbonTooltip.KeyTip="X" Click="BorderThickBoxMenuItem_Click"/>
                                                <MenuItem Header="Top and Bottom Border" local:RibbonTooltip.KeyTip="U" Click="BorderTopAndBottomMenuItem_Click"/>
                                                <MenuItem Header="Top and Thick Bottom Border" local:RibbonTooltip.KeyTip="H" Click="BorderTopAndThickBottomMenuItem_Click"/>
                                                <MenuItem Header="Top and Double Bottom Border" local:RibbonTooltip.KeyTip="J" Click="BorderTopAndDoubleBottomMenuItem_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Line Color" local:RibbonTooltip.KeyTip="C">
                                                    <MenuItem Header="Black" local:RibbonTooltip.KeyTip="K" Click="BorderLineColorBlackMenuItem_Click"/>
                                                    <MenuItem Header="Gray" local:RibbonTooltip.KeyTip="G" Click="BorderLineColorGrayMenuItem_Click"/>
                                                    <MenuItem Header="Accent 1" local:RibbonTooltip.KeyTip="1" Click="BorderLineColorAccent1MenuItem_Click"/>
                                                    <MenuItem Header="Accent 2" local:RibbonTooltip.KeyTip="2" Click="BorderLineColorAccent2MenuItem_Click"/>
                                                </MenuItem>
                                                <MenuItem Header="Line Style" local:RibbonTooltip.KeyTip="S">
                                                    <MenuItem Header="Thin" local:RibbonTooltip.KeyTip="T" Click="BorderLineStyleThinMenuItem_Click"/>
                                                    <MenuItem Header="Medium" local:RibbonTooltip.KeyTip="M" Click="BorderLineStyleMediumMenuItem_Click"/>
                                                    <MenuItem Header="Thick" local:RibbonTooltip.KeyTip="K" Click="BorderLineStyleThickMenuItem_Click"/>
                                                    <MenuItem Header="Dashed" local:RibbonTooltip.KeyTip="D" Click="BorderLineStyleDashedMenuItem_Click"/>
                                                    <MenuItem Header="Dotted" local:RibbonTooltip.KeyTip="O" Click="BorderLineStyleDottedMenuItem_Click"/>
                                                    <MenuItem Header="Double" local:RibbonTooltip.KeyTip="U" Click="BorderLineStyleDoubleMenuItem_Click"/>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="More Borders..." local:RibbonTooltip.KeyTip="M" Click="BorderMoreMenuItem_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Grid Width="15" Height="15" SnapsToDevicePixels="True">
                                            <Grid.RowDefinitions>
                                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.RowSpan="3" Grid.ColumnSpan="3" BorderBrush="#111" BorderThickness="1"/>
                                            <Border Grid.Column="1" Grid.RowSpan="3" BorderBrush="#111" BorderThickness="1,0,0,0"/>
                                            <Border Grid.Column="2" Grid.RowSpan="3" BorderBrush="#111" BorderThickness="1,0,0,0"/>
                                            <Border Grid.Row="1" Grid.ColumnSpan="3" BorderBrush="#111" BorderThickness="0,1,0,0"/>
                                            <Border Grid.Row="2" Grid.ColumnSpan="3" BorderBrush="#111" BorderThickness="0,1,0,0"/>
                                        </Grid>
                                    </Button>
                                    <Rectangle Width="1" Fill="#CCCCCC" Margin="3,3"/>
                                    <Button x:Name="FontColorBtn" Width="28" Height="22"
                                            Style="{StaticResource RibbonIconButton}"
                                            Click="FontColorBtn_Click"
                                            local:RibbonTooltip.Title="Font Color"
                                            local:RibbonTooltip.KeyTip="FC"
                                            local:RibbonTooltip.Description="Change the color of the text.">
                                        <StackPanel>
                                            <TextBlock Text="A" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,-3,0,0"/>
                                            <Rectangle x:Name="FontColorBar" Height="3" Width="17" Fill="#FF0000" Margin="0,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="FillColorBtn" Width="28" Height="22"
                                            Style="{StaticResource RibbonIconButton}"
                                            Click="FillColorBtn_Click"
                                            local:RibbonTooltip.Title="Fill Color"
                                            local:RibbonTooltip.KeyTip="H"
                                            local:RibbonTooltip.Description="Color the background of the selected cells.">
                                        <Grid Width="20" Height="18">
                                            <Rectangle Width="17" Height="15" Fill="{Binding ElementName=FillColorBar, Path=Fill}"
                                                       Stroke="#555" StrokeThickness="1"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Text="A" FontFamily="Segoe UI" FontSize="17" FontWeight="SemiBold"
                                                       Foreground="#242424"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                            <Rectangle x:Name="FillColorBar" Width="0" Height="0" Fill="#FFFF00"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" Style="{StaticResource RibbonGroupLabelBorder}">
                                <TextBlock Text="Font" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                        <Rectangle Style="{StaticResource RibbonGroupDivider}"/>

                        <!-- ▌Alignment ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="18"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="0,2,2,0">
                                <!-- Vertical align + Orientation + Wrap -->
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="AlignTopBtn"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="AlignTopBtn_Click"
                                                  local:RibbonTooltip.Title="Top Align"
                                                  local:RibbonTooltip.KeyTip="AT"
                                                  local:RibbonTooltip.Description="Align the contents to the top of the cell.">
                                        <Grid Width="20" Height="20">
                                            <StackPanel Margin="3,4,3,0" VerticalAlignment="Top">
                                                <Rectangle Height="1" Fill="#202124" Margin="0,0,0,3"/>
                                                <Rectangle Height="1" Fill="#202124" Margin="2,0,2,3"/>
                                                <Rectangle Height="1" Fill="#202124" Margin="4,0,4,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </ToggleButton>
                                    <ToggleButton x:Name="AlignMiddleBtn"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="AlignMiddleBtn_Click"
                                                  local:RibbonTooltip.Title="Middle Align"
                                                  local:RibbonTooltip.KeyTip="AM"
                                                  local:RibbonTooltip.Description="Align the contents between the top and bottom of the cell.">
                                        <Grid Width="20" Height="20">
                                            <StackPanel Margin="3,0" VerticalAlignment="Center">
                                                <Rectangle Height="1" Fill="#202124" Margin="4,0,4,3"/>
                                                <Rectangle Height="1" Fill="#202124" Margin="0,0,0,3"/>
                                                <Rectangle Height="1" Fill="#202124" Margin="4,0,4,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </ToggleButton>
                                    <ToggleButton x:Name="AlignBottomBtn"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="AlignBottomBtn_Click"
                                                  local:RibbonTooltip.Title="Bottom Align"
                                                  local:RibbonTooltip.KeyTip="AB"
                                                  local:RibbonTooltip.Description="Align the contents to the bottom of the cell.">
                                        <Grid Width="20" Height="20">
                                            <StackPanel Margin="3,0,3,4" VerticalAlignment="Bottom">
                                                <Rectangle Height="1" Fill="#202124" Margin="4,0,4,3"/>
                                                <Rectangle Height="1" Fill="#202124" Margin="2,0,2,3"/>
                                                <Rectangle Height="1" Fill="#202124" Margin="0,0,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </ToggleButton>
                                    <Rectangle Width="1" Fill="#CCCCCC" Margin="3,3"/>
                                    <Button Width="40" Height="22" Style="{StaticResource RibbonBtn}"
                                            Click="OrientationPickerBtn_Click"
                                            local:RibbonTooltip.Title="Orientation"
                                            local:RibbonTooltip.KeyTip="RO"
                                            local:RibbonTooltip.Description="Rotate text diagonally or vertically in a cell.">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Horizontal"               local:RibbonTooltip.KeyTip="H" Click="OrientHorizMenuItem_Click"/>
                                                <MenuItem Header="Angle Counterclockwise"   local:RibbonTooltip.KeyTip="A" Click="OrientAngleCCWMenuItem_Click"/>
                                                <MenuItem Header="Angle Clockwise"          local:RibbonTooltip.KeyTip="C" Click="OrientAngleCWMenuItem_Click"/>
                                                <MenuItem Header="Vertical Text"            local:RibbonTooltip.KeyTip="V" Click="OrientVertMenuItem_Click"/>
                                                <MenuItem Header="Rotate Text Up"           local:RibbonTooltip.KeyTip="U" Click="OrientRotateUpMenuItem_Click"/>
                                                <MenuItem Header="Rotate Text Down"         local:RibbonTooltip.KeyTip="D" Click="OrientRotateDownMenuItem_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <TextBlock Text="ab&#x2197;" FontSize="10" VerticalAlignment="Center"/>
                                    </Button>
                                    <ToggleButton x:Name="WrapTextBtn" Width="58" Height="22"
                                                  Style="{StaticResource RibbonToggleBtn}"
                                                  Click="WrapTextBtn_Click"
                                                  local:RibbonTooltip.Title="Wrap Text"
                                                  local:RibbonTooltip.KeyTip="W"
                                                  local:RibbonTooltip.Description="Make all content visible within a cell by displaying it on multiple lines.">
                                        <StackPanel Orientation="Horizontal">
                                            <local:RibbonIcon Kind="Wrap" IconSize="11"
                                                              VerticalAlignment="Center" Margin="0,0,2,0"/>
                                            <TextBlock Text="Wrap" FontSize="9" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                </StackPanel>
                                <!-- Horizontal align + indent + merge -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <ToggleButton x:Name="AlignLeftBtn"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="AlignLeftBtn_Click"
                                                  local:RibbonTooltip.Title="Align Left"
                                                  local:RibbonTooltip.KeyTip="AL"
                                                  local:RibbonTooltip.Description="Align the contents to the left edge of the cell (Ctrl+L).">
                                        <local:RibbonIcon Kind="Align" IconSize="13"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <ToggleButton x:Name="AlignCenterBtn"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="AlignCenterBtn_Click"
                                                  local:RibbonTooltip.Title="Center"
                                                  local:RibbonTooltip.KeyTip="AC"
                                                  local:RibbonTooltip.Description="Center the contents of the selected cells (Ctrl+E).">
                                        <local:RibbonIcon Kind="Align" IconSize="13"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <ToggleButton x:Name="AlignRightBtn"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="AlignRightBtn_Click"
                                                  local:RibbonTooltip.Title="Align Right"
                                                  local:RibbonTooltip.KeyTip="AR"
                                                  local:RibbonTooltip.Description="Align the contents to the right edge of the cell (Ctrl+R).">
                                        <local:RibbonIcon Kind="Align" IconSize="13"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <Rectangle Width="1" Fill="#CCCCCC" Margin="3,3"/>
                                    <Button Width="30" Height="22" Style="{StaticResource RibbonIconButton}"
                                            Click="IndentDecBtn_Click"
                                            local:RibbonTooltip.Title="Decrease Indent"
                                            local:RibbonTooltip.KeyTip="AO"
                                            local:RibbonTooltip.Description="Decrease the indent level of the cell contents.">
                                        <Grid Width="26" Height="18" SnapsToDevicePixels="True">
                                            <Path Data="M 9 4 H 24 M 9 9 H 21 M 9 14 H 24"
                                                  Stroke="#242424" StrokeThickness="1"
                                                  StrokeStartLineCap="Square" StrokeEndLineCap="Square"/>
                                            <Path Data="M 7 5 L 2 9 L 7 13" Stroke="#217346" StrokeThickness="1.4"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        </Grid>
                                    </Button>
                                    <Button Width="30" Height="22" Style="{StaticResource RibbonIconButton}"
                                            Click="IndentIncBtn_Click"
                                            local:RibbonTooltip.Title="Increase Indent"
                                            local:RibbonTooltip.KeyTip="AI"
                                            local:RibbonTooltip.Description="Increase the indent level of the cell contents.">
                                        <Grid Width="26" Height="18" SnapsToDevicePixels="True">
                                            <Path Data="M 2 4 H 17 M 5 9 H 17 M 2 14 H 17"
                                                  Stroke="#242424" StrokeThickness="1"
                                                  StrokeStartLineCap="Square" StrokeEndLineCap="Square"/>
                                            <Path Data="M 19 5 L 24 9 L 19 13" Stroke="#217346" StrokeThickness="1.4"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        </Grid>
                                    </Button>
                                    <Button Width="106" Height="22" Margin="2,0,0,0" Style="{StaticResource RibbonBtn}"
                                            Click="MergeCenterBtn_Click"
                                            local:RibbonTooltip.Title="Merge &amp; Center"
                                            local:RibbonTooltip.KeyTip="M"
                                            local:RibbonTooltip.Description="Join the selected cells into one larger cell and center the contents.">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Grid Width="20" Height="14" Margin="0,0,4,0">
                                                <Border BorderBrush="#111" BorderThickness="1"/>
                                                <Rectangle Height="1" Fill="#111" VerticalAlignment="Center"/>
                                                <Path Data="M 2 7 L 7 3 M 2 7 L 7 11 M 18 7 L 13 3 M 18 7 L 13 11"
                                                      Stroke="#111" StrokeThickness="1"/>
                                            </Grid>
                                            <TextBlock Text="Merge &amp; Center" Tag="RibbonLabel" FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" Style="{StaticResource RibbonGroupLabelBorder}">
                                <TextBlock Text="Alignment" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                        <Rectangle Style="{StaticResource RibbonGroupDivider}"/>

                        <!-- ▌Number ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="18"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="0,2,2,0">
                                <ComboBox x:Name="NumberFormatBox" Width="116" Height="22" Margin="1,4,1,2" Background="White"
                                          SelectionChanged="NumberFormatBox_SelectionChanged"
                                          AutomationProperties.Name="Number Format"
                                          local:RibbonTooltip.Title="Number Format"
                                          local:RibbonTooltip.KeyTip="N"
                                          local:RibbonTooltip.Description="Choose how to display values in the selected cells."/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <Button Style="{StaticResource RibbonIconButton}"
                                            Click="CurrencyBtn_Click"
                                            local:RibbonTooltip.Title="Accounting Number Format"
                                            local:RibbonTooltip.KeyTip="AN"
                                            local:RibbonTooltip.Description="Choose the currency format for selected cells.">
                                        <TextBlock Text="$" FontFamily="Segoe UI" FontSize="19" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Style="{StaticResource RibbonIconButton}"
                                            Click="PercentBtn_Click"
                                            local:RibbonTooltip.Title="Percent Style"
                                            local:RibbonTooltip.KeyTip="P"
                                            local:RibbonTooltip.Description="Display values as a percentage (Ctrl+Shift+%).">
                                        <TextBlock Text="%" FontFamily="Segoe UI" FontSize="19" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Style="{StaticResource RibbonIconButton}"
                                            Click="CommaStyleBtn_Click"
                                            local:RibbonTooltip.Title="Comma Style"
                                            local:RibbonTooltip.KeyTip="K"
                                            local:RibbonTooltip.Description="Display values with a thousands separator.">
                                        <TextBlock Text="," FontFamily="Segoe UI" FontSize="23" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-7,0,0"/>
                                    </Button>
                                    <Button Width="42" Height="22" Style="{StaticResource RibbonIconButton}"
                                            Click="IncDecimalBtn_Click"
                                            local:RibbonTooltip.Title="Increase Decimal Places"
                                            local:RibbonTooltip.KeyTip="QI"
                                            local:RibbonTooltip.Description="Show more decimal places.">
                                        <Grid Width="38" Height="18" SnapsToDevicePixels="True">
                                            <StackPanel Margin="1,0,10,0" VerticalAlignment="Center">
                                                <TextBlock Text="0.0" FontFamily="Segoe UI" FontSize="10" LineHeight="9"
                                                           HorizontalAlignment="Left"/>
                                                <TextBlock Text="0.00" FontFamily="Segoe UI" FontSize="10" LineHeight="9"
                                                           HorizontalAlignment="Left" Margin="0,-1,0,0"/>
                                            </StackPanel>
                                            <Path Data="M 30 5 L 35 9 L 30 13" Stroke="#1F6AA5" StrokeThickness="1.4"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        </Grid>
                                    </Button>
                                    <Button Width="42" Height="22" Style="{StaticResource RibbonIconButton}"
                                            Click="DecDecimalBtn_Click"
                                            local:RibbonTooltip.Title="Decrease Decimal Places"
                                            local:RibbonTooltip.KeyTip="QD"
                                            local:RibbonTooltip.Description="Show fewer decimal places.">
                                        <Grid Width="38" Height="18" SnapsToDevicePixels="True">
                                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="0.00" FontFamily="Segoe UI" FontSize="10" LineHeight="9"
                                                           HorizontalAlignment="Left"/>
                                                <TextBlock Text="0.0" FontFamily="Segoe UI" FontSize="10" LineHeight="9"
                                                           HorizontalAlignment="Left" Margin="0,-1,0,0"/>
                                            </StackPanel>
                                            <Path Data="M 8 5 L 3 9 L 8 13" Stroke="#1F6AA5" StrokeThickness="1.4"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" Style="{StaticResource RibbonGroupLabelBorder}">
                                <TextBlock Text="Number" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                        <Rectangle Style="{StaticResource RibbonGroupDivider}"/>

                        <!-- ▌Styles ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="18"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,2,0">
                                <!-- Conditional Formatting -->
                                <Button Width="94" Height="76" Margin="1,0" Tag="RibbonCompact:94:36"
                                        Style="{StaticResource RibbonTallButton}" Click="CfPickerBtn_Click"
                                        local:RibbonTooltip.Title="Conditional Formatting"
                                        local:RibbonTooltip.KeyTip="L"
                                        local:RibbonTooltip.Description="Highlight cells based on their values using rules, color scales, or data bars.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Highlight Cells Rules" local:RibbonTooltip.KeyTip="H">
                                                <MenuItem Header="Greater Than..."        local:RibbonTooltip.KeyTip="HG" Click="CfGtMenuItem_Click"/>
                                                <MenuItem Header="Less Than..."           local:RibbonTooltip.KeyTip="HL" Click="CfLtMenuItem_Click"/>
                                                <MenuItem Header="Between..."             local:RibbonTooltip.KeyTip="HB" Click="CfBetweenMenuItem_Click"/>
                                                <MenuItem Header="Equal To..."            local:RibbonTooltip.KeyTip="HE" Click="CfEqMenuItem_Click"/>
                                                <MenuItem Header="Text that Contains..."  local:RibbonTooltip.KeyTip="HT" Click="CfTextMenuItem_Click"/>
                                                <MenuItem Header="A Date Occurring..."    local:RibbonTooltip.KeyTip="HD" Click="CfDateMenuItem_Click"/>
                                                <MenuItem Header="Duplicate Values..."    local:RibbonTooltip.KeyTip="HU" Click="CfDuplicateMenuItem_Click"/>
                                            </MenuItem>
                                            <MenuItem Header="Top/Bottom Rules" local:RibbonTooltip.KeyTip="T">
                                                <MenuItem Header="Top 10 Items..."        local:RibbonTooltip.KeyTip="TT" Click="CfTop10MenuItem_Click"/>
                                                <MenuItem Header="Top 10%..."             local:RibbonTooltip.KeyTip="TP" Click="CfTop10PercentMenuItem_Click"/>
                                                <MenuItem Header="Bottom 10 Items..."     local:RibbonTooltip.KeyTip="TB" Click="CfBottom10MenuItem_Click"/>
                                                <MenuItem Header="Bottom 10%..."          local:RibbonTooltip.KeyTip="BP" Click="CfBottom10PercentMenuItem_Click"/>
                                                <MenuItem Header="Above Average..."       local:RibbonTooltip.KeyTip="TA" Click="CfAboveAvgMenuItem_Click"/>
                                                <MenuItem Header="Below Average..."       local:RibbonTooltip.KeyTip="TL" Click="CfBelowAvgMenuItem_Click"/>
                                            </MenuItem>
                                            <MenuItem Header="Data Bars..."               local:RibbonTooltip.KeyTip="D" Click="CfDataBarMenuItem_Click"/>
                                            <MenuItem Header="Color Scales..."            local:RibbonTooltip.KeyTip="C" Click="CfColorScaleMenuItem_Click"/>
                                            <MenuItem Header="Icon Sets"                  local:RibbonTooltip.KeyTip="I">
                                                <MenuItem Header="Directional" local:RibbonTooltip.KeyTip="ID" IsEnabled="False"/>
                                                <MenuItem Header="3 Arrows"               local:RibbonTooltip.KeyTip="I3" Tag="3Arrows" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="3 Arrows (Gray)"        local:RibbonTooltip.KeyTip="IG" Tag="3ArrowsGray" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="4 Arrows"               local:RibbonTooltip.KeyTip="I4" Tag="4Arrows" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="4 Arrows (Gray)"        local:RibbonTooltip.KeyTip="IH" Tag="4ArrowsGray" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="5 Arrows"               local:RibbonTooltip.KeyTip="I5" Tag="5Arrows" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="5 Arrows (Gray)"        local:RibbonTooltip.KeyTip="IJ" Tag="5ArrowsGray" Click="CfIconSetPresetMenuItem_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Shapes" local:RibbonTooltip.KeyTip="IK" IsEnabled="False"/>
                                                <MenuItem Header="3 Traffic Lights"       local:RibbonTooltip.KeyTip="IT" Tag="3TrafficLights1" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="3 Traffic Lights (Rimmed)" local:RibbonTooltip.KeyTip="IR" Tag="3TrafficLights2" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="3 Signs"                local:RibbonTooltip.KeyTip="IS" Tag="3Signs" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="3 Symbols"              local:RibbonTooltip.KeyTip="IY" Tag="3Symbols" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="3 Symbols (Uncircled)"  local:RibbonTooltip.KeyTip="IU" Tag="3Symbols2" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="3 Flags"                local:RibbonTooltip.KeyTip="IF" Tag="3Flags" Click="CfIconSetPresetMenuItem_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Indicators" local:RibbonTooltip.KeyTip="IO" IsEnabled="False"/>
                                                <MenuItem Header="4 Traffic Lights"       local:RibbonTooltip.KeyTip="IL" Tag="4TrafficLights" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="4 Red To Black"         local:RibbonTooltip.KeyTip="IB" Tag="4RedToBlack" Click="CfIconSetPresetMenuItem_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Ratings" local:RibbonTooltip.KeyTip="IZ" IsEnabled="False"/>
                                                <MenuItem Header="4 Ratings"              local:RibbonTooltip.KeyTip="I9" Tag="4Rating" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="5 Ratings"              local:RibbonTooltip.KeyTip="IA" Tag="5Rating" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="5 Quarters"             local:RibbonTooltip.KeyTip="IQ" Tag="5Quarters" Click="CfIconSetPresetMenuItem_Click"/>
                                                <MenuItem Header="5 Boxes"                local:RibbonTooltip.KeyTip="IX" Tag="5Boxes" Click="CfIconSetPresetMenuItem_Click"/>
                                                <Separator/>
                                                <MenuItem Header="More Rules..."          local:RibbonTooltip.KeyTip="IM" Click="CfIconSetMenuItem_Click"/>
                                            </MenuItem>
                                            <Separator/>
                                            <MenuItem Header="New Rule..."                local:RibbonTooltip.KeyTip="N" Click="CfNewRuleMenuItem_Click"/>
                                            <MenuItem Header="New Formula Rule..."        local:RibbonTooltip.KeyTip="F" Click="CfNewFormulaRuleMenuItem_Click"/>
                                            <MenuItem Header="Clear Rules"                local:RibbonTooltip.KeyTip="R" Click="CfClearRulesMenuItem_Click"/>
                                            <MenuItem Header="Manage Rules..."            local:RibbonTooltip.KeyTip="M" Click="CfManageRulesMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel HorizontalAlignment="Center">
                                        <local:RibbonIcon Kind="Theme" IconSize="20"
                                                          HorizontalAlignment="Center" Margin="0,5,0,3"/>
                                        <TextBlock Text="Conditional" Tag="RibbonLabel" FontSize="9" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Formatting" Tag="RibbonLabel" FontSize="9" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <!-- Format as Table -->
                                <Button Width="78" Height="76" Margin="1,0" Tag="RibbonCompact:78:36"
                                        Style="{StaticResource RibbonTallButton}" Click="FormatTableBtn_Click"
                                        local:RibbonTooltip.Title="Format as Table"
                                        local:RibbonTooltip.KeyTip="T"
                                        local:RibbonTooltip.Description="Quickly format a range as a styled table.">
                                    <Button.ContextMenu>
                                        <ContextMenu x:Name="FormatTableGalleryMenu"/>
                                    </Button.ContextMenu>
                                    <StackPanel HorizontalAlignment="Center">
                                        <local:RibbonIcon Kind="Table" IconSize="20"
                                                          HorizontalAlignment="Center" Margin="0,5,0,3"/>
                                        <TextBlock Text="Format as" Tag="RibbonLabel" FontSize="9" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Table" Tag="RibbonLabel" FontSize="9" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <!-- Cell Styles -->
                                <Button Width="66" Height="76" Margin="1,0" Tag="RibbonCompact:66:36"
                                        Style="{StaticResource RibbonTallButton}" Click="CellStylesBtn_Click"
                                        local:RibbonTooltip.Title="Cell Styles"
                                        local:RibbonTooltip.KeyTip="J"
                                        local:RibbonTooltip.Description="Apply a predefined cell style.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Normal"       local:RibbonTooltip.KeyTip="NM" Click="CellStyleNormalMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Good"         local:RibbonTooltip.KeyTip="GD" Click="CellStyleGoodMenuItem_Click"/>
                                            <MenuItem Header="Bad"          local:RibbonTooltip.KeyTip="BD" Click="CellStyleBadMenuItem_Click"/>
                                            <MenuItem Header="Neutral"      local:RibbonTooltip.KeyTip="NT" Click="CellStyleNeutralMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Input"        local:RibbonTooltip.KeyTip="IN" Click="CellStyleInputMenuItem_Click"/>
                                            <MenuItem Header="Output"       local:RibbonTooltip.KeyTip="OP" Click="CellStyleOutputMenuItem_Click"/>
                                            <MenuItem Header="Calculation"  local:RibbonTooltip.KeyTip="CA" Click="CellStyleCalculationMenuItem_Click"/>
                                            <MenuItem Header="Check Cell"   local:RibbonTooltip.KeyTip="CK" Click="CellStyleCheckCellMenuItem_Click"/>
                                            <MenuItem Header="Linked Cell"  local:RibbonTooltip.KeyTip="LK" Click="CellStyleLinkedCellMenuItem_Click"/>
                                            <MenuItem Header="Explanatory Text" local:RibbonTooltip.KeyTip="EX" Click="CellStyleExplanatoryTextMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Heading 1"    local:RibbonTooltip.KeyTip="H1" Click="CellStyleH1MenuItem_Click"/>
                                            <MenuItem Header="Heading 2"    local:RibbonTooltip.KeyTip="H2" Click="CellStyleH2MenuItem_Click"/>
                                            <MenuItem Header="Note"         local:RibbonTooltip.KeyTip="NO" Click="CellStyleNoteMenuItem_Click"/>
                                            <MenuItem Header="Warning Text" local:RibbonTooltip.KeyTip="WT" Click="CellStyleWarningMenuItem_Click"/>
                                            <MenuItem Header="Total"        local:RibbonTooltip.KeyTip="TT" Click="CellStyleTotalMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="20% - Accent 1" local:RibbonTooltip.KeyTip="A1" Click="CellStyleAccent1_20MenuItem_Click"/>
                                            <MenuItem Header="20% - Accent 2" local:RibbonTooltip.KeyTip="A2" Click="CellStyleAccent2_20MenuItem_Click"/>
                                            <MenuItem Header="20% - Accent 3" local:RibbonTooltip.KeyTip="A3" Click="CellStyleAccent3_20MenuItem_Click"/>
                                            <MenuItem Header="20% - Accent 4" local:RibbonTooltip.KeyTip="A4" Click="CellStyleAccent4_20MenuItem_Click"/>
                                            <MenuItem Header="20% - Accent 5" local:RibbonTooltip.KeyTip="A5" Click="CellStyleAccent5_20MenuItem_Click"/>
                                            <MenuItem Header="20% - Accent 6" local:RibbonTooltip.KeyTip="A6" Click="CellStyleAccent6_20MenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel HorizontalAlignment="Center">
                                        <local:RibbonIcon Kind="Color" IconSize="20"
                                                          HorizontalAlignment="Center" Margin="0,5,0,3"/>
                                        <TextBlock Text="Cell" Tag="RibbonLabel" FontSize="9" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Styles" Tag="RibbonLabel" FontSize="9" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
