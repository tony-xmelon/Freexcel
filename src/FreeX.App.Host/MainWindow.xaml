                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_SelectItems}" local:RibbonTooltip.KeyTip="I" Click="PivotFieldSelectItemsMenuItem_Click" local:RibbonMetadata.CommandName="Select Items"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_LabelFilter}" local:RibbonTooltip.KeyTip="L" Click="PivotFieldLabelFilterMenuItem_Click" local:RibbonMetadata.CommandName="Label Filter"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_ValueFilter}" local:RibbonTooltip.KeyTip="F" Click="PivotFieldValueFilterMenuItem_Click" local:RibbonMetadata.CommandName="Value Filter"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_ClearFilter}" local:RibbonTooltip.KeyTip="C" Click="PivotFieldClearFilterMenuItem_Click" local:RibbonMetadata.CommandName="Clear Filter"/>
                                    <Separator/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_ValueFieldSettings}" local:RibbonTooltip.KeyTip="V" Click="PivotFieldValueSettingsMenuItem_Click" local:RibbonMetadata.CommandName="Value Field Settings"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{local:Loc Key=MainWindow_Text_Rows}" FontWeight="SemiBold" Margin="0,8,0,3"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{local:Loc Key=MainWindow_Text_Values}" FontWeight="SemiBold" Margin="0,8,0,3"/>
                        <ListBox x:Name="PivotRowsList"
                                 Grid.Row="3"
                                 Grid.Column="0"
                                 MinHeight="80"
                                 SelectionMode="Single"
                                 AllowDrop="True"
                                 PreviewMouseMove="PivotFieldList_PreviewMouseMove"
                                 Drop="PivotFieldList_Drop"
                                 AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_PivotTableRowsArea}">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_SortAToZ}" local:RibbonTooltip.KeyTip="S" Click="PivotFieldSortAscendingMenuItem_Click" local:RibbonMetadata.CommandName="Sort A to Z"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_SortZToA}" local:RibbonTooltip.KeyTip="O" Click="PivotFieldSortDescendingMenuItem_Click" local:RibbonMetadata.CommandName="Sort Z to A"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_SelectItems}" local:RibbonTooltip.KeyTip="I" Click="PivotFieldSelectItemsMenuItem_Click" local:RibbonMetadata.CommandName="Select Items"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_LabelFilter}" local:RibbonTooltip.KeyTip="L" Click="PivotFieldLabelFilterMenuItem_Click" local:RibbonMetadata.CommandName="Label Filter"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_ValueFilter}" local:RibbonTooltip.KeyTip="F" Click="PivotFieldValueFilterMenuItem_Click" local:RibbonMetadata.CommandName="Value Filter"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_ClearFilter}" local:RibbonTooltip.KeyTip="C" Click="PivotFieldClearFilterMenuItem_Click" local:RibbonMetadata.CommandName="Clear Filter"/>
                                    <Separator/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_ValueFieldSettings}" local:RibbonTooltip.KeyTip="V" Click="PivotFieldValueSettingsMenuItem_Click" local:RibbonMetadata.CommandName="Value Field Settings"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                        <ListBox x:Name="PivotValuesList"
                                 Grid.Row="3"
                                 Grid.Column="2"
                                 MinHeight="80"
                                 SelectionMode="Single"
                                 AllowDrop="True"
                                 PreviewMouseMove="PivotFieldList_PreviewMouseMove"
                                 Drop="PivotFieldList_Drop"
                                 AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_PivotTableValuesArea}">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_SortAToZ}" local:RibbonTooltip.KeyTip="S" Click="PivotFieldSortAscendingMenuItem_Click" local:RibbonMetadata.CommandName="Sort A to Z"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_SortZToA}" local:RibbonTooltip.KeyTip="O" Click="PivotFieldSortDescendingMenuItem_Click" local:RibbonMetadata.CommandName="Sort Z to A"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_SelectItems}" local:RibbonTooltip.KeyTip="I" Click="PivotFieldSelectItemsMenuItem_Click" local:RibbonMetadata.CommandName="Select Items"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_LabelFilter}" local:RibbonTooltip.KeyTip="L" Click="PivotFieldLabelFilterMenuItem_Click" local:RibbonMetadata.CommandName="Label Filter"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_ValueFilter}" local:RibbonTooltip.KeyTip="F" Click="PivotFieldValueFilterMenuItem_Click" local:RibbonMetadata.CommandName="Value Filter"/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_ClearFilter}" local:RibbonTooltip.KeyTip="C" Click="PivotFieldClearFilterMenuItem_Click" local:RibbonMetadata.CommandName="Clear Filter"/>
                                    <Separator/>
                                    <MenuItem Header="{local:Loc Key=MainWindow_Header_ValueFieldSettings}" local:RibbonTooltip.KeyTip="V" Click="PivotFieldValueSettingsMenuItem_Click" local:RibbonMetadata.CommandName="Value Field Settings"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="SlicerTimelinePane"
                    Grid.Column="3"
                    Width="280"
                    Background="#FFFFFF"
                    BorderBrush="#C8C8C8"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed"
                    KeyboardNavigation.TabNavigation="Cycle"
                    KeyboardNavigation.ControlTabNavigation="Cycle"
                    AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_SlicersAndTimelines}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <DockPanel LastChildFill="True" Margin="0,0,0,8">
                            <Button x:Name="SlicerTimelinePaneCloseBtn"
                                    Content="X"
                                    Width="22"
                                    Height="22"
                                    DockPanel.Dock="Right"
                                    Padding="0"
                                    Click="SlicerTimelinePaneCloseBtn_Click"
                                    AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_CloseSlicersAndTimelines}" local:RibbonMetadata.CommandName="X"/>
                            <TextBlock Text="{local:Loc Key=MainWindow_Text_SlicersAndTimelines}"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <ItemsControl x:Name="SlicerItemsControl"
                                      AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_WorkbookSlicers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,10" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding FieldName}" FontSize="11" Foreground="#666" Margin="0,1,0,6"/>
                                            <ItemsControl ItemsSource="{Binding Tiles}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Caption}"
                                                                Tag="{Binding SlicerName}"
                                                                Click="SlicerTileButton_Click"
                                                                MinHeight="24"
                                                                Margin="0,1"
                                                                HorizontalContentAlignment="Left"
                                                                AutomationProperties.Name="{Binding Caption}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Content="{local:Loc Key=MainWindow_Content_ClearFilter}"
                                                    Tag="{Binding Name}"
                                                    Click="SlicerClearButton_Click"
                                                    Margin="0,6,0,0"
                                                    MinHeight="24"
                                                    AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_ClearSlicerFilter}" local:RibbonMetadata.CommandName="Clear Filter"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl x:Name="TimelineItemsControl"
                                      AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_WorkbookTimelines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,10" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding FieldName}" FontSize="11" Foreground="#666" Margin="0,1,0,6"/>
                                            <UniformGrid Columns="2">
                                                <TextBox x:Name="TimelineStartBox" Text="{Binding SelectedStartDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,3,0"/>
                                                <TextBox x:Name="TimelineEndBox" Text="{Binding SelectedEndDate, UpdateSourceTrigger=PropertyChanged}" Margin="3,0,0,0"/>
                                            </UniformGrid>
                                            <UniformGrid Columns="2" Margin="0,6,0,0">
                                            <Button Content="{local:Loc Key=MainWindow_Content_Apply}" Click="TimelineApplyButton_Click" MinHeight="24" Margin="0,0,3,0"
                                                    AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_ApplyTimelineFilter}" local:RibbonMetadata.CommandName="Apply"/>
                                            <Button Content="{local:Loc Key=MainWindow_Content_Clear}" Click="TimelineClearButton_Click" MinHeight="24" Margin="3,0,0,0"
                                                    AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_ClearTimelineFilter}" local:RibbonMetadata.CommandName="Clear"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 4  Sheet tabs
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Panel.ZIndex="5" Background="{StaticResource FreeXSheetSurfaceBrush}" BorderBrush="{StaticResource FreeXBorderBrush}"
                BorderThickness="0" Padding="0">
            <Grid x:Name="SheetTabsRowGrid"
                  Background="{StaticResource FreeXSheetSurfaceBrush}"
                  SizeChanged="SheetTabsRowGrid_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="SheetTabsLeadingSpacer" Grid.Column="0"
                        Width="{Binding ActualRowHeaderWidth, ElementName=SheetGrid}"
                        Height="27"
                        Margin="0,1,0,0"
                        VerticalAlignment="Top"
                        Panel.ZIndex="4"
                        Background="{StaticResource FreeXSheetSurfaceBrush}"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        IsHitTestVisible="False"/>

                <Canvas x:Name="SheetTabsChromeLayer"
                        Grid.Column="0"
                        Grid.ColumnSpan="6"
                        Height="28"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Panel.ZIndex="1"
                        ClipToBounds="False"
                        SnapsToDevicePixels="True"
                        IsHitTestVisible="False"/>

                <Button x:Name="SheetNavLeftBtn" Grid.Column="0" Content="&lt;" Width="18" Height="27" Padding="0"
                        FontSize="13" Background="{StaticResource FreeXSheetSurfaceBrush}" BorderBrush="Transparent" BorderThickness="0"
                        Foreground="{StaticResource FreeXAccentDarkBrush}"
                        Cursor="Hand" Click="SheetNavLeftBtn_Click" Visibility="Hidden" Margin="0,1,0,0"
                        HorizontalAlignment="Right" HorizontalContentAlignment="Center"
                        VerticalAlignment="Top" VerticalContentAlignment="Center"
                        Panel.ZIndex="7"
                        local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_ScrollTabsLeft}"
                        local:RibbonTooltip.KeyTip="SL"
                        local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_ScrollTheSheetTabListToTheLeft}" local:RibbonMetadata.CommandName="Scroll Tabs Left">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="NavHitArea"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="NavHitArea" Property="Background" Value="#E6F6FA"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="NavHitArea" Property="Background" Value="#CCEAF2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Sheet tabs in a clipped, scrollbar-free viewport -->
                <ScrollViewer x:Name="SheetTabsScroller" Grid.Column="1"
                              Grid.ColumnSpan="4"
                              Margin="0,0,0,0"
                              Panel.ZIndex="3"
                              ClipToBounds="True"
                              HorizontalAlignment="Left"
                              FocusVisualStyle="{x:Null}"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              ScrollChanged="SheetTabsScroller_ScrollChanged"
                              SizeChanged="SheetTabsScroller_SizeChanged"
                              Loaded="SheetTabsScroller_Loaded">
                    <StackPanel x:Name="SheetTabsScrollableContent"
                                Orientation="Horizontal"
                                ClipToBounds="False">
                        <ItemsControl x:Name="SheetTabsControl"
                                      FocusVisualStyle="{x:Null}"
                                      Panel.ZIndex="4">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Panel.ZIndex" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGrouped}" Value="True">
                                            <Setter Property="Panel.ZIndex" Value="5"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Panel.ZIndex" Value="10"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid x:Name="TabChrome"
                                          Cursor="Hand"
                                          Focusable="True"
                                          AutomationProperties.Name="{Binding Name}"
                                          AutomationProperties.AutomationId="{Binding Name}"
                                          AutomationProperties.HelpText="{local:Loc Key=MainWindow_AutomationHelpText_SelectThisSheetRightClickOrPressShiftF10ForSheetTabOptions}"
                                          FocusVisualStyle="{x:Null}"
                                          MouseLeftButtonDown="SheetTab_MouseLeftButtonDown"
                                          MouseMove="SheetTab_MouseMove"
                                          MouseLeftButtonUp="SheetTab_MouseLeftButtonUp"
                                          MouseRightButtonDown="SheetTab_MouseRightButtonDown">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Margin"       Value="-16,0,0,1"/>
                                                <Setter Property="Panel.ZIndex" Value="0"/>
                                                <Setter Property="MinHeight"    Value="27"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGrouped}" Value="True">
                                                        <Setter Property="Margin"       Value="-16,0,0,1"/>
                                                        <Setter Property="Panel.ZIndex" Value="5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Margin"       Value="-16,0,0,1"/>
                                                        <Setter Property="Panel.ZIndex" Value="10"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_Rename}"         local:RibbonTooltip.KeyTip="R" Click="SheetCtxRename_Click" local:RibbonMetadata.CommandName="Rename"/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_InsertSheet}"    local:RibbonTooltip.KeyTip="I" Click="SheetCtxInsert_Click" local:RibbonMetadata.CommandName="Insert Sheet"/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_Duplicate}"       local:RibbonTooltip.KeyTip="D" Click="SheetCtxDuplicate_Click" local:RibbonMetadata.CommandName="Duplicate"/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_DeleteSheet}"    local:RibbonTooltip.KeyTip="E" Click="SheetCtxDelete_Click" local:RibbonMetadata.CommandName="Delete Sheet"/>
                                                <Separator/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_Hide}"            local:RibbonTooltip.KeyTip="H" Click="SheetCtxHide_Click" local:RibbonMetadata.CommandName="Hide"/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_Unhide}"         local:RibbonTooltip.KeyTip="U" Click="SheetCtxUnhide_Click" local:RibbonMetadata.CommandName="Unhide"/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_TabColor_EDBDA613}"      local:RibbonTooltip.KeyTip="T" Click="SheetCtxTabColor_Click" local:RibbonMetadata.CommandName="Tab Color"/>
                                                <Separator/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_SelectAllSheets}" local:RibbonTooltip.KeyTip="A" Click="SheetCtxSelectAllSheets_Click" local:RibbonMetadata.CommandName="Select All Sheets"/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_UngroupSheets}"    local:RibbonTooltip.KeyTip="G" Click="SheetCtxUngroupSheets_Click" local:RibbonMetadata.CommandName="Ungroup Sheets"/>
                                                <Separator/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_MoveLeft}"       local:RibbonTooltip.KeyTip="L" Click="SheetCtxMoveLeft_Click" local:RibbonMetadata.CommandName="Move Left"/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_MoveRight}"      local:RibbonTooltip.KeyTip="M" Click="SheetCtxMoveRight_Click" local:RibbonMetadata.CommandName="Move Right"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Path x:Name="TabLeftOutline"
                                              Data="M 0,0 A 8,8 0 0 1 8,8 L 8,22 A 4,4 0 0 0 12,26"
                                              Stroke="{Binding ElementName=TabBorder, Path=BorderBrush}"
                                              StrokeThickness="1.25"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Panel.ZIndex="3"
                                              SnapsToDevicePixels="True"
                                              Visibility="Collapsed"
                                              IsHitTestVisible="False"/>
                                        <Path x:Name="TabRightOutline"
                                              Data="M 12,0 A 8,8 0 0 0 4,8 L 4,22 A 4,4 0 0 1 0,26"
                                              HorizontalAlignment="Right"
                                              Stroke="{Binding ElementName=TabBorder, Path=BorderBrush}"
                                              StrokeThickness="1.25"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Panel.ZIndex="3"
                                              SnapsToDevicePixels="True"
                                              Visibility="Collapsed"
                                              IsHitTestVisible="False"/>
                                        <Border x:Name="TabBottomOutline"
                                                Height="1.25"
                                                VerticalAlignment="Bottom"
                                                Margin="12,0,12,0"
                                                Background="{Binding ElementName=TabBorder, Path=BorderBrush}"
                                                Panel.ZIndex="3"
                                                Visibility="Collapsed"
                                                IsHitTestVisible="False"/>
                                        <Canvas x:Name="TabOutlineCanvas"
                                                Height="26"
                                                VerticalAlignment="Top"
                                                Panel.ZIndex="4"
                                                Visibility="Collapsed"
                                                IsHitTestVisible="False">
                                            <Path x:Name="TabOutline"
                                                  Data="M 1,0 C 5,0 8,3 8,8 L 8,22 C 8,24 10,26 12,26 L 88,26 C 90,26 92,24 92,22 L 92,8 C 92,3 95,0 99,0"
                                                  Width="{Binding ActualWidth, ElementName=TabChrome}"
                                                  Height="26"
                                                  Stretch="Fill"
                                                  Stroke="{Binding ElementName=TabBorder, Path=BorderBrush}"
                                                  StrokeThickness="1.25"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  SnapsToDevicePixels="True"/>
                                        </Canvas>
                                        <Border x:Name="ActiveTabTopCutout"
                                                Height="2"
                                                VerticalAlignment="Top"
                                                Margin="2,0,2,0"
                                                Background="{StaticResource FreeXRibbonSurfaceBrush}"
                                                Panel.ZIndex="6"
                                                IsHitTestVisible="False">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <Border x:Name="TabBorder"
                                                CornerRadius="0,0,4,4" Padding="12,3,12,1"
                                                Margin="8,0,8,0"
                                                Panel.ZIndex="2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"      Value="Transparent"/>
                                                    <Setter Property="BorderBrush"     Value="{StaticResource FreeXBorderStrongBrush}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsGrouped}" Value="True">
                                                            <Setter Property="Background"      Value="Transparent"/>
                                                            <Setter Property="BorderBrush"     Value="{StaticResource FreeXAccentBrush}"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background"      Value="Transparent"/>
                                                            <Setter Property="BorderBrush"     Value="{StaticResource FreeXAccentBrush}"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid MouseDown="SheetTab_LabelMouseDown">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="0"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontFamily="Segoe UI">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <Border x:Name="TabFocusCue"
                                                Margin="14,4,14,5"
                                                BorderBrush="{StaticResource FreeXAccentDarkBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2"
                                                Panel.ZIndex="8"
                                                Visibility="Collapsed"
                                                IsHitTestVisible="False"/>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=TabChrome}" Value="True">
                                            <Setter TargetName="TabFocusCue" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsGrouped}" Value="True">
                                            <Setter TargetName="TabOutline" Property="Stroke" Value="{StaticResource FreeXAccentBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter TargetName="TabOutline" Property="Stroke" Value="{StaticResource FreeXAccentBrush}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button x:Name="AddSheetButton" Content="+" Width="70" MinWidth="70" MinHeight="27"
                                FontSize="17" FontWeight="SemiBold" Margin="0,0,0,1" Padding="0"
                                Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                Foreground="{StaticResource FreeXAccentBrush}" Opacity="1"
                                VerticalAlignment="Top" Cursor="Hand"
                                Panel.ZIndex="3"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_InsertSheet}"
                                AutomationProperties.HelpText="{local:Loc Key=MainWindow_AutomationHelpText_AddANewSheetToTheWorkbook}"
                                Click="AddSheetButton_Click"
                                local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_InsertSheet}"
                                local:RibbonTooltip.KeyTip="IS"
                                local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_AddANewSheetToTheWorkbook}" local:RibbonMetadata.CommandName="Insert Sheet">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid x:Name="GhostTabRoot"
                                          Background="Transparent"
                                          Opacity="{TemplateBinding Opacity}">
                                        <Border x:Name="GhostTabChrome"
                                                Background="Transparent"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="0"
                                                CornerRadius="0,0,4,4"
                                                Margin="0"
                                                Panel.ZIndex="2"
                                                SnapsToDevicePixels="True">
                                            <TextBlock Text="+"
                                                       FontSize="{TemplateBinding FontSize}"
                                                       FontWeight="{TemplateBinding FontWeight}"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       LineHeight="18"
                                                       LineStackingStrategy="BlockLineHeight"
                                                       Margin="0,1,0,0"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.RenderTransform>
                                                    <TranslateTransform X="-8"/>
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="GhostTabChrome" Property="Opacity" Value="1"/>
                                            <Setter TargetName="GhostTabChrome" Property="Background" Value="Transparent"/>
                                            <Setter TargetName="GhostTabChrome" Property="BorderBrush" Value="{StaticResource FreeXAccentBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="GhostTabChrome" Property="Opacity" Value="1"/>
                                            <Setter TargetName="GhostTabChrome" Property="Background" Value="Transparent"/>
                                            <Setter TargetName="GhostTabChrome" Property="BorderBrush" Value="{StaticResource FreeXAccentDarkBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <Canvas x:Name="SheetTabsOverlayLayer"
