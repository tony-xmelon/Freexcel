<Window x:Class="Freexcel.App.Host.NamedRangeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Name Manager"
        Width="720" Height="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="_New..." Width="72" Margin="0,0,8,0" Click="NewButton_Click"/>
                <Button Content="_Edit..." Width="72" Margin="0,0,8,0" Click="EditButton_Click"/>
                <Button Content="_Delete" Width="72" Click="DeleteButton_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Label Content="_Filter:" Target="{Binding ElementName=FilterBox}" VerticalAlignment="Center"/>
                <ComboBox x:Name="FilterBox" Width="190" SelectedIndex="0" SelectionChanged="FilterBox_SelectionChanged">
                    <ComboBoxItem Content="All names"/>
                    <ComboBoxItem Content="Names scoped to workbook"/>
                    <ComboBoxItem Content="Names scoped to worksheet"/>
                </ComboBox>
            </StackPanel>
        </DockPanel>

        <GroupBox Grid.Row="1" Header="_Defined Names">
            <ListView x:Name="NamesList" SelectionChanged="NamesList_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="130"
                                        DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Value" Width="120"
                                        DisplayMemberBinding="{Binding Value}"/>
                        <GridViewColumn Header="Refers To" Width="210"
                                        DisplayMemberBinding="{Binding RefersTo}"/>
                        <GridViewColumn Header="Scope" Width="100"
                                        DisplayMemberBinding="{Binding Scope}"/>
                        <GridViewColumn Header="Comment" Width="120"
                                        DisplayMemberBinding="{Binding Comment}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>
            <Label Content="_Refers to:" Target="{Binding ElementName=RefersToBox}" VerticalAlignment="Center"/>
            <TextBox x:Name="RefersToBox" Grid.Column="1" IsReadOnly="True"
                     ToolTip="Selected name reference"/>
            <Button x:Name="RefersToPickerButton" Grid.Column="2" Content="..." Width="26" Margin="4,0,0,0" ToolTip="Select the referenced range from the worksheet" IsEnabled="False"/>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="_Close" Width="64" IsCancel="True" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
