<Window x:Class="Freexcel.App.Host.FindReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find &amp; Replace"
        Width="400" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Find row -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="_Find:" Target="{Binding ElementName=FindBox}" VerticalAlignment="Center"/>
            <TextBox x:Name="FindBox" Grid.Column="1" KeyDown="FindBox_KeyDown"/>
        </Grid>

        <!-- Replace row -->
        <Grid Grid.Row="1" Margin="0,0,0,8" x:Name="ReplaceRow">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="_Replace:" Target="{Binding ElementName=ReplaceBox}" VerticalAlignment="Center"/>
            <TextBox x:Name="ReplaceBox"/>
        </Grid>

        <!-- Options -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <CheckBox x:Name="MatchCaseBox" Content="Match _case" Margin="0,0,12,0"/>
            <CheckBox x:Name="MatchEntireBox" Content="_Entire cell" Margin="0,0,12,0"/>
            <CheckBox x:Name="SearchFormulasBox" Content="Search _formulas"/>
        </StackPanel>

        <!-- Status label -->
        <TextBlock x:Name="StatusLabel" Grid.Row="3" Foreground="#555" FontSize="11" Height="18" Margin="0,0,0,8"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="FindNextBtn" Content="_Find Next" Width="80" Margin="0,0,8,0" Click="FindNext_Click"/>
            <Button x:Name="ReplaceAllBtn" Content="_Replace All" Width="80" Margin="0,0,8,0" Click="ReplaceAll_Click"/>
            <Button Content="_Close" Width="60" IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
