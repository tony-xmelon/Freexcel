                                    <Button Content="Series Color" Width="90"  Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ChartSeriesColorBtn_Click"
                                            local:RibbonTooltip.Title="Series Color" local:RibbonTooltip.KeyTip="SR"
                                            local:RibbonTooltip.Description="Cycle the first chart series fill or line color."/>
                                    <Button Content="Series Width" Width="90"  Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ChartSeriesWidthBtn_Click"
                                            local:RibbonTooltip.Title="Series Width" local:RibbonTooltip.KeyTip="WD"
                                            local:RibbonTooltip.Description="Cycle the first chart series outline or line width."/>
                                </StackPanel>
                                <StackPanel>
                                    <Button Content="Series Dash"  Width="90"  Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ChartSeriesDashBtn_Click"
                                            local:RibbonTooltip.Title="Series Dash" local:RibbonTooltip.KeyTip="SD"
                                            local:RibbonTooltip.Description="Cycle the first chart series line dash style."/>
                                    <Button Content="Marker"       Width="70"  Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ChartSeriesMarkerBtn_Click"
                                            local:RibbonTooltip.Title="Series Marker" local:RibbonTooltip.KeyTip="SM"
                                            local:RibbonTooltip.Description="Cycle the first chart series marker style."/>
                                    <Button Content="Marker Size"  Width="90"  Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ChartSeriesMarkerSizeBtn_Click"
                                            local:RibbonTooltip.Title="Marker Size" local:RibbonTooltip.KeyTip="MS"
                                            local:RibbonTooltip.Description="Cycle the first chart series marker size."/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Charts" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Tours ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="3D Map" Width="78" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" IsEnabled="False"
                                        local:RibbonTooltip.Title="3D Map"
                                        local:RibbonTooltip.KeyTip="M"
                                        local:RibbonTooltip.Description="3D Map tours are deferred in Freexcel."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Tours" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Sparklines ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Line"    Width="70" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SparklineLineBtn_Click"
                                        local:RibbonTooltip.Title="Line Sparkline"
                                        local:RibbonTooltip.KeyTip="SL"
                                        local:RibbonTooltip.Description="Insert a line sparkline — a tiny chart in a single cell showing a trend."/>
                                <Button Content="Column"  Width="70" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SparklineColumnBtn_Click"
                                        local:RibbonTooltip.Title="Column Sparkline"
                                        local:RibbonTooltip.KeyTip="SK"
                                        local:RibbonTooltip.Description="Insert a column sparkline showing relative values as small bars."/>
                                <Button Content="Win/Loss" Width="70" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SparklineWinLossBtn_Click"
                                        local:RibbonTooltip.Title="Win/Loss Sparkline"
                                        local:RibbonTooltip.KeyTip="SW"
                                        local:RibbonTooltip.Description="Insert a win/loss sparkline showing positive and negative results."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Sparklines" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Filters ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Slicer" Width="74" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotInsertSlicerBtn_Click"
                                        local:RibbonTooltip.Title="Insert Slicer"
                                        local:RibbonTooltip.KeyTip="SF"
                                        local:RibbonTooltip.Description="Create a slicer connected to the selected PivotTable field."/>
                                <Button Content="Timeline" Width="82" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PivotInsertTimelineBtn_Click"
                                        local:RibbonTooltip.Title="Insert Timeline"
                                        local:RibbonTooltip.KeyTip="TL"
                                        local:RibbonTooltip.Description="Create a timeline connected to the selected PivotTable date field."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Filters" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Links ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Link" Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="InsertLinkBtn_Click"
                                        local:RibbonTooltip.Title="Insert Link"
                                        local:RibbonTooltip.KeyTip="K"
                                        local:RibbonTooltip.Description="Insert a hyperlink to a web page, file, or location in the workbook."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Links" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Text ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Text Box" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DrawTextBtn_Click"
                                        local:RibbonTooltip.Title="Text Box"
                                        local:RibbonTooltip.KeyTip="X"
                                        local:RibbonTooltip.Description="Insert a text box you can position and resize anywhere on the sheet."/>
                                <Button Content="Header &amp; Footer" Width="118" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="HeaderFooterBtn_Click"
                                        local:RibbonTooltip.Title="Header &amp; Footer"
                                        local:RibbonTooltip.KeyTip="H"
                                        local:RibbonTooltip.Description="Edit printed page headers and footers."/>
                                <Button Content="Object" Width="74" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" IsEnabled="False"
                                        local:RibbonTooltip.Title="Object"
                                        local:RibbonTooltip.KeyTip="O"
                                        local:RibbonTooltip.Description="Embedded object authoring is deferred in Freexcel."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Text" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Symbols ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Equation" Width="82" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" IsEnabled="False"
                                        local:RibbonTooltip.Title="Equation"
                                        local:RibbonTooltip.KeyTip="E"
                                        local:RibbonTooltip.Description="Equation authoring is deferred in Freexcel."/>
                                <Button Content="Symbol" Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SymbolPickerBtn_Click"
                                        local:RibbonTooltip.Title="Insert Symbol"
                                        local:RibbonTooltip.KeyTip="SY"
                                        local:RibbonTooltip.Description="Insert a special character or symbol at the cursor position."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Symbols" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── DRAW ──────────────────────────────────────────────── -->
            <TabItem Header="Draw" local:RibbonTooltip.KeyTip="J">
                <Border Background="{StaticResource FreexcelRibbonSurfaceBrush}" Padding="6,4,6,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal" MinHeight="88">

                        <!-- ▌Draw ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Rectangle" Width="70" Height="46" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DrawRectBtn_Click"
                                        local:RibbonTooltip.Title="Rectangle"
                                        local:RibbonTooltip.KeyTip="R"
                                        local:RibbonTooltip.Description="Draw a rectangle shape on the sheet."/>
                                <Button Content="Ellipse"   Width="70" Height="46" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DrawEllipseBtn_Click"
                                        local:RibbonTooltip.Title="Ellipse"
                                        local:RibbonTooltip.KeyTip="E"
                                        local:RibbonTooltip.Description="Draw an ellipse or circle on the sheet."/>
                                <Button Content="Line"      Width="70" Height="46" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DrawLineBtn_Click"
                                        local:RibbonTooltip.Title="Line"
                                        local:RibbonTooltip.KeyTip="L"
                                        local:RibbonTooltip.Description="Draw a straight line on the sheet."/>
                                <Button Content="Text Box"  Width="70" Height="46" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DrawTextBtn_Click"
                                        local:RibbonTooltip.Title="Text Box"
                                        local:RibbonTooltip.KeyTip="X"
                                        local:RibbonTooltip.Description="Insert a text box you can position and resize anywhere on the sheet."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Draw" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Arrange ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Bring Forward" Width="72" Height="64" Margin="1,0" Tag="RibbonCompact:72:36"
                                        Style="{StaticResource RibbonBtn}" Click="BringForwardBtn_Click"
                                        local:RibbonTooltip.Title="Bring Forward"
                                        local:RibbonTooltip.KeyTip="BF"
                                        local:RibbonTooltip.Description="Move the selected shape one step closer to the front."/>
                                <Button Content="Send Backward" Width="72" Height="64" Margin="1,0" Tag="RibbonCompact:72:36"
                                        Style="{StaticResource RibbonBtn}" Click="SendBackwardBtn_Click"
                                        local:RibbonTooltip.Title="Send Backward"
                                        local:RibbonTooltip.KeyTip="SB"
                                        local:RibbonTooltip.Description="Move the selected shape one step closer to the back."/>
                                <Button Content="Selection Pane" Width="72" Height="64" Margin="1,0" Tag="RibbonCompact:72:36"
                                        Style="{StaticResource RibbonBtn}" Click="SelectionPaneBtn_Click"
                                        local:RibbonTooltip.Title="Selection Pane"
                                        local:RibbonTooltip.KeyTip="SP"
                                        local:RibbonTooltip.Description="List sheet objects and control visibility or stacking order."/>
                                <StackPanel VerticalAlignment="Center" Margin="2,0">
                                    <Button Content="Rotate" Width="68" Height="28" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectRotateBtn_Click"
                                            local:RibbonTooltip.Title="Rotate Object"
                                            local:RibbonTooltip.KeyTip="RO"
                                            local:RibbonTooltip.Description="Rotate the selected or most recent drawing object."/>
                                    <Button Content="Size"   Width="68" Height="28" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectSizeBtn_Click"
                                            local:RibbonTooltip.Title="Object Size"
                                            local:RibbonTooltip.KeyTip="SZ"
                                            local:RibbonTooltip.Description="Resize the selected or most recent drawing object."/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Arrange" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- â–ŒFormat â–Œ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <StackPanel Margin="1,0">
                                    <Button Content="Fill" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectFillBtn_Click"
                                            local:RibbonTooltip.Title="Object Fill"
                                            local:RibbonTooltip.KeyTip="F"
                                            local:RibbonTooltip.Description="Change the fill color of the selected drawing object."/>
                                    <Button Content="Outline" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectOutlineBtn_Click"
                                            local:RibbonTooltip.Title="Object Outline"
                                            local:RibbonTooltip.KeyTip="O"
                                            local:RibbonTooltip.Description="Change the outline color of the selected drawing object."/>
                                    <Button Content="Crop" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PictureCropBtn_Click"
                                            local:RibbonTooltip.Title="Crop Picture"
                                            local:RibbonTooltip.KeyTip="C"
                                            local:RibbonTooltip.Description="Crop the selected or most recent picture by percentage from each edge.">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Crop..." local:RibbonTooltip.KeyTip="C" Click="PictureCropDialogMenuItem_Click"/>
                                                <MenuItem Header="Reset Crop" local:RibbonTooltip.KeyTip="R" Click="PictureResetCropMenuItem_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </StackPanel>
                                <StackPanel Margin="1,0" VerticalAlignment="Center">
                                    <Button Content="Gradient" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectGradientBtn_Click"
                                            local:RibbonTooltip.Title="Shape Gradient"
                                            local:RibbonTooltip.KeyTip="G"
                                            local:RibbonTooltip.Description="Apply a two-color gradient fill to the selected shape."/>
                                    <Button Content="Effects" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectEffectsBtn_Click"
                                            local:RibbonTooltip.Title="Shape Effects"
                                            local:RibbonTooltip.KeyTip="FX"
                                            local:RibbonTooltip.Description="Toggle a shadow effect on the selected shape."/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Format" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── PAGE LAYOUT ───────────────────────────────────────── -->
            <TabItem Header="Page Layout" local:RibbonTooltip.KeyTip="P">
                <Border Background="{StaticResource FreexcelRibbonSurfaceBrush}" Padding="6,4,6,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal" MinHeight="88">

                        <!-- Themes -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Themes" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ThemeBtn_Click"
                                        local:RibbonTooltip.Title="Themes"
                                        local:RibbonTooltip.KeyTip="TH"
                                        local:RibbonTooltip.Description="Change the workbook theme colors and fonts.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Office" local:RibbonTooltip.KeyTip="O" Click="ThemeOfficeMenuItem_Click"/>
                                            <MenuItem Header="Freexcel Colorful" local:RibbonTooltip.KeyTip="C" Click="ThemeColorfulMenuItem_Click"/>
                                            <MenuItem Header="Grayscale" local:RibbonTooltip.KeyTip="G" Click="ThemeGrayscaleMenuItem_Click"/>
                                            <MenuItem Header="Customize..." local:RibbonTooltip.KeyTip="U" Click="ThemeCustomizeMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Colors" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ThemeColorsBtn_Click"
                                        local:RibbonTooltip.Title="Theme Colors"
                                        local:RibbonTooltip.KeyTip="TC"
                                        local:RibbonTooltip.Description="Change the workbook theme color palette.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Office" local:RibbonTooltip.KeyTip="O" Click="ThemeColorsOfficeMenuItem_Click"/>
                                            <MenuItem Header="Freexcel Colorful" local:RibbonTooltip.KeyTip="C" Click="ThemeColorsColorfulMenuItem_Click"/>
                                            <MenuItem Header="Grayscale" local:RibbonTooltip.KeyTip="G" Click="ThemeColorsGrayscaleMenuItem_Click"/>
                                            <MenuItem Header="Customize Colors..." local:RibbonTooltip.KeyTip="U" Click="ThemeColorsCustomizeMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Fonts" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ThemeFontsBtn_Click"
                                        local:RibbonTooltip.Title="Theme Fonts"
                                        local:RibbonTooltip.KeyTip="TF"
                                        local:RibbonTooltip.Description="Change the workbook theme heading and body fonts.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Office" local:RibbonTooltip.KeyTip="O" Click="ThemeFontsOfficeMenuItem_Click"/>
                                            <MenuItem Header="Arial" local:RibbonTooltip.KeyTip="A" Click="ThemeFontsArialMenuItem_Click"/>
                                            <MenuItem Header="Times New Roman" local:RibbonTooltip.KeyTip="T" Click="ThemeFontsTimesMenuItem_Click"/>
                                            <MenuItem Header="Customize Fonts..." local:RibbonTooltip.KeyTip="U" Click="ThemeFontsCustomizeMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Effects" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ThemeEffectsBtn_Click"
                                        local:RibbonTooltip.Title="Theme Effects"
                                        local:RibbonTooltip.KeyTip="TE"
                                        local:RibbonTooltip.Description="Change the workbook theme effect set name.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Office" local:RibbonTooltip.KeyTip="O" Click="ThemeEffectsOfficeMenuItem_Click"/>
                                            <MenuItem Header="Subtle" local:RibbonTooltip.KeyTip="S" Click="ThemeEffectsSubtleMenuItem_Click"/>
                                            <MenuItem Header="Refined" local:RibbonTooltip.KeyTip="R" Click="ThemeEffectsRefinedMenuItem_Click"/>
                                            <MenuItem Header="Customize Effects..." local:RibbonTooltip.KeyTip="U" Click="ThemeEffectsCustomizeMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Themes" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Page Setup ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Margins" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageMarginsBtn_Click"
                                        local:RibbonTooltip.Title="Margins"
                                        local:RibbonTooltip.KeyTip="M"
                                        local:RibbonTooltip.Description="Select the margin sizes for the printed page.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Normal"   local:RibbonTooltip.KeyTip="N" Click="MarginNormalMenuItem_Click"/>
                                            <MenuItem Header="Wide"     local:RibbonTooltip.KeyTip="W" Click="MarginWideMenuItem_Click"/>
                                            <MenuItem Header="Narrow"   local:RibbonTooltip.KeyTip="A" Click="MarginNarrowMenuItem_Click"/>
                                            <MenuItem Header="Custom…"  local:RibbonTooltip.KeyTip="C" Click="MarginCustomMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Orientation" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageOrientBtn_Click"
                                        local:RibbonTooltip.Title="Orientation"
                                        local:RibbonTooltip.KeyTip="O"
                                        local:RibbonTooltip.Description="Change the page orientation to Portrait or Landscape.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Portrait"  local:RibbonTooltip.KeyTip="P" Click="OrientPortraitMenuItem_Click"/>
                                            <MenuItem Header="Landscape" local:RibbonTooltip.KeyTip="L" Click="OrientLandscapeMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Size" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageSizeBtn_Click"
                                        local:RibbonTooltip.Title="Paper Size"
                                        local:RibbonTooltip.KeyTip="SZ"
                                        local:RibbonTooltip.Description="Choose a paper size for the printed page.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Letter (8.5x11)"  local:RibbonTooltip.KeyTip="L" Click="SizeLetter_Click"/>
                                            <MenuItem Header="A4 (210x297 mm)"  local:RibbonTooltip.KeyTip="A" Click="SizeA4_Click"/>
                                            <MenuItem Header="Legal (8.5x14)"   local:RibbonTooltip.KeyTip="G" Click="SizeLegal_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Print Area" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PrintAreaBtn_Click"
                                        local:RibbonTooltip.Title="Print Area"
                                        local:RibbonTooltip.KeyTip="R"
                                        local:RibbonTooltip.Description="Set or clear the print area for the current sheet.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Set Print Area"   local:RibbonTooltip.KeyTip="S" Click="PrintAreaSetMenuItem_Click"/>
                                            <MenuItem Header="Clear Print Area" local:RibbonTooltip.KeyTip="C" Click="PrintAreaClearMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Breaks" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageBreaksBtn_Click"
                                        local:RibbonTooltip.Title="Breaks"
                                        local:RibbonTooltip.KeyTip="B"
                                        local:RibbonTooltip.Description="Insert, remove, or reset manual page breaks for printing.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Insert Page Break" local:RibbonTooltip.KeyTip="I" Click="InsertPageBreakMenuItem_Click"/>
                                            <MenuItem Header="Remove Page Break" local:RibbonTooltip.KeyTip="R" Click="RemovePageBreakMenuItem_Click"/>
                                            <MenuItem Header="Reset All Page Breaks" local:RibbonTooltip.KeyTip="A" Click="ResetAllPageBreaksMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Background" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="BackgroundBtn_Click"
                                        local:RibbonTooltip.Title="Background"
                                        local:RibbonTooltip.KeyTip="BG"
                                        local:RibbonTooltip.Description="Choose or clear a display-only worksheet background image.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Choose Background..." local:RibbonTooltip.KeyTip="C" Click="BackgroundChooseMenuItem_Click"/>
                                            <MenuItem Header="Delete Background" local:RibbonTooltip.KeyTip="D" Click="BackgroundClearMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Print Titles" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PrintTitlesBtn_Click"
                                        local:RibbonTooltip.Title="Print Titles"
                                        local:RibbonTooltip.KeyTip="T"
                                        local:RibbonTooltip.Description="Repeat selected rows or columns on every printed page."/>
                                <Button Content="Header/Footer" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="HeaderFooterBtn_Click"
                                        local:RibbonTooltip.Title="Header &amp; Footer"
                                        local:RibbonTooltip.KeyTip="H"
                                        local:RibbonTooltip.Description="Edit printed page headers and footers."/>
                                <Button Content="Page Setup" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageSetupDialogBtn_Click"
                                        local:RibbonTooltip.Title="Page Setup"
                                        local:RibbonTooltip.KeyTip="PS"
                                        local:RibbonTooltip.Description="Open the Page Setup dialog for page, margin, and sheet print options."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Page Setup" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Scale to Fit ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Scale" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ScaleToFitBtn_Click"
                                        local:RibbonTooltip.Title="Scale to Fit"
                                        local:RibbonTooltip.KeyTip="SF"
                                        local:RibbonTooltip.Description="Scale printed output by percentage or fit it to a fixed page count."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Scale to Fit" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Sheet Options ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <StackPanel VerticalAlignment="Center" Margin="0,0,4,0">
                                    <TextBlock Text="Gridlines" FontSize="10" Margin="4,2,4,0" Foreground="#444"/>
                                    <CheckBox x:Name="PageLayoutViewGridlinesChk" Content="View" Margin="4,1" IsChecked="True"
                                              Checked="ViewGridlinesChk_Changed" Unchecked="ViewGridlinesChk_Changed"
                                              local:RibbonTooltip.Title="View Gridlines"
                                              local:RibbonTooltip.KeyTip="VG"
                                              local:RibbonTooltip.Description="Show or hide cell gridlines on the worksheet."/>
                                    <CheckBox x:Name="PageLayoutPrintGridlinesChk" Content="Print" Margin="4,1"
                                              Click="PrintGridlinesChk_Click"
                                              local:RibbonTooltip.Title="Print Gridlines"
                                              local:RibbonTooltip.KeyTip="PG"
                                              local:RibbonTooltip.Description="Print worksheet gridlines on each page."/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Headings" FontSize="10" Margin="4,2,4,0" Foreground="#444"/>
                                    <CheckBox x:Name="PageLayoutViewHeadingsChk" Content="View" Margin="4,1" IsChecked="True"
                                              Checked="ViewHeadersChk_Changed" Unchecked="ViewHeadersChk_Changed"
                                              local:RibbonTooltip.Title="View Headings"
                                              local:RibbonTooltip.KeyTip="VH"
                                              local:RibbonTooltip.Description="Show or hide row and column headings."/>
                                    <CheckBox x:Name="PageLayoutPrintHeadingsChk" Content="Print" Margin="4,1"
                                              Click="PrintHeadingsChk_Click"
                                              local:RibbonTooltip.Title="Print Headings"
                                              local:RibbonTooltip.KeyTip="PH"
                                              local:RibbonTooltip.Description="Print row and column headings on each page."/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Sheet Options" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Arrange ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Bring Forward" Width="72" Height="64" Margin="1,0" Tag="RibbonCompact:72:36"
                                        Style="{StaticResource RibbonBtn}" Click="BringForwardBtn_Click"
                                        local:RibbonTooltip.Title="Bring Forward"
                                        local:RibbonTooltip.KeyTip="BF"
                                        local:RibbonTooltip.Description="Move the selected shape one step closer to the front."/>
                                <Button Content="Send Backward" Width="72" Height="64" Margin="1,0" Tag="RibbonCompact:72:36"
                                        Style="{StaticResource RibbonBtn}" Click="SendBackwardBtn_Click"
                                        local:RibbonTooltip.Title="Send Backward"
                                        local:RibbonTooltip.KeyTip="SB"
                                        local:RibbonTooltip.Description="Move the selected shape one step closer to the back."/>
                                <Button Content="Selection Pane" Width="72" Height="64" Margin="1,0" Tag="RibbonCompact:72:36"
                                        Style="{StaticResource RibbonBtn}" Click="SelectionPaneBtn_Click"
                                        local:RibbonTooltip.Title="Selection Pane"
                                        local:RibbonTooltip.KeyTip="SP"
                                        local:RibbonTooltip.Description="List sheet objects and control visibility or stacking order."/>
                                <StackPanel VerticalAlignment="Center" Margin="2,0">
                                    <Button Content="Rotate" Width="68" Height="28" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectRotateBtn_Click"
                                            local:RibbonTooltip.Title="Rotate Object"
                                            local:RibbonTooltip.KeyTip="RO"
                                            local:RibbonTooltip.Description="Rotate the selected or most recent drawing object."/>
                                    <Button Content="Size" Width="68" Height="28" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ObjectSizeBtn_Click"
                                            local:RibbonTooltip.Title="Object Size"
                                            local:RibbonTooltip.KeyTip="SZ"
                                            local:RibbonTooltip.Description="Resize the selected or most recent drawing object."/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Arrange" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── FORMULAS ──────────────────────────────────────────── -->
            <TabItem Header="Formulas" local:RibbonTooltip.KeyTip="M">
                <Border Background="{StaticResource FreexcelRibbonSurfaceBrush}" Padding="6,4,6,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal" MinHeight="88">

                        <!-- ▌Function Library ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <local:AutomationInvokeButton x:Name="FormulasInsertFunctionButton"
                                                              Content="Insert Function" Width="116" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="InsertFunctionBtn_Click"
                                                              AutomationProperties.Name="Insert Function"
                                                              AutomationProperties.AutomationId="FormulasInsertFunctionButton"
                                                              local:RibbonTooltip.Title="Insert Function"
                                                              local:RibbonTooltip.KeyTip="F"
                                                              local:RibbonTooltip.Description="Search for and insert a function into the selected cell."/>
                                <Button Content="AutoSum" Width="70" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulasAutoSumPickerBtn_Click"
                                        local:RibbonTooltip.Title="AutoSum"
                                        local:RibbonTooltip.KeyTip="U"
                                        local:RibbonTooltip.Description="Automatically insert a SUM, AVERAGE, COUNT, MAX, or MIN formula.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Sum"           local:RibbonTooltip.KeyTip="S" Click="AutoSumSumMenuItem_Click"/>
                                            <MenuItem Header="Average"       local:RibbonTooltip.KeyTip="A" Click="AutoSumAvgMenuItem_Click"/>
                                            <MenuItem Header="Count Numbers" local:RibbonTooltip.KeyTip="C" Click="AutoSumCountMenuItem_Click"/>
                                            <MenuItem Header="Max"           local:RibbonTooltip.KeyTip="X" Click="AutoSumMaxMenuItem_Click"/>
                                            <MenuItem Header="Min"           local:RibbonTooltip.KeyTip="M" Click="AutoSumMinMenuItem_Click"/>
                                            <MenuItem Header="More…"         local:RibbonTooltip.KeyTip="F" Click="AutoSumMoreMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <StackPanel VerticalAlignment="Center">
                                    <Button Content="Recently Used" Width="84" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="InsertFunctionBtn_Click"
                                            local:RibbonTooltip.Title="Recently Used"
                                            local:RibbonTooltip.KeyTip="R"
                                            local:RibbonTooltip.Description="Insert a function you have used recently."/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Math"     Width="48" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaMathBtn_Click"
                                                local:RibbonTooltip.Title="Math &amp; Trig"
                                                local:RibbonTooltip.KeyTip="M"
                                                local:RibbonTooltip.Description="Browse and insert math and trigonometry functions."/>
                                        <Button Content="Text"     Width="48" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaTextBtn_Click"
                                                local:RibbonTooltip.Title="Text Functions"
                                                local:RibbonTooltip.KeyTip="T"
                                                local:RibbonTooltip.Description="Browse and insert text manipulation functions like LEFT, MID, and TRIM."/>
                                        <Button Content="Date"     Width="48" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaDateBtn_Click"
                                                local:RibbonTooltip.Title="Date &amp; Time"
                                                local:RibbonTooltip.KeyTip="D"
                                                local:RibbonTooltip.Description="Browse and insert date and time functions like TODAY and NOW."/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Logical"  Width="56" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaLogicalBtn_Click"
                                                local:RibbonTooltip.Title="Logical Functions"
                                                local:RibbonTooltip.KeyTip="L"
                                                local:RibbonTooltip.Description="Browse and insert logical functions like IF, AND, OR, and NOT."/>
                                        <Button Content="Lookup"   Width="56" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaLookupBtn_Click"
                                                local:RibbonTooltip.Title="Lookup &amp; Reference"
                                                local:RibbonTooltip.KeyTip="K"
                                                local:RibbonTooltip.Description="Browse and insert lookup functions like VLOOKUP, HLOOKUP, and INDEX."/>
                                        <Button Content="More…"    Width="40" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FormulaMoreBtn_Click"
                                                local:RibbonTooltip.Title="More Functions"
                                                local:RibbonTooltip.KeyTip="MF"
                                                local:RibbonTooltip.Description="Browse all available functions organized by category."/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Function Library" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Defined Names ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Define Name"    Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DefineNameBtn_Click"
                                        local:RibbonTooltip.Title="Define Name"
                                        local:RibbonTooltip.KeyTip="DN"
                                        local:RibbonTooltip.Description="Assign a name to a cell or range so you can refer to it in formulas."/>
                                <Button Content="Create from Selection" Width="126" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="CreateNamesFromSelectionBtn_Click"
                                        local:RibbonTooltip.Title="Create from Selection"
                                        local:RibbonTooltip.KeyTip="CS"
                                        local:RibbonTooltip.Description="Create named ranges from labels in the selected cells."/>
                                <Button Content="Use in Formula" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="UseInFormulaBtn_Click"
                                        local:RibbonTooltip.Title="Use in Formula"
                                        local:RibbonTooltip.KeyTip="I"
                                        local:RibbonTooltip.Description="Insert a defined name into the formula you are currently editing."/>
                                <Button Content="Name Manager"   Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="NamedRangesButton_Click"
                                        local:RibbonTooltip.Title="Name Manager"
                                        local:RibbonTooltip.KeyTip="N"
                                        local:RibbonTooltip.Description="View, create, edit, and delete all named ranges in the workbook."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Defined Names" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Formula Auditing ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <StackPanel VerticalAlignment="Center">
                                    <Button Content="Trace Precedents"  Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="TracePrecedentsBtn_Click"
                                            local:RibbonTooltip.Title="Trace Precedents"
                                            local:RibbonTooltip.KeyTip="TP"
                                            local:RibbonTooltip.Description="Show arrows pointing to the cells that supply values to the selected formula."/>
                                    <Button Content="Trace Dependents"  Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="TraceDependentsBtn_Click"
                                            local:RibbonTooltip.Title="Trace Dependents"
                                            local:RibbonTooltip.KeyTip="TD"
                                            local:RibbonTooltip.Description="Show arrows pointing to the cells that depend on the selected cell."/>
                                    <Button Content="Remove Arrows"     Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="RemoveArrowsBtn_Click"
                                            local:RibbonTooltip.Title="Remove Arrows"
                                            local:RibbonTooltip.KeyTip="RA"
                                            local:RibbonTooltip.Description="Remove the tracer arrows added by Trace Precedents or Trace Dependents."/>
                                    <Button Content="Show Formulas"     Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ShowFormulasBtn_Click"
                                            local:RibbonTooltip.Title="Show Formulas"
                                            local:RibbonTooltip.KeyTip="SF"
                                            local:RibbonTooltip.Description="Display formulas in all cells instead of their calculated results."/>
                                    <Button Content="Error Checking"    Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ErrorCheckBtn_Click"
                                            local:RibbonTooltip.Title="Error Checking"
                                            local:RibbonTooltip.KeyTip="EC"
                                            local:RibbonTooltip.Description="Check for common errors in the formulas on this sheet, or open error-checking options.">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Error Checking..." local:RibbonTooltip.KeyTip="E" Click="ErrorCheckBtn_Click"/>
                                                <MenuItem Header="Error Checking Options..." local:RibbonTooltip.KeyTip="O" Click="SsOptionsBtn_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                    <Button Content="Evaluate Formula"  Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="EvaluateFormulaBtn_Click"
                                            local:RibbonTooltip.Title="Evaluate Formula"
                                            local:RibbonTooltip.KeyTip="V"
                                            local:RibbonTooltip.Description="Show the selected formula and its current calculated result."/>
                                    <Button Content="Watch Window"      Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="WatchWindowBtn_Click"
                                            local:RibbonTooltip.Title="Watch Window"
                                            local:RibbonTooltip.KeyTip="W"
                                            local:RibbonTooltip.Description="Show watched cells and their current values."/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Center">
                                    <Button Content="Add Watch" Width="58" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="AddWatchBtn_Click"
                                            local:RibbonTooltip.Title="Add Watch"
                                            local:RibbonTooltip.KeyTip="AW"
                                            local:RibbonTooltip.Description="Add the selected cell to the Watch Window."/>
                                    <Button Content="Del Watch" Width="58" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="DeleteWatchBtn_Click"
                                            local:RibbonTooltip.Title="Delete Watch"
                                            local:RibbonTooltip.KeyTip="DW"
                                            local:RibbonTooltip.Description="Remove the selected cell from the Watch Window."/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Formula Auditing" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Calculation ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Calculate Now"   Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="CalcNowBtn_Click"
                                        local:RibbonTooltip.Title="Calculate Now"
                                        local:RibbonTooltip.KeyTip="C"
                                        local:RibbonTooltip.Description="Recalculate all formulas in all open workbooks now."/>
                                <Button Content="Calculate Sheet" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="CalcSheetBtn_Click"
                                        local:RibbonTooltip.Title="Calculate Sheet"
                                        local:RibbonTooltip.KeyTip="S"
                                        local:RibbonTooltip.Description="Recalculate all formulas in the active sheet."/>
                                <Button Content="Calc Options" Width="96" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="CalcOptionsBtn_Click"
                                        local:RibbonTooltip.Title="Calculation Options"
                                        local:RibbonTooltip.KeyTip="O"
                                        local:RibbonTooltip.Description="Choose whether formulas are recalculated automatically or manually.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Automatic" local:RibbonTooltip.KeyTip="A" Click="CalcAutoMenuItem_Click"/>
                                            <MenuItem Header="Manual"    local:RibbonTooltip.KeyTip="M" Click="CalcManualMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Calculation" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── DATA ──────────────────────────────────────────────── -->
            <TabItem Header="Data" local:RibbonTooltip.KeyTip="A">
                <Border Background="{StaticResource FreexcelRibbonSurfaceBrush}" Padding="6,4,6,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal" MinHeight="88">

                        <!-- ▌Get &amp; Transform Data ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Get Data"    Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="GetDataBtn_Click"
                                        local:RibbonTooltip.Title="Get Data"
                                        local:RibbonTooltip.KeyTip="D"
                                        local:RibbonTooltip.Description="Import data from a local CSV file. Database, web, and Power Query connectors are excluded."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Get &amp; Transform Data" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Queries &amp; Connections ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Refresh All" Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="RefreshAllBtn_Click"
                                        local:RibbonTooltip.Title="Refresh All"
                                        local:RibbonTooltip.KeyTip="R"
                                        local:RibbonTooltip.Description="Recalculate formulas and refresh Freexcel-managed workbook data. External data connections and Power Query are excluded."/>
                                <Button Content="Queries" Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" IsEnabled="False"
                                        local:RibbonTooltip.Title="Queries &amp; Connections"
                                        local:RibbonTooltip.KeyTip="Q"
                                        local:RibbonTooltip.Description="External workbook queries and connection management are deferred in Freexcel."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Queries &amp; Connections" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Sort &amp; Filter ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Width="64" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SortAscButton_Click"
                                            local:RibbonTooltip.Title="Sort Ascending"
                                            local:RibbonTooltip.KeyTip="SA"
                                            local:RibbonTooltip.Description="Sort the selected column from smallest to largest (A to Z).">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <local:RibbonIcon Kind="SortAscending" IconSize="12" Margin="0,0,3,0"/>
                                            <TextBlock Text="A-Z" FontSize="10" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Width="64" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SortDescButton_Click"
                                            local:RibbonTooltip.Title="Sort Descending"
                                            local:RibbonTooltip.KeyTip="SD"
                                            local:RibbonTooltip.Description="Sort the selected column from largest to smallest (Z to A).">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <local:RibbonIcon Kind="SortDescending" IconSize="12" Margin="0,0,3,0"/>
                                            <TextBlock Text="Z-A" FontSize="10" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Width="64" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FilterButton_Click"
                                            local:RibbonTooltip.Title="Filter"
                                            local:RibbonTooltip.KeyTip="T"
                                            local:RibbonTooltip.Description="Enable dropdown filters on each column to show only the rows you want.">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <local:RibbonIcon Kind="Filter" IconSize="11"
                                                              VerticalAlignment="Center" Margin="0,0,2,0"/>
                                            <TextBlock Text="Filter" VerticalAlignment="Center" FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ClearFilterButton_Click"
                                            local:RibbonTooltip.Title="Clear Filter"
                                            local:RibbonTooltip.KeyTip="C"
                                            local:RibbonTooltip.Description="Remove all active filters and show all rows in the current range.">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <local:RibbonIcon Kind="Filter" IconSize="11"
                                                              VerticalAlignment="Center" Margin="0,0,2,0"/>
                                            <TextBlock Text="Clear Filter" VerticalAlignment="Center" FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Content="Advanced" Width="74" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="AdvancedFilterBtn_Click"
                                            local:RibbonTooltip.Title="Advanced Filter"
                                            local:RibbonTooltip.KeyTip="A"
                                            local:RibbonTooltip.Description="Filter a list using an Excel-style criteria range, optionally copying matching rows elsewhere."/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Sort &amp; Filter" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Data Tools ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Text to Columns"   Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="TextToColumnsBtn_Click"
                                        local:RibbonTooltip.Title="Text to Columns"
                                        local:RibbonTooltip.KeyTip="E"
                                        local:RibbonTooltip.Description="Split text in one column into multiple columns using a delimiter such as a comma or space."/>
                                <Button Content="Flash Fill"        Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="FlashFillMenuItem_Click"
                                        local:RibbonTooltip.Title="Flash Fill"
                                        local:RibbonTooltip.KeyTip="FF"
                                        local:RibbonTooltip.Description="Automatically fill values from examples in adjacent columns."/>
                                <Button Content="Remove Duplicates" Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="RemoveDuplicatesBtn_Click"
                                        local:RibbonTooltip.Title="Remove Duplicates"
                                        local:RibbonTooltip.KeyTip="M"
                                        local:RibbonTooltip.Description="Delete duplicate rows from the selected range."/>
                                <Button Content="Data Validation"   Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ValidationButton_Click"
                                        local:RibbonTooltip.Title="Data Validation"
                                        local:RibbonTooltip.KeyTip="V"
                                        local:RibbonTooltip.Description="Control what data can be entered in the selected cells."/>
                                <Button Content="Consolidate"       Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ConsolidateBtn_Click"
                                        local:RibbonTooltip.Title="Consolidate"
                                        local:RibbonTooltip.KeyTip="N"
                                        local:RibbonTooltip.Description="Combine values from multiple ranges into a single summary range."/>
                                <Button Content="Subtotal"         Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="SubtotalBtn_Click"
                                        local:RibbonTooltip.Title="Subtotal"
                                        local:RibbonTooltip.KeyTip="B"
                                        local:RibbonTooltip.Description="Insert subtotal rows for grouped data in the selected range."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Data Tools" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Forecast ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="What-If Analysis" Width="116" Height="22" Margin="1,1"
                                        Style="{StaticResource RibbonBtn}" Click="GoalSeekBtn_Click"
                                        local:RibbonTooltip.Title="What-If Analysis"
                                        local:RibbonTooltip.KeyTip="W"
                                        local:RibbonTooltip.Description="Open Goal Seek, Scenario Manager, or Data Table tools.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Goal Seek..." local:RibbonTooltip.KeyTip="G" Click="GoalSeekBtn_Click"/>
                                            <MenuItem Header="Scenario Manager..." local:RibbonTooltip.KeyTip="S" Click="ScenariosBtn_Click"/>
                                            <MenuItem Header="Data Table..." local:RibbonTooltip.KeyTip="D" Click="DataTableBtn_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Content="Forecast Sheet" Width="90" Height="22" Margin="1,1"
                                        Style="{StaticResource RibbonBtn}" Click="ForecastSheetBtn_Click"
                                        local:RibbonTooltip.Title="Forecast Sheet"
                                        local:RibbonTooltip.KeyTip="F"
                                        local:RibbonTooltip.Description="Create a new worksheet with forecast values from a two-column timeline and value range."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
                                <TextBlock Text="Forecast" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Outline ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Group" Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="GroupRowsBtn_Click"
                                            local:RibbonTooltip.Title="Group"
                                            local:RibbonTooltip.KeyTip="G"
                                            local:RibbonTooltip.Description="Group the selected rows or whole selected columns (Alt+Shift+Right Arrow)."/>
                                    <Button Content="Ungroup" Width="90" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="UngroupRowsBtn_Click"
                                            local:RibbonTooltip.Title="Ungroup"
                                            local:RibbonTooltip.KeyTip="U"
                                            local:RibbonTooltip.Description="Remove grouping from selected rows or whole selected columns (Alt+Shift+Left Arrow)."/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Collapse" Width="80" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="CollapseGroupBtn_Click"
                                            local:RibbonTooltip.Title="Collapse Group"
                                            local:RibbonTooltip.KeyTip="H"
                                            local:RibbonTooltip.Description="Hide all rows in the current outline group."/>
                                    <Button Content="Expand" Width="90" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ExpandGroupBtn_Click"
                                            local:RibbonTooltip.Title="Expand Group"
                                            local:RibbonTooltip.KeyTip="J"
                                            local:RibbonTooltip.Description="Show all rows in the current outline group."/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Outline" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── REVIEW ────────────────────────────────────────────── -->
            <TabItem Header="Review" local:RibbonTooltip.KeyTip="R">
                <Border Background="{StaticResource FreexcelRibbonSurfaceBrush}" Padding="6,4,6,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal" MinHeight="88">

                        <!-- ▌Proofing ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Spelling" Width="104" Height="22"
                                        Style="{StaticResource RibbonBtn}" FontSize="12"
                                        Margin="1,1"
                                        Click="SpellCheckBtn_Click"
                                        local:RibbonTooltip.Title="Spelling"
                                        local:RibbonTooltip.KeyTip="S"
                                        local:RibbonTooltip.Description="Find known misspellings in text cells on the active sheet with replace, replace all, and ignore choices."/>
                                <Button Content="Workbook Stats" Width="104" Height="22"
                                        Style="{StaticResource RibbonBtn}" FontSize="12"
                                        Margin="1,1"
                                        Click="WorkbookStatisticsBtn_Click"
                                        local:RibbonTooltip.Title="Workbook Statistics"
                                        local:RibbonTooltip.KeyTip="W"
                                        local:RibbonTooltip.Description="Show workbook counts for sheets, cells, formulas, comments, and objects."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Proofing" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Accessibility" Width="96" Height="22"
                                        Style="{StaticResource RibbonBtn}" FontSize="12"
                                        Margin="1,1"
                                        Click="AccessibilityCheckerBtn_Click"
                                        local:RibbonTooltip.Title="Check Accessibility"
                                        local:RibbonTooltip.KeyTip="A"
                                        local:RibbonTooltip.Description="Find merged cells, objects missing alternate text, and charts without titles."/>
                                <Button Content="Alt Text" Width="96" Height="22"
                                        Style="{StaticResource RibbonBtn}" FontSize="12"
                                        Margin="1,1"
                                        Click="SetAltTextBtn_Click"
                                        local:RibbonTooltip.Title="Alt Text"
                                        local:RibbonTooltip.KeyTip="T"
                                        local:RibbonTooltip.Description="Add or edit alternate text for the picture, shape, or text box anchored at the selected cell."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Accessibility" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Comments ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="New Comment" Width="102" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewNewThreadedCommentBtn_Click"
                                        local:RibbonTooltip.Title="New Comment"
                                        local:RibbonTooltip.KeyTip="C"
                                        local:RibbonTooltip.Description="Add or edit a threaded comment on the selected cell (Ctrl+Shift+F2)."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Comments" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Notes ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="New" Width="50" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewNewCommentBtn_Click"
                                                local:RibbonTooltip.Title="New Note"
                                                local:RibbonTooltip.KeyTip="O"
                                                local:RibbonTooltip.Description="Add a simple cell note to the selected cell."/>
                                        <Button Content="Edit" Width="50" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewNewCommentBtn_Click"
                                                local:RibbonTooltip.Title="Edit Note"
                                                local:RibbonTooltip.KeyTip="E"
                                                local:RibbonTooltip.Description="Edit the simple cell note on the selected cell."/>
                                        <Button Content="Delete" Width="50" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewDeleteCommentBtn_Click"
                                                local:RibbonTooltip.Title="Delete Note"
                                                local:RibbonTooltip.KeyTip="D"
                                                local:RibbonTooltip.Description="Remove the simple cell note from the selected cell."/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Prev" Width="50" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewPrevCommentBtn_Click"
                                                local:RibbonTooltip.Title="Previous Note"
                                                local:RibbonTooltip.KeyTip="P"
                                                local:RibbonTooltip.Description="Navigate to the previous simple cell note in the sheet."/>
                                        <Button Content="Next" Width="50" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewNextCommentBtn_Click"
                                                local:RibbonTooltip.Title="Next Note"
                                                local:RibbonTooltip.KeyTip="N"
                                                local:RibbonTooltip.Description="Navigate to the next simple cell note in the sheet."/>
                                    </StackPanel>
                                    <Button Content="Show Notes" Width="102" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ReviewShowCommentsBtn_Click"
                                            local:RibbonTooltip.Title="Show Notes"
                                            local:RibbonTooltip.KeyTip="H"
                                            local:RibbonTooltip.Description="Open a list of simple cell notes on the active sheet."/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Notes" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Protect ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button x:Name="ProtectSheetButton" Content="Protect Sheet"    Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ProtectSheetBtn_Click"
                                        local:RibbonTooltip.Title="Protect Sheet"
                                        local:RibbonTooltip.KeyTip="PS"
                                        local:RibbonTooltip.Description="Set sheet protection for locked cells with an optional password."/>
                                <Button x:Name="ProtectWorkbookButton" Content="Protect Workbook"  Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ProtectWorkbookBtn_Click"
                                        local:RibbonTooltip.Title="Protect Workbook"
                                        local:RibbonTooltip.KeyTip="PW"
                                        local:RibbonTooltip.Description="Prevent structural changes to the workbook such as adding, deleting, or renaming sheets."/>
                                <Button Content="Allow Edit Ranges" Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="AllowEditRangesBtn_Click"
                                        local:RibbonTooltip.Title="Allow Edit Ranges"
                                        local:RibbonTooltip.KeyTip="AR"
                                        local:RibbonTooltip.Description="Add a range that remains editable when the sheet is protected."/>
                                <Button Content="Share" Width="110" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ShareWorkbookBtn_Click"
                                        local:RibbonTooltip.Title="Share"
                                        local:RibbonTooltip.KeyTip="SH"
                                        local:RibbonTooltip.Description="Save the workbook if needed and open Windows Share for the file."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Protect" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── VIEW ──────────────────────────────────────────────── -->
            <TabItem Header="View" local:RibbonTooltip.KeyTip="W">
                <Border Background="{StaticResource FreexcelRibbonSurfaceBrush}" Padding="6,4,6,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal" MinHeight="88">

                        <!-- ▌Show ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Normal" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="NormalViewBtn_Click"
                                        local:RibbonTooltip.Title="Normal"
                                        local:RibbonTooltip.KeyTip="N"
                                        local:RibbonTooltip.Description="Show the worksheet in the standard editing view."/>
                                <Button Content="Page Break Preview" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageBreakPreviewBtn_Click"
                                        local:RibbonTooltip.Title="Page Break Preview"
                                        local:RibbonTooltip.KeyTip="P"
                                        local:RibbonTooltip.Description="Show manual page breaks and print area boundaries while editing."/>
                                <Button Content="Page Layout" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="PageLayoutViewBtn_Click"
                                        local:RibbonTooltip.Title="Page Layout"
                                        local:RibbonTooltip.KeyTip="L"
                                        local:RibbonTooltip.Description="Show the sheet with print layout boundaries."/>
                                <Button Content="Custom Views" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="CustomViewsBtn_Click"
                                        local:RibbonTooltip.Title="Custom Views"
                                        local:RibbonTooltip.KeyTip="C"
                                        local:RibbonTooltip.Description="View, add, show, and delete saved workbook views."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Workbook Views" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,2,8,0">
                                <CheckBox x:Name="ViewGridlinesChk" Content="Gridlines"              Margin="4,1" IsChecked="True" Checked="ViewGridlinesChk_Changed" Unchecked="ViewGridlinesChk_Changed"
                                          local:RibbonTooltip.Title="Gridlines"
                                          local:RibbonTooltip.KeyTip="G"
                                          local:RibbonTooltip.Description="Show or hide worksheet gridlines."/>
                                <CheckBox x:Name="ViewHeadersChk"   Content="Row and Column Headers" Margin="4,1" IsChecked="True" Checked="ViewHeadersChk_Changed"   Unchecked="ViewHeadersChk_Changed"
                                          local:RibbonTooltip.Title="Headings"
                                          local:RibbonTooltip.KeyTip="H"
                                          local:RibbonTooltip.Description="Show or hide row numbers and column letters."/>
                                <CheckBox x:Name="ViewRulerChk"     Content="Ruler"                  Margin="4,1" IsChecked="True" Checked="ViewRulerChk_Changed"     Unchecked="ViewRulerChk_Changed"
                                          local:RibbonTooltip.Title="Ruler"
                                          local:RibbonTooltip.KeyTip="R"
                                          local:RibbonTooltip.Description="Show or hide rulers in Page Layout view."/>
                                <CheckBox x:Name="ViewFormulaBarChk" Content="Formula Bar" Margin="4,1" IsChecked="True" Checked="ViewFormulaBarChk_Changed" Unchecked="ViewFormulaBarChk_Changed"
                                          local:RibbonTooltip.Title="Formula Bar"
                                          local:RibbonTooltip.KeyTip="FB"
                                          local:RibbonTooltip.Description="Show or hide the formula bar."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Show" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

                        <!-- ▌Zoom ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="16"/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                                <Button Content="Zoom" Width="102" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ZoomPickerBtn_Click"
                                        local:RibbonTooltip.Title="Zoom"
                                        local:RibbonTooltip.KeyTip="Q"
                                        local:RibbonTooltip.Description="Choose an Excel-style zoom preset from 10% to 400%.">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="200%" Tag="200" local:RibbonTooltip.KeyTip="2" Click="ZoomPresetMenuItem_Click"/>
                                            <MenuItem Header="100%" Tag="100" local:RibbonTooltip.KeyTip="1" Click="ZoomPresetMenuItem_Click"/>
                                            <MenuItem Header="75%"  Tag="75"  local:RibbonTooltip.KeyTip="7" Click="ZoomPresetMenuItem_Click"/>
                                            <MenuItem Header="50%"  Tag="50"  local:RibbonTooltip.KeyTip="5" Click="ZoomPresetMenuItem_Click"/>
                                            <MenuItem Header="25%"  Tag="25"  local:RibbonTooltip.KeyTip="3" Click="ZoomPresetMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Custom..." local:RibbonTooltip.KeyTip="C" Click="ZoomCustomMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="-"    Width="28" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ZoomOutBtn_Click"
                                            local:RibbonTooltip.Title="Zoom Out"
                                            local:RibbonTooltip.KeyTip="ZO"
                                            local:RibbonTooltip.Description="Decrease the zoom level to see more of the sheet."/>
                                    <Button Content="100%" Width="44" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="Zoom100Btn_Click"
                                            local:RibbonTooltip.Title="Zoom to 100%"
                                            local:RibbonTooltip.KeyTip="Z1"
                                            local:RibbonTooltip.Description="Reset the zoom level to 100%."/>
                                    <Button Content="+"    Width="28" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ZoomInBtn_Click"
                                            local:RibbonTooltip.Title="Zoom In"
                                            local:RibbonTooltip.KeyTip="ZI"
                                            local:RibbonTooltip.Description="Increase the zoom level for a closer look at cells."/>
                                </StackPanel>
                                <Button Content="Zoom to Selection" Width="102" Height="22" Margin="1,1" Style="{StaticResource RibbonBtn}" Click="ZoomSelectionBtn_Click"
                                        local:RibbonTooltip.Title="Zoom to Selection"
                                        local:RibbonTooltip.KeyTip="ZS"
                                        local:RibbonTooltip.Description="Fit the selected cells within the visible grid viewport."/>
                            </StackPanel>
                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"><TextBlock Text="Zoom" Style="{StaticResource GroupLbl}"/></Border>
                        </Grid>
                        <Rectangle Width="1" Fill="#CCCCCC" Margin="3,4,5,16"/>

