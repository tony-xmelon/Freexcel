<Window x:Class="Freexcel.App.Host.CustomViewsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Views"
        Width="640" Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="_Views">
            <ListView x:Name="ViewsList" SelectionChanged="ViewsList_SelectionChanged"
                      AutomationProperties.Name="Custom views"
                      AutomationProperties.HelpText="Shows saved workbook views that can be shown or deleted.">
                <ListView.View>
                        <GridView>
                        <GridViewColumn Header="Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Sheets" Width="70" DisplayMemberBinding="{Binding SheetCount}"/>
                        <GridViewColumn Header="Print settings" Width="110" DisplayMemberBinding="{Binding PrintSettingsIndicator}"/>
                        <GridViewColumn Header="Hidden rows, columns and filter settings" Width="210" DisplayMemberBinding="{Binding FilterSettingsIndicator}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ShowButton" Content="_Show" Width="72" Margin="0,0,8,0" IsDefault="True" Click="ShowButton_Click"/>
            <Button Content="_Add..." Width="72" Margin="0,0,8,0" Click="AddButton_Click"/>
            <Button x:Name="DeleteButton" Content="_Delete" Width="72" Margin="0,0,8,0" Click="DeleteButton_Click"/>
            <Button Content="_Close" Width="72" IsCancel="True" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
