<Window x:Class="FreeX.App.Host.PivotLabelFilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FreeX.App.Host"
        Title="{local:Loc Key=PivotLabelFilter_LabelFilter}"
        Width="380"
        Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{local:Loc Key=Common_Ok}" Width="74" Margin="0,0,8,0" IsDefault="True" Click="OkButton_Click"/>
            <Button Content="{local:Loc Key=Common_Cancel}" Width="74" IsCancel="True"/>
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="104"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="{local:Loc Key=PivotLabelFilter_ShowItemsForWhichTheLabel}" Margin="0,0,0,10"/>
            <Label Grid.Row="1" Grid.Column="0" Content="{local:Loc Key=PivotLabelFilter_Operator}" Target="{Binding ElementName=LabelFilterKindBox}" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <ComboBox x:Name="LabelFilterKindBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" SelectionChanged="LabelFilterKindBox_SelectionChanged" AutomationProperties.Name="{local:Loc Key=PivotLabelFilter_LabelFilterOperator}"/>
            <Label Grid.Row="2" Grid.Column="0" Content="{local:Loc Key=PivotLabelFilter_Value}" Target="{Binding ElementName=LabelFilterValueBox}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="LabelFilterValueBox" Grid.Row="2" Grid.Column="1" AutomationProperties.Name="{local:Loc Key=PivotLabelFilter_LabelFilterValue}"/>
            <Label x:Name="LabelFilterValue2Label" Grid.Row="3" Grid.Column="0" Content="{local:Loc Key=PivotLabelFilter_And}" Target="{Binding ElementName=LabelFilterValue2Box}" VerticalAlignment="Center" Margin="0,8,8,0"/>
            <TextBox x:Name="LabelFilterValue2Box" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" AutomationProperties.Name="{local:Loc Key=PivotLabelFilter_EndingLabelFilterValue}"/>
        </Grid>
    </DockPanel>
</Window>
