<Window x:Class="Freexcel.App.Host.CustomViewsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Views"
        Width="420" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Views">
            <ListView x:Name="ViewsList" SelectionChanged="ViewsList_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="220" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Sheets" Width="90" DisplayMemberBinding="{Binding SheetCount}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ShowButton" Content="Show" Width="72" Margin="0,0,8,0" Click="ShowButton_Click"/>
            <Button Content="Add..." Width="72" Margin="0,0,8,0" Click="AddButton_Click"/>
            <Button x:Name="DeleteButton" Content="Delete" Width="72" Margin="0,0,8,0" Click="DeleteButton_Click"/>
            <Button Content="Close" Width="72" IsCancel="True" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
