<Window x:Class="Freexcel.App.Host.PivotFieldFilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filter"
        Width="380"
        Height="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="_OK"
                    Width="74"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Content="_Cancel"
                    Width="74"
                    IsCancel="True"/>
        </StackPanel>

        <TabControl>
            <TabItem Header="Select _Items">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Choose items to show:"
                               Margin="0,0,0,8"/>
                    <Label Grid.Row="1"
                           Content="_Search:"
                           Target="{Binding ElementName=FilterSearchBox}"
                           Padding="0"
                           Margin="0,0,0,4"/>
                    <TextBox x:Name="FilterSearchBox"
                             Grid.Row="2"
                             Margin="0,0,0,8"
                             TextChanged="FilterSearchBox_TextChanged"
                             AutomationProperties.Name="Search PivotTable filter items"/>

                    <CheckBox x:Name="SelectAllCheckBox"
                              Grid.Row="3"
                              Content="Select _All"
                              Margin="2,0,0,6"
                              Click="SelectAllCheckBox_Click"/>

                    <ListBox x:Name="FilterItemsList"
                             Grid.Row="4"
                             BorderBrush="#BDBDBD"
                             AutomationProperties.Name="PivotTable filter items">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Caption}"
                                          IsChecked="{Binding IsChecked}"
                                          Click="FilterItemCheckBox_Click"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
            <TabItem Header="_Label Filters">
                <StackPanel Margin="10">
                    <TextBlock Text="Open the full label filter dialog to filter PivotTable items by their captions."
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>
                    <Button x:Name="LabelFilterButton"
                            Content="_Label Filter..."
                            Width="120"
                            HorizontalAlignment="Left"
                            Click="LabelFilterButton_Click"
                            AutomationProperties.Name="Open PivotTable label filter dialog"/>
                </StackPanel>
            </TabItem>
            <TabItem x:Name="ValueFiltersTab"
                     Header="_Value Filters">
                <StackPanel Margin="10">
                    <TextBlock Text="Open the full value filter dialog to filter PivotTable items by summarized values."
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>
                    <TextBlock x:Name="ValueFilterUnavailableText"
                               Text="Add at least one PivotTable value field to use value filters."
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"
                               Visibility="Collapsed"/>
                    <Button x:Name="ValueFilterButton"
                            Content="_Value Filter..."
                            Width="120"
                            HorizontalAlignment="Left"
                            Click="ValueFilterButton_Click"
                            AutomationProperties.Name="Open PivotTable value filter dialog"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
