<Window x:Class="Freexcel.App.Host.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Color"
        Width="340"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="NoColorButton"
                    MinWidth="76"
                    Margin="0,0,8,0"
                    Content="No color"
                    Click="NoColorButton_Click"/>
            <Button MinWidth="76"
                    Margin="0,0,8,0"
                    Content="OK"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button MinWidth="76"
                    Content="Cancel"
                    IsCancel="True"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Swatches" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <ListBox x:Name="SwatchList"
                     Height="220"
                     DisplayMemberPath="Hex"
                     SelectionChanged="SwatchList_SelectionChanged"/>

            <TextBlock Text="Custom color" FontWeight="SemiBold" Margin="0,12,0,6"/>
            <TextBox x:Name="CustomColorTextBox"/>
            <TextBlock Text="#RRGGBB or R, G, B"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       FontSize="11"
                       Margin="0,4,0,0"/>
        </StackPanel>
    </DockPanel>
</Window>
