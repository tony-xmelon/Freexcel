                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Recent files -->
                <Grid Grid.Row="2" Margin="40,0,40,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Tabs + search -->
                        <RowDefinition Height="Auto"/> <!-- Column headers -->
                        <RowDefinition Height="*"/>    <!-- File list -->
                    </Grid.RowDefinitions>

                    <!-- Tabs row + search box -->
                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,0">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Button Background="Transparent" BorderThickness="0" Padding="0"
                                    Cursor="Hand" Click="SsRecentTab_Click"
                                    local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Recent}"
                                    local:RibbonTooltip.KeyTip="RC" local:RibbonMetadata.CommandName="Recent">
                                <Border x:Name="SsRecentTab" Padding="0,8,22,8"
                                        BorderThickness="0,0,0,2" BorderBrush="#0F6D8C">
                                <TextBlock x:Name="SsRecentTabText" Text="{local:Loc Key=MainWindow_Text_Recent}" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#0F6D8C"/>
                                </Border>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="0"
                                    Cursor="Hand" Click="SsPinnedTab_Click"
                                    local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Pinned}"
                                    local:RibbonTooltip.KeyTip="PN" local:RibbonMetadata.CommandName="Pinned">
                                <Border x:Name="SsPinnedTab" Padding="0,8,22,8"
                                        BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                <TextBlock x:Name="SsPinnedTabText" Text="{local:Loc Key=MainWindow_Text_Pinned}" FontSize="13"
                                           Foreground="#888"/>
                                </Border>
                            </Button>
                        </StackPanel>
                        <Border DockPanel.Dock="Right"
                                Background="#F5F5F5" BorderBrush="#D8D8D8" BorderThickness="1"
                                CornerRadius="2" Padding="8,4" VerticalAlignment="Center">
                            <TextBox x:Name="SsSearchBox" Width="180" FontSize="12"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_SearchRecentFiles}"
                                     AutomationProperties.HelpText="{local:Loc Key=MainWindow_AutomationHelpText_FilterRecentAndPinnedFiles}"
                                     TextChanged="SsSearchBox_TextChanged"/>
                        </Border>
                    </DockPanel>

                    <!-- Column headers -->
                    <Border Grid.Row="1" BorderThickness="0,1,0,1" BorderBrush="#E4E4E4"
                            Padding="0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{local:Loc Key=MainWindow_Text_Name}" FontSize="11" Foreground="#888"/>
                            <TextBlock Grid.Column="1" Text="{local:Loc Key=MainWindow_Text_DateModified}" FontSize="11" Foreground="#888"/>
                        </Grid>
                    </Border>

                    <!-- File list (Recent) -->
                    <ScrollViewer x:Name="SsRecentScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="SsRecentList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button HorizontalContentAlignment="Stretch"
                                            BorderThickness="0" Padding="0,7"
                                            Click="SsRecentItem_Click"
                                            Cursor="Hand"
                                            AutomationProperties.AutomationId="BackstageRecentFileItem"
                                            AutomationProperties.Name="{Binding OpenAutomationName}"
                                            AutomationProperties.HelpText="{Binding OpenAutomationHelpText}">
                                        <Button.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_PinToList}" local:RibbonTooltip.KeyTip="P" Click="SsPinItem_Click"
                                                          AutomationProperties.AutomationId="BackstageRecentPinMenuItem"
                                                          AutomationProperties.Name="{Binding PinAutomationName}"
                                                          AutomationProperties.HelpText="{Binding PinAutomationHelpText}" local:RibbonMetadata.CommandName="Pin to list"/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_RemoveFromList}" local:RibbonTooltip.KeyTip="R" Click="SsRemoveRecentItem_Click"
                                                          AutomationProperties.AutomationId="BackstageRecentRemoveMenuItem"
                                                          AutomationProperties.Name="{Binding RemoveAutomationName}"
                                                          AutomationProperties.HelpText="{Binding RemoveAutomationHelpText}" local:RibbonMetadata.CommandName="Remove from list"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="rowBg" Background="Transparent"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="rowBg" Property="Background"
                                                                Value="#F3F6F9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Border Width="26" Height="30" Background="#0F6D8C"
                                                        CornerRadius="2" Margin="0,0,10,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="X" Foreground="White"
                                                               FontSize="11" FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontSize="13" Foreground="#1F1F1F"/>
                                                    <TextBlock Text="{Binding Directory}"
                                                               FontSize="11" Foreground="#888"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LastOpenedText}"
                                                       FontSize="12" Foreground="#666"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Width="24" Height="24"
                                                    Style="{StaticResource RibbonBtn}"
                                                    Click="SsPinItem_Click"
                                                    local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_PinFile}"
                                                    local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_PinOrUnpinThisWorkbookInTheRecentFilesList}"
                                                    AutomationProperties.AutomationId="BackstageRecentPinButton"
                                                    AutomationProperties.Name="{Binding PinAutomationName}"
                                                    AutomationProperties.HelpText="{Binding PinAutomationHelpText}"
                                                    ToolTip="{local:Loc Key=MainWindow_ToolTip_PinToList}" local:RibbonMetadata.CommandName="Pin File">
                                                <local:RibbonIcon Kind="Pin" IconSize="16" HorizontalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- File list (Pinned) -->
                    <ScrollViewer x:Name="SsPinnedScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <ItemsControl x:Name="SsPinnedList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button HorizontalContentAlignment="Stretch"
                                            BorderThickness="0" Padding="0,7"
                                            Click="SsRecentItem_Click"
                                            Cursor="Hand"
                                            AutomationProperties.AutomationId="BackstagePinnedFileItem"
                                            AutomationProperties.Name="{Binding OpenAutomationName}"
                                            AutomationProperties.HelpText="{Binding OpenAutomationHelpText}">
                                        <Button.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_UnpinFromList}" local:RibbonTooltip.KeyTip="U" Click="SsUnpinItem_Click"
                                                          AutomationProperties.AutomationId="BackstagePinnedUnpinMenuItem"
                                                          AutomationProperties.Name="{Binding PinAutomationName}"
                                                          AutomationProperties.HelpText="{Binding PinAutomationHelpText}" local:RibbonMetadata.CommandName="Unpin from list"/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_RemoveFromList}" local:RibbonTooltip.KeyTip="R" Click="SsRemoveRecentItem_Click"
                                                          AutomationProperties.AutomationId="BackstagePinnedRemoveMenuItem"
                                                          AutomationProperties.Name="{Binding RemoveAutomationName}"
                                                          AutomationProperties.HelpText="{Binding RemoveAutomationHelpText}" local:RibbonMetadata.CommandName="Remove from list"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="rowBg" Background="Transparent"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="rowBg" Property="Background"
                                                                Value="#F3F6F9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Border Width="26" Height="30" Background="#0F6D8C"
                                                        CornerRadius="2" Margin="0,0,10,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="X" Foreground="White"
                                                               FontSize="11" FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontSize="13" Foreground="#1F1F1F"/>
                                                    <TextBlock Text="{Binding Directory}"
                                                               FontSize="11" Foreground="#888"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LastOpenedText}"
                                                       FontSize="12" Foreground="#666"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Width="24" Height="24"
                                                    Style="{StaticResource RibbonBtn}"
                                                    Click="SsUnpinItem_Click"
                                                    local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_UnpinFile}"
                                                    local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_RemoveThisWorkbookFromThePinnedFilesList}"
                                                    AutomationProperties.AutomationId="BackstagePinnedUnpinButton"
                                                    AutomationProperties.Name="{Binding PinAutomationName}"
                                                    AutomationProperties.HelpText="{Binding PinAutomationHelpText}"
                                                    ToolTip="{local:Loc Key=MainWindow_ToolTip_UnpinFromList}" local:RibbonMetadata.CommandName="Unpin File">
                                                <local:RibbonIcon Kind="Pin" IconSize="16" HorizontalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
                </Grid><!-- end SsHomeView -->

                <!-- ══ INFO VIEW ════════════════════════════════════════════ -->
                <Grid x:Name="SsInfoView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{local:Loc Key=MainWindow_Text_Info}"
                               FontSize="28" FontWeight="Light" Foreground="#1F1F1F"
                               Margin="40,36,40,0"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="40,24,40,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Workbook actions (left) -->
                            <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                <TextBlock Text="{local:Loc Key=MainWindow_Text_ProtectWorkbook}"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="{local:Loc Key=MainWindow_Text_ControlWhatTypesOfChangesOthersCanMake}"
                                           FontSize="12" Foreground="#555" TextWrapping="Wrap"
                                           Margin="0,0,0,20"/>
                                <TextBlock Text="{local:Loc Key=MainWindow_Text_CheckAccessibility}"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="{local:Loc Key=MainWindow_Text_FindMergedCellsAndObjectsMissingAltText}"
                                           FontSize="12" Foreground="#555" TextWrapping="Wrap"
                                           Margin="0,0,0,20"/>
                                <TextBlock Text="{local:Loc Key=MainWindow_Text_ManageWorkbook}"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="{local:Loc Key=MainWindow_Text_ReviewLocalFileStatusAndUnsupportedWorkbookFeatureWarnings}"
                                           FontSize="12" Foreground="#555" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Properties (right) -->
                            <Border Grid.Column="1"
                                    BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                                    Padding="24,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="{local:Loc Key=MainWindow_Text_Properties}"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#555"
                                               Margin="0,0,0,14"/>

                                    <TextBlock Text="{local:Loc Key=MainWindow_Text_WorkbookName}" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoWorkbookName" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,12"/>

                                    <TextBlock Text="{local:Loc Key=MainWindow_Text_FilePath}" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoFilePath" FontSize="12" Foreground="#555"
                                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                                    <TextBlock Text="{local:Loc Key=MainWindow_Text_Sheets}" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoSheetCount" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,12"/>

                                    <TextBlock Text="{local:Loc Key=MainWindow_Text_Format}" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoFormat" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,20"/>

                                    <TextBlock Text="{local:Loc Key=MainWindow_Text_WorkbookStatistics}" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoStatisticsSummary" FontSize="12" Foreground="#555"
                                               TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,12"/>

                                    <TextBlock Text="{local:Loc Key=MainWindow_Text_Accessibility}" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoAccessibilitySummary" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,20"/>

                                    <TextBlock Text="{local:Loc Key=MainWindow_Text_FormulaErrors}" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="InfoFormulaErrorSummary" FontSize="13" Foreground="#1F1F1F" Margin="0,0,0,20"/>

                                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,20"/>

                                    <TextBlock Text="{local:Loc Key=MainWindow_Text_AboutFreeX}"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#555"
                                               Margin="0,0,0,10"/>
                                    <TextBlock FontSize="12" Foreground="#555"
                                               TextWrapping="Wrap" LineHeight="20"
                                               Margin="0,0,0,6">FreeX is a free spreadsheet app for .xlsx files. It supports workbook editing, formulas, styling, charts, and local file workflows.</TextBlock>
                                    <TextBlock FontSize="11" Foreground="#666"
                                               TextWrapping="Wrap" LineHeight="18"
                                               Margin="0,0,0,6">FreeX is not affiliated with, endorsed by, or sponsored by Microsoft. Microsoft Excel is a trademark of Microsoft Corporation.</TextBlock>
                                    <TextBlock Text="{local:Loc Key=MainWindow_Text_Version05TesterRelease}"
                                               FontSize="11" Foreground="#888"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid><!-- end SsInfoView -->

            </Grid>
        </Grid>

        <Canvas x:Name="KeyTipOverlay"
                Grid.RowSpan="6"
                Panel.ZIndex="1000"
                IsHitTestVisible="False"
                Visibility="Collapsed"/>

    </Grid>
</Window>

