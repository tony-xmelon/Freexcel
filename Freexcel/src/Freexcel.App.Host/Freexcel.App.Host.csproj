<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Freexcel.Core.Model\Freexcel.Core.Model.csproj" />
    <ProjectReference Include="..\Freexcel.Core.Formula\Freexcel.Core.Formula.csproj" />
    <ProjectReference Include="..\Freexcel.Core.Calc\Freexcel.Core.Calc.csproj" />
    <ProjectReference Include="..\Freexcel.Core.Commands\Freexcel.Core.Commands.csproj" />
    <ProjectReference Include="..\Freexcel.Core.IO\Freexcel.Core.IO.csproj" />
    <ProjectReference Include="..\Freexcel.App.UI\Freexcel.App.UI.csproj" />
  </ItemGroup>

  <ItemGroup>
