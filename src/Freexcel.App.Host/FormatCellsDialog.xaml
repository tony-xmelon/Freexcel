<Window x:Class="Freexcel.App.Host.FormatCellsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Format Cells" Width="560" Height="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="Tabs" Grid.Row="0">
            <!-- Number -->
            <TabItem Header="_Number">
                <StackPanel Margin="8">
                    <TextBlock Text="Format code:" Margin="0,4,0,2"/>
                    <ComboBox x:Name="NumberFormatCombo" IsEditable="True" Height="24"
                              SelectionChanged="NumberFormatCombo_SelectionChanged"/>
                    <TextBlock Text="Preview:" Margin="0,8,0,2"/>
                    <TextBlock x:Name="NumberPreview" FontWeight="Bold"/>
                </StackPanel>
            </TabItem>

            <!-- Alignment -->
            <TabItem Header="_Alignment">
                <StackPanel Margin="8">
                    <TextBlock Text="Horizontal alignment:" Margin="0,4,0,2"/>
                    <ComboBox x:Name="DlgHAlignBox" Height="24"/>
                    <TextBlock Text="Vertical alignment:" Margin="0,8,0,2"/>
                    <ComboBox x:Name="DlgVAlignBox" Height="24"/>
                    <CheckBox x:Name="DlgWrapTextCheck" Content="_Wrap text" Margin="0,8,0,0"/>
                    <CheckBox x:Name="DlgShrinkToFitCheck" Content="S_hrink to fit" Margin="0,6,0,0"/>
                    <TextBlock Text="Indent level (0-15):" Margin="0,8,0,2"/>
                    <TextBox x:Name="DlgIndentLevelBox" Height="24"/>
                    <TextBlock Text="Text rotation (-90 to 90, or 255):" Margin="0,8,0,2"/>
                    <TextBox x:Name="DlgTextRotationBox" Height="24"/>
                </StackPanel>
            </TabItem>

            <!-- Font -->
            <TabItem Header="_Font">
                <StackPanel Margin="8">
                    <TextBlock Text="Font:" Margin="0,4,0,2"/>
                    <ComboBox x:Name="DlgFontNameBox" Height="24"/>
                    <TextBlock Text="Size:" Margin="0,8,0,2"/>
                    <ComboBox x:Name="DlgFontSizeBox" IsEditable="True" Height="24"/>
                    <WrapPanel Margin="0,8,0,0">
                        <CheckBox x:Name="DlgBoldCheck"      Content="_Bold"             Margin="0,0,12,6"/>
                        <CheckBox x:Name="DlgItalicCheck"    Content="_Italic"           Margin="0,0,12,6"/>
                        <CheckBox x:Name="DlgUnderlineCheck" Content="_Underline"        Margin="0,0,12,6"/>
                        <CheckBox x:Name="DlgDoubleUnderlineCheck" Content="_Double underline" Margin="0,0,12,6"/>
                        <CheckBox x:Name="DlgStrikeCheck"    Content="_Strikethrough"    Margin="0,0,12,6"/>
                        <CheckBox x:Name="DlgSuperscriptCheck" Content="Super_script"     Margin="0,0,12,6"/>
                        <CheckBox x:Name="DlgSubscriptCheck" Content="Su_bscript"/>
                    </WrapPanel>
                    <TextBlock Text="Font Color (R,G,B):" Margin="0,8,0,2"/>
                    <DockPanel>
                        <Button x:Name="DlgFontColorPickerButton" DockPanel.Dock="Right" Content="_Pick" Width="54" Margin="6,0,0,0" Click="DlgFontColorPickerButton_Click"/>
                        <TextBox x:Name="DlgFontColorBox" Height="24" Text="0,0,0"/>
                    </DockPanel>
                </StackPanel>
            </TabItem>

            <!-- Fill -->
            <TabItem Header="F_ill">
                <StackPanel Margin="8">
                    <TextBlock Text="Background Color (R,G,B, or empty for none):" Margin="0,4,0,2"/>
                    <DockPanel>
                        <Button x:Name="DlgFillColorPickerButton" DockPanel.Dock="Right" Content="_Pick" Width="54" Margin="6,0,0,0" Click="DlgFillColorPickerButton_Click"/>
                        <TextBox x:Name="DlgFillColorBox" Height="24"/>
                    </DockPanel>
                    <CheckBox x:Name="DlgClearFillCheck" Content="_Clear fill" Margin="0,8,0,0"/>
                </StackPanel>
            </TabItem>

            <!-- Border -->
            <TabItem Header="_Border">
                <StackPanel Margin="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Style" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Color (R,G,B)" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Top:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <ComboBox x:Name="DlgBorderTopStyleBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,0,8,6"/>
                        <DockPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,6">
                            <Button x:Name="DlgBorderTopColorPickerButton" DockPanel.Dock="Right" Content="P_ick" Width="54" Margin="6,0,0,0" Click="DlgBorderTopColorPickerButton_Click"/>
                            <TextBox x:Name="DlgBorderTopColorBox" Height="24"/>
                        </DockPanel>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Right:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <ComboBox x:Name="DlgBorderRightStyleBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,0,8,6"/>
                        <DockPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,6">
                            <Button x:Name="DlgBorderRightColorPickerButton" DockPanel.Dock="Right" Content="P_ick" Width="54" Margin="6,0,0,0" Click="DlgBorderRightColorPickerButton_Click"/>
                            <TextBox x:Name="DlgBorderRightColorBox" Height="24"/>
                        </DockPanel>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Bottom:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <ComboBox x:Name="DlgBorderBottomStyleBox" Grid.Row="3" Grid.Column="1" Height="24" Margin="0,0,8,6"/>
                        <DockPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,6">
                            <Button x:Name="DlgBorderBottomColorPickerButton" DockPanel.Dock="Right" Content="P_ick" Width="54" Margin="6,0,0,0" Click="DlgBorderBottomColorPickerButton_Click"/>
                            <TextBox x:Name="DlgBorderBottomColorBox" Height="24"/>
                        </DockPanel>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Left:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="DlgBorderLeftStyleBox" Grid.Row="4" Grid.Column="1" Height="24" Margin="0,0,8,0"/>
                        <DockPanel Grid.Row="4" Grid.Column="2">
                            <Button x:Name="DlgBorderLeftColorPickerButton" DockPanel.Dock="Right" Content="P_ick" Width="54" Margin="6,0,0,0" Click="DlgBorderLeftColorPickerButton_Click"/>
                            <TextBox x:Name="DlgBorderLeftColorBox" Height="24"/>
                        </DockPanel>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- Protection -->
            <TabItem Header="_Protection">
                <StackPanel Margin="8">
                    <CheckBox x:Name="DlgLockedCheck" Content="_Locked" Margin="0,4,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="_OK"     Width="70" Height="26" Margin="4,0" IsDefault="True" Click="OkButton_Click"/>
            <Button Content="_Cancel" Width="70" Height="26" Margin="4,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
