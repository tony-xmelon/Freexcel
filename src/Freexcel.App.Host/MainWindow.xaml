<Window x:Class="Freexcel.App.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:Freexcel.App.UI;assembly=Freexcel.App.UI"
        mc:Ignorable="d"
        Title="Freexcel" 
        Height="720" Width="1280"
        WindowState="Maximized"
        Background="#F0F0F0">
    
    <Grid>
        <Grid.RowDefinitions>
            <!-- Ribbon area -->
            <RowDefinition Height="Auto"/>
            <!-- Formatting toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Formula bar -->
            <RowDefinition Height="Auto"/>
            <!-- Grid area (main content) -->
            <RowDefinition Height="*"/>
            <!-- Sheet tabs -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ribbon placeholder -->
        <Border Grid.Row="0" Background="#217346" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Freexcel" FontSize="16" FontWeight="SemiBold" 
                           Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="  —  " Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                <TextBlock x:Name="WorkbookNameText" Text="Untitled" FontSize="14" 
                           Foreground="#CCFFFFFF" VerticalAlignment="Center" Margin="0,0,20,0"/>
                
                <Button Content="Open" Click="OpenButton_Click" Width="60" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Button Content="Save" Click="SaveButton_Click" Width="60" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Button Content="Find" Click="FindButton_Click" Width="50" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Button Content="Replace" Click="ReplaceButton_Click" Width="60" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Button Content="Chart" Click="InsertChartButton_Click" Width="50" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Button Content="Sort A→Z" Click="SortAscButton_Click" Width="60" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Button Content="Sort Z→A" Click="SortDescButton_Click" Width="60" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Button Content="Filter" Click="FilterButton_Click" Width="44" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Button Content="Clear Filter" Click="ClearFilterButton_Click" Width="70" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Button Content="CF Rule" Click="CfRuleButton_Click" Width="50" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Button Content="Validation" Click="ValidationButton_Click" Width="64" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Button Content="Names" Click="NamedRangesButton_Click" Width="46" Height="24" Margin="4,0"
                        Background="#2D8C57" Foreground="White" BorderThickness="0"/>
                <Separator Background="#80FFFFFF" Width="1" Margin="8,4"/>
                <Button Content="Print" Click="PrintButton_Click" Width="40" Height="24" Margin="4,0"
                        Background="#1A6B3A" Foreground="White" BorderThickness="0"/>
                <Button Content="PDF" Click="ExportPdfButton_Click" Width="36" Height="24" Margin="4,0"
                        Background="#1A6B3A" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Formatting toolbar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="4,3">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="FontNameBox" Width="110" Height="22" Margin="2,0"
                          SelectionChanged="FontNameBox_SelectionChanged"/>
                <ComboBox x:Name="FontSizeBox" Width="46" Height="22" Margin="2,0" IsEditable="True"
                          SelectionChanged="FontSizeBox_SelectionChanged"/>
                <Separator Width="1" Background="#D0D0D0" Margin="4,2"/>
                <ToggleButton x:Name="BoldButton" Width="24" Height="22" Margin="1,0"
                              FontWeight="Bold" Click="BoldButton_Click">B</ToggleButton>
                <ToggleButton x:Name="ItalicButton" Width="24" Height="22" Margin="1,0"
                              FontStyle="Italic" Click="ItalicButton_Click">I</ToggleButton>
                <ToggleButton x:Name="UnderlineButton" Width="24" Height="22" Margin="1,0"
                              Click="UnderlineButton_Click">
                    <TextBlock Text="U" TextDecorations="Underline"/>
                </ToggleButton>
                <ToggleButton x:Name="StrikeButton" Width="24" Height="22" Margin="1,0"
                              Click="StrikeButton_Click">
                    <TextBlock Text="S" TextDecorations="Strikethrough"/>
                </ToggleButton>
                <Separator Width="1" Background="#D0D0D0" Margin="4,2"/>
                <Button x:Name="FontColorBtn" Content="A" Width="24" Height="22" Margin="1,0"
                        Click="FontColorBtn_Click" ToolTip="Font Color"/>
                <Button x:Name="FillColorBtn" Content="H" Width="24" Height="22" Margin="1,0"
                        Click="FillColorBtn_Click" ToolTip="Fill Color"/>
                <Separator Width="1" Background="#D0D0D0" Margin="4,2"/>
                <ToggleButton x:Name="AlignLeftBtn" Width="28" Height="22" Margin="1,0"
                              Click="AlignLeftBtn_Click">L</ToggleButton>
                <ToggleButton x:Name="AlignCenterBtn" Width="28" Height="22" Margin="1,0"
                              Click="AlignCenterBtn_Click">C</ToggleButton>
                <ToggleButton x:Name="AlignRightBtn" Width="28" Height="22" Margin="1,0"
                              Click="AlignRightBtn_Click">R</ToggleButton>
                <ToggleButton x:Name="WrapTextBtn" Width="24" Height="22" Margin="1,0"
                              Click="WrapTextBtn_Click" ToolTip="Wrap Text">W</ToggleButton>
                <Separator Width="1" Background="#D0D0D0" Margin="4,2"/>
                <Button Content="Merge" Width="44" Height="22" Margin="1,0" Click="MergeCenterBtn_Click"/>
                <Separator Width="1" Background="#D0D0D0" Margin="4,2"/>
                <ComboBox x:Name="NumberFormatBox" Width="90" Height="22" Margin="2,0"
                          SelectionChanged="NumberFormatBox_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- Formula bar -->
        <Border Grid.Row="2" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Background="White" Padding="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="CellAddressBox" Grid.Column="0" Text="A1" 
                         FontFamily="Consolas" FontSize="13" VerticalContentAlignment="Center"
                         BorderBrush="#C0C0C0" Padding="4,2"/>
                
                <TextBlock Grid.Column="1" Text=" fx " FontWeight="Bold" Foreground="#666"
                           VerticalAlignment="Center" Margin="4,0"/>
                
                <TextBox x:Name="FormulaBar" Grid.Column="2" FontFamily="Consolas" FontSize="13"
                         VerticalContentAlignment="Center" BorderBrush="#C0C0C0" Padding="4,2"
                         KeyDown="FormulaBar_KeyDown"/>
            </Grid>
        </Border>

        <!-- Grid area -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ui:GridView x:Name="SheetGrid" Grid.Row="0" Grid.Column="0"/>
            
            <ScrollBar x:Name="VerticalScroll" Grid.Row="0" Grid.Column="1" 
                       Orientation="Vertical" Minimum="1" Maximum="1000000" Value="1"/>
            <ScrollBar x:Name="HorizontalScroll" Grid.Row="1" Grid.Column="0" 
                       Orientation="Horizontal" Minimum="1" Maximum="16384" Value="1"/>
            
            <Border Grid.Row="1" Grid.Column="1" Background="#E8E8E8"/>
        </Grid>

        <!-- Sheet tabs -->
        <Border Grid.Row="4" Background="#E8E8E8" BorderBrush="#D0D0D0"
                BorderThickness="0,1,0,0" Padding="4,2">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddSheetButton" Content="+" Width="24" Height="22"
                        FontSize="14" Margin="0,0,4,0"
                        Background="Transparent" BorderBrush="#C0C0C0"
                        Click="AddSheetButton_Click"/>
                <ItemsControl x:Name="SheetTabsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TabBorder"
                                    BorderBrush="#D0D0D0" BorderThickness="1"
                                    CornerRadius="3,3,0,0" Padding="10,3" Margin="2,0,0,0"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="SheetTab_MouseLeftButtonDown"
                                    MouseRightButtonDown="SheetTab_MouseRightButtonDown">
                                <TextBlock Text="{Binding Name}" FontSize="12"
                                           MouseDown="SheetTab_LabelMouseDown"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="5" Background="#217346" Padding="8,4">
            <Grid>
                <TextBlock x:Name="StatusReadyText" Text="Ready" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                <StackPanel x:Name="StatusStatsPanel" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="StatusSumText"   Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock x:Name="StatusCountText" Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock x:Name="StatusAvgText"   Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock x:Name="StatusMinText"   Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock x:Name="StatusMaxText"   Foreground="White" FontSize="12"/>
                </StackPanel>
                <TextBlock Text="100%" Foreground="White" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
