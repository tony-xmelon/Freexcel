<Window x:Class="Freexcel.App.Host.NamedRangeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Named Range Manager"
        Width="500" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- List of existing named ranges -->
            <RowDefinition Height="*"/>
            <!-- Separator -->
            <RowDefinition Height="8"/>
            <!-- Define / edit area -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Existing named ranges list -->
        <GroupBox Grid.Row="0" Header="_Defined Names">
            <ListView x:Name="NamesList" SelectionChanged="NamesList_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="160"
                                        DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Address" Width="260"
                                        DisplayMemberBinding="{Binding Address}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <!-- Define new / edit area -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="_Name:" Target="{Binding ElementName=NameBox}" VerticalAlignment="Center"/>
            <TextBox x:Name="NameBox" Grid.Column="1"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="_Range:" Target="{Binding ElementName=RangeBox}" VerticalAlignment="Center"/>
            <TextBox x:Name="RangeBox" Grid.Column="1"
                     ToolTip="Enter range in format: Sheet1!A1:B10"/>
        </Grid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="_Define" Width="64" Margin="0,0,8,0" Click="DefineButton_Click"/>
            <Button Content="_Delete" Width="64" Margin="0,0,8,0" Click="DeleteButton_Click"/>
            <Button Content="_Close" Width="64" IsCancel="True" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
