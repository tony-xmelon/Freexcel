<Window x:Class="FreeX.App.Host.OptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FreeX.App.Host"
        Title="{local:Loc Key=Options_FreeXOptions}"
        Width="760" Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="OptionTabItem" TargetType="ListBoxItem">
            <Setter Property="Padding"  Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#A0A0A0"/>
                                <Setter TargetName="bg" Property="Background" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bg" Property="Background" Value="#DCDCDC"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left sidebar ───────────────────────────────────── -->
            <Border Grid.Column="0" Background="#F5F5F5"
                    BorderThickness="0,0,1,0" BorderBrush="#C8C8C8">
                <ListBox x:Name="TabList" BorderThickness="0" Background="Transparent"
                         Margin="0,8,0,0"
                         SelectionChanged="TabList_SelectionChanged"
                         AutomationProperties.Name="{local:Loc Key=Options_OptionsCategories}"
                         AutomationProperties.AutomationId="OptionsCategoryList"
                         AutomationProperties.HelpText="{local:Loc Key=Options_SelectAFreeXOptionsCategory}"
                         ItemContainerStyle="{StaticResource OptionTabItem}">
                    <ListBoxItem Content="{local:Loc Key=Options_General}"/>
                    <ListBoxItem Content="{local:Loc Key=Options_Formulas}"/>
                    <ListBoxItem Content="{local:Loc Key=Options_Proofing}"/>
                    <ListBoxItem Content="{local:Loc Key=Options_Save}"/>
                    <ListBoxItem Content="{local:Loc Key=Options_Language}"/>
                    <ListBoxItem Content="{local:Loc Key=Options_EaseOfAccess}"/>
                    <ListBoxItem Content="{local:Loc Key=Options_Advanced}"/>
                    <ListBoxItem Content="{local:Loc Key=Options_CustomizeRibbon}"/>
                    <ListBoxItem Content="{local:Loc Key=Options_QuickAccessToolbar}"/>
                    <ListBoxItem Content="{local:Loc Key=Options_AddIns}"/>
                    <ListBoxItem Content="{local:Loc Key=Options_TrustCenter}"/>
                    <ListBoxItem Content="{local:Loc Key=Options_View}"/>
                </ListBox>
            </Border>

            <!-- ── Right content area ─────────────────────────────── -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                          Padding="28,20,28,20">
                <Grid>

                    <!-- ═══ GENERAL ═══════════════════════════════════════ -->
                    <StackPanel x:Name="PanelGeneral">

                        <TextBlock Text="{local:Loc Key=Options_GeneralOptionsForWorkingWithFreeX}"
                                   FontSize="12" Foreground="#555" Margin="0,0,0,18"/>

                        <!-- User Interface options -->
                        <TextBlock Text="{local:Loc Key=Options_UserInterfaceOptions}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <CheckBox x:Name="OptCollapseRibbon"
                                  Content="{local:Loc Key=Options_CollapseTheRibbonAutomatically}"
                                  Margin="0,0,0,6" FontSize="12"/>
                        <CheckBox x:Name="OptShowScreenTips"
                                  Content="{local:Loc Key=Options_ShowFeatureDescriptionsInScreenTips}"
                                  Margin="0,0,0,4" FontSize="12"/>

                        <!-- When creating new workbooks -->
                        <TextBlock Text="{local:Loc Key=Options_WhenCreatingNewWorkbooks}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="{local:Loc Key=Options_DefaultFont}"
                                   Target="{Binding ElementName=OptDefaultFont}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <ComboBox x:Name="OptDefaultFont" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="{local:Loc Key=Options_FontSize}"
                                   Target="{Binding ElementName=OptDefaultFontSize}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <ComboBox x:Name="OptDefaultFontSize" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"
                                      IsEditable="True"/>
                        </Grid>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="{local:Loc Key=Options_IncludeThisManySheets}"
                                   Target="{Binding ElementName=OptSheetCount}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <TextBox x:Name="OptSheetCount" Grid.Column="1"
                                     Height="24" VerticalContentAlignment="Center"
                                     Padding="6,0" FontSize="12"/>
                        </Grid>

                        <!-- Personalize -->
                        <TextBlock Text="{local:Loc Key=Options_PersonalizeYourCopyOfFreeX}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="{local:Loc Key=Options_UserName}"
                                   Target="{Binding ElementName=OptUserName}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <TextBox x:Name="OptUserName" Grid.Column="1"
                                     Height="24" VerticalContentAlignment="Center"
                                     Padding="6,0" FontSize="12"/>
                        </Grid>
                    </StackPanel>

                    <!-- ═══ FORMULAS ══════════════════════════════════════ -->
                    <StackPanel x:Name="PanelFormulas" Visibility="Collapsed">

                        <TextBlock Text="{local:Loc Key=Options_CalculationOptions}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <TextBlock Text="{local:Loc Key=Options_WorkbookCalculation}" FontSize="12"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <RadioButton x:Name="OptCalcAuto" Content="{local:Loc Key=Options_Automatic}"
                                     GroupName="CalcMode" FontSize="12"
                                     Margin="0,0,0,6"/>
                        <RadioButton x:Name="OptCalcManual" Content="{local:Loc Key=Options_Manual}"
                                     GroupName="CalcMode" FontSize="12"
                                     Margin="0,0,0,4"/>
                        <TextBlock Text="{local:Loc Key=Options_InManualModePressF9ToRecalculateTheWorkbook}"
                                   FontSize="11" Foreground="#777" Margin="18,4,0,0"/>

                        <TextBlock Text="{local:Loc Key=Options_WorkingWithFormulas}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <CheckBox x:Name="OptR1C1" Content="{local:Loc Key=Options_UseR1C1ReferenceStyle}"
                                  FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox x:Name="OptFormulasAutocomplete"
                                  Content="{local:Loc Key=Options_EnableAutoCompleteForCellValues}"
                                  FontSize="12" Margin="0,0,0,4"/>

                        <TextBlock Text="{local:Loc Key=Options_ErrorCheckingRules}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <TextBlock Text="{local:Loc Key=Options_EnableBackgroundErrorChecksFor}"
                                   FontSize="12" Foreground="#555" Margin="0,0,0,8"/>
                        <StackPanel x:Name="OptErrorCheckingRules"/>
                    </StackPanel>

                    <!-- PROOFING -->
                    <StackPanel x:Name="PanelProofing" Visibility="Collapsed">
                        <TextBlock Text="{local:Loc Key=Options_AutoCorrectOptions}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <CheckBox Content="{local:Loc Key=Options_CheckSpellingAsYouType}" IsChecked="True"
                                  FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="{local:Loc Key=Options_IgnoreWordsInUPPERCASE}"
                                  FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="{local:Loc Key=Options_FlagRepeatedWords}"
                                  FontSize="12" Margin="0,0,0,12"/>
                        <Button x:Name="AutoCorrectOptionsButton" Content="{local:Loc Key=Options_AutoCorrectOptions2}" Width="150" Height="26"
                                HorizontalAlignment="Left" Click="AutoCorrectOptionsButton_Click"/>
                    </StackPanel>

                    <!-- VIEW -->
                    <StackPanel x:Name="PanelView" Visibility="Collapsed">

                        <TextBlock Text="{local:Loc Key=Options_WorkbookViewOptions}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <CheckBox x:Name="OptShowFormulaBar"
                                  Content="{local:Loc Key=Options_ShowFormulaBar}"
                                  FontSize="12" Margin="0,0,0,6"
                                  Checked="ShowFormulaBar_Changed"
                                  Unchecked="ShowFormulaBar_Changed"/>
                        <CheckBox x:Name="OptFormulaBarExpanded"
                                  Content="{local:Loc Key=Options_ExpandFormulaBar}"
                                  FontSize="12" Margin="0,0,0,4"/>
                    </StackPanel>

                    <!-- LANGUAGE -->
                    <StackPanel x:Name="PanelLanguage" Visibility="Collapsed">
                        <TextBlock Text="{local:Loc Key=Options_ChooseDisplayLanguage}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="240"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="{local:Loc Key=Options_AppLanguage}"
                                   Target="{Binding ElementName=OptAppLanguage}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <ComboBox x:Name="OptAppLanguage" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="CultureName"
                                      AutomationProperties.Name="{local:Loc Key=Options_AppLanguage}"
                                      AutomationProperties.HelpText="{local:Loc Key=Options_AppLanguageHelpText}"/>
                        </Grid>
                        <TextBlock Text="{local:Loc Key=Options_AppLanguageRestartNotice}"
                                   FontSize="11" Foreground="#777" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- EASE OF ACCESS -->
                    <StackPanel x:Name="PanelEaseOfAccess" Visibility="Collapsed">
                        <TextBlock Text="{local:Loc Key=Options_EaseOfAccessOptions}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <CheckBox Content="{local:Loc Key=Options_ProvideFeedbackWithSound}"
                                  FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="{local:Loc Key=Options_ShowQuickAnalysisOptionsOnSelection}"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="{local:Loc Key=Options_OptimizeDisplayForAccessibility}"
                                  FontSize="12" Margin="0,0,0,6"/>
                    </StackPanel>

                    <!-- ADVANCED -->
                    <StackPanel x:Name="PanelAdvanced" Visibility="Collapsed">
                        <TextBlock Text="{local:Loc Key=Options_EditingOptions}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <CheckBox x:Name="OptMoveAfterEnter"
                                  Content="{local:Loc Key=Options_AfterPressingEnterMoveSelection}"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,8"
                                  Checked="MoveAfterEnter_Changed"
                                  Unchecked="MoveAfterEnter_Changed"/>
                        <Grid Margin="18,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="{local:Loc Key=Options_Direction}"
                                   Target="{Binding ElementName=OptAfterEnterDirection}"
                                   Padding="0" VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="OptAfterEnterDirection" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"/>
                        </Grid>
                        <CheckBox Content="{local:Loc Key=Options_EnableFillHandleAndCellDragAndDrop}"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="{local:Loc Key=Options_EnableAutoCompleteForCellValues}"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,6"/>

                        <TextBlock Text="{local:Loc Key=Options_DisplayOptionsForThisWorkbook}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <CheckBox x:Name="OptShowGridlines" Content="{local:Loc Key=Options_ShowGridlines}"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox x:Name="OptShowHeadings" Content="{local:Loc Key=Options_ShowRowAndColumnHeadings}"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="{local:Loc Key=Options_ForObjectsShow}"
                                   Target="{Binding ElementName=OptObjectsDisplay}"
                                   Padding="0" VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="OptObjectsDisplay" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- ═══ SAVE ═══════════════════════════════════════════ -->
                    <StackPanel x:Name="PanelSave" Visibility="Collapsed">

                        <TextBlock Text="{local:Loc Key=Options_SaveWorkbooks}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="{local:Loc Key=Options_SaveFilesInThisFormat}"
                                   Target="{Binding ElementName=OptDefaultFormat}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <ComboBox x:Name="OptDefaultFormat" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="{local:Loc Key=Options_FileLocations}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="{local:Loc Key=Options_RecentFilesLocation}"
                                   Target="{Binding ElementName=OptRecentFilesPath}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <TextBox x:Name="OptRecentFilesPath" Grid.Column="1"
                                     Height="24" IsReadOnly="True"
                                     VerticalContentAlignment="Center"
                                     Padding="6,0" FontSize="11" Foreground="#666"/>
                        </Grid>
                    </StackPanel>

                    <!-- CUSTOMIZE RIBBON -->
                    <StackPanel x:Name="PanelCustomizeRibbon" Visibility="Collapsed">
                        <TextBlock Text="{local:Loc Key=Options_CustomizeTheRibbon}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <TextBlock Text="{local:Loc Key=Options_ChooseCommandsFromPopularCommands}"
                                   FontSize="12" Margin="0,0,0,8"/>
                        <Button x:Name="RibbonImportExportButton" Content="{local:Loc Key=Options_ImportExport}" Width="130" Height="26"
                                HorizontalAlignment="Left" Click="RibbonImportExportButton_Click"/>
                    </StackPanel>

                    <!-- QUICK ACCESS TOOLBAR -->
                    <StackPanel x:Name="PanelQuickAccessToolbar" Visibility="Collapsed">
                        <TextBlock Text="{local:Loc Key=Options_CustomizeTheQuickAccessToolbar}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <CheckBox Content="{local:Loc Key=Options_ShowQuickAccessToolbarBelowTheRibbon}"
                                  FontSize="12" Margin="0,0,0,8"/>
                        <Button x:Name="QuickAccessResetButton" Content="{local:Loc Key=Options_Reset}" Width="90" Height="26"
                                HorizontalAlignment="Left" Click="QuickAccessResetButton_Click"/>
                    </StackPanel>

                    <!-- ADD-INS -->
                    <StackPanel x:Name="PanelAddIns" Visibility="Collapsed">
                        <TextBlock Text="{local:Loc Key=Options_ViewAndManageAddIns}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <TextBlock Text="{local:Loc Key=Options_ActiveApplicationAddIns}"
                                   FontSize="12" Margin="0,0,0,8"/>
                        <Button x:Name="AddInsGoButton" Content="{local:Loc Key=Options_Go}" Width="70" Height="26"
                                HorizontalAlignment="Left" Click="AddInsGoButton_Click"/>
                    </StackPanel>

                    <!-- TRUST CENTER -->
                    <StackPanel x:Name="PanelTrustCenter" Visibility="Collapsed">
                        <TextBlock Text="{local:Loc Key=Options_TrustCenter2}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <TextBlock Text="{local:Loc Key=Options_SecurityAndPrivacySettingsForFreeX}"
                                   FontSize="12" Foreground="#555" Margin="0,0,0,12"/>
                        <CheckBox x:Name="OptCrashAnalytics"
                                  Content="{local:Loc Key=Options_SendOptInCrashReports}"
                                  FontSize="12"
                                  Margin="0,0,0,6"
                                  AutomationProperties.HelpText="{local:Loc Key=Options_CrashReportsIncludeAppVersionRuntimeOperatingSystemSessi}"/>
                        <TextBlock Text="{local:Loc Key=Options_CrashReportsAreSentOnlyWhenThisOptionIsEnabledAndTheTest}"
                                   FontSize="11" Foreground="#777" TextWrapping="Wrap" Margin="18,0,0,12"/>
                        <TextBlock Text="{local:Loc Key=Options_LocalTesterDiagnostics}"
                                   FontWeight="SemiBold" FontSize="12" Margin="0,8,0,5"/>
                        <TextBlock Text="{local:Loc Key=Options_FreeXWritesLocalUsageEventsAndCrashFilesToLOCALAPPDATAFr}"
                                   FontSize="11" Foreground="#777" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Button x:Name="TrustCenterSettingsButton" Content="{local:Loc Key=Options_TrustCenterSettings}" Width="170" Height="26"
                                HorizontalAlignment="Left" Click="TrustCenterSettingsButton_Click"/>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ── OK / Cancel ──────────────────────────────────────────── -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#C8C8C8"
                Padding="16,10" Background="#F5F5F5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="OkBtn" Content="{local:Loc Key=Common_Ok}" Width="80" Height="26"
                        Margin="0,0,8,0" IsDefault="True" Click="OkBtn_Click"
                        AutomationProperties.Name="{local:Loc Key=Options_OK}"
                        AutomationProperties.AutomationId="OptionsOkButton"
                        AutomationProperties.HelpText="{local:Loc Key=Options_ApplyFreeXOptionsChanges}"/>
                <Button x:Name="CancelBtn" Content="{local:Loc Key=Common_Cancel}" Width="80" Height="26"
                        AutomationProperties.Name="{local:Loc Key=Options_Cancel}"
                        AutomationProperties.AutomationId="OptionsCancelButton"
                        AutomationProperties.HelpText="{local:Loc Key=Options_CloseFreeXOptionsWithoutApplyingChanges}"
                        IsCancel="True" Click="CancelBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
