<Window x:Class="Freexcel.App.Host.PageSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Page Setup"
        Width="600" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="PageSetupTabs" Grid.Row="0">
            <TabItem x:Name="PageTab" Header="_Page">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="_Orientation:" Target="{Binding ElementName=OrientationBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <ComboBox x:Name="OrientationBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                        <ComboBoxItem Content="Portrait" Tag="Portrait"/>
                        <ComboBoxItem Content="Landscape" Tag="Landscape"/>
                    </ComboBox>

                    <Label Grid.Row="1" Grid.Column="0" Content="_Paper size:" Target="{Binding ElementName=PaperSizeBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <ComboBox x:Name="PaperSizeBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                        <ComboBoxItem Content="Letter (8.5 x 11)" Tag="Letter"/>
                        <ComboBoxItem Content="A4 (210 x 297 mm)" Tag="A4"/>
                        <ComboBoxItem Content="Legal (8.5 x 14)" Tag="Legal"/>
                    </ComboBox>

                    <GroupBox Grid.Row="2" Grid.ColumnSpan="2" Header="Scaling" Margin="0,2,0,8">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <RadioButton x:Name="AdjustToRadioButton" Grid.Row="0" Grid.Column="0" Content="_Adjust to:" GroupName="ScalingMode" VerticalAlignment="Center" Margin="0,0,8,8" Checked="ScalingMode_Changed" Unchecked="ScalingMode_Changed"/>
                            <TextBox x:Name="ScalePercentBox" Grid.Row="0" Grid.Column="1" Margin="0,0,6,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="% normal size" VerticalAlignment="Center" Margin="0,0,0,8"/>

                            <RadioButton x:Name="FitToRadioButton" Grid.Row="1" Grid.Column="0" Content="_Fit to:" GroupName="ScalingMode" VerticalAlignment="Center" Margin="0,0,8,0" Checked="ScalingMode_Changed" Unchecked="ScalingMode_Changed"/>
                            <TextBox x:Name="FitPagesWideBox" Grid.Row="1" Grid.Column="1" Margin="0,0,6,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="page(s) wide by" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="FitPagesTallBox" Grid.Row="1" Grid.Column="3" Margin="0,0,6,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="tall" VerticalAlignment="Center"/>
                        </Grid>
                    </GroupBox>

                    <Label Grid.Row="3" Grid.Column="0" Content="First _page number:" Target="{Binding ElementName=FirstPageNumberBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="FirstPageNumberBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>
                    <Label Grid.Row="4" Grid.Column="0" Content="Print _quality:" Target="{Binding ElementName=PrintQualityBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="PrintQualityBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"/>
                </Grid>
            </TabItem>

            <TabItem x:Name="MarginsTab" Header="_Margins">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="_Left:" Target="{Binding ElementName=LeftMarginBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="LeftMarginBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="_Right:" Target="{Binding ElementName=RightMarginBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="RightMarginBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="_Top:" Target="{Binding ElementName=TopMarginBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="TopMarginBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>
                    <Label Grid.Row="3" Grid.Column="0" Content="_Bottom:" Target="{Binding ElementName=BottomMarginBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="BottomMarginBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>
                    <Label Grid.Row="4" Grid.Column="0" Content="_Header:" Target="{Binding ElementName=HeaderMarginBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="HeaderMarginBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"/>
                    <Label Grid.Row="5" Grid.Column="0" Content="_Footer:" Target="{Binding ElementName=FooterMarginBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="FooterMarginBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,8"/>
                    <CheckBox x:Name="CenterHorizontallyBox" Grid.Row="6" Grid.Column="1" Content="_Center horizontally" Margin="0,4,0,8"/>
                    <CheckBox x:Name="CenterVerticallyBox" Grid.Row="7" Grid.Column="1" Content="Center _vertically"/>
                </Grid>
            </TabItem>

            <TabItem Header="_Header/Footer">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="_Header preset:" Target="{Binding ElementName=HeaderPresetBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <ComboBox x:Name="HeaderPresetBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" SelectionChanged="HeaderPresetBox_SelectionChanged">
                        <ComboBoxItem Content="(none)" Tag=""/>
                        <ComboBoxItem Content="Page 1" Tag="&amp;[Page]"/>
                        <ComboBoxItem Content="Page 1 of ?" Tag="Page &amp;[Page] of &amp;[Pages]"/>
                        <ComboBoxItem Content="Sheet1" Tag="&amp;[Tab]"/>
                        <ComboBoxItem Content="Book1" Tag="&amp;[File]"/>
                        <ComboBoxItem Content="Book1.xlsx" Tag="&amp;[File]"/>
                        <ComboBoxItem Content="Book1.xlsx, Sheet1" Tag="&amp;[File], &amp;[Tab]"/>
                        <ComboBoxItem Content="Confidential, Page 1" Tag="Confidential, Page &amp;[Page]"/>
                        <ComboBoxItem Content="Date, Page 1" Tag="&amp;[Date], Page &amp;[Page]"/>
                        <ComboBoxItem Content="Sheet name" Tag="&amp;[Tab]"/>
                        <ComboBoxItem Content="File name" Tag="&amp;[File]"/>
                        <ComboBoxItem Content="File path" Tag="&amp;[Path]&amp;[File]"/>
                    </ComboBox>

                    <Label Grid.Row="1" Grid.Column="0" Content="_Footer preset:" Target="{Binding ElementName=FooterPresetBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <ComboBox x:Name="FooterPresetBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" SelectionChanged="FooterPresetBox_SelectionChanged">
                        <ComboBoxItem Content="(none)" Tag=""/>
                        <ComboBoxItem Content="Page 1" Tag="&amp;[Page]"/>
                        <ComboBoxItem Content="Page 1 of ?" Tag="Page &amp;[Page] of &amp;[Pages]"/>
                        <ComboBoxItem Content="Sheet1" Tag="&amp;[Tab]"/>
                        <ComboBoxItem Content="Book1" Tag="&amp;[File]"/>
                        <ComboBoxItem Content="Book1.xlsx" Tag="&amp;[File]"/>
                        <ComboBoxItem Content="Book1.xlsx, Sheet1" Tag="&amp;[File], &amp;[Tab]"/>
                        <ComboBoxItem Content="Date" Tag="&amp;[Date]"/>
                        <ComboBoxItem Content="Time" Tag="&amp;[Time]"/>
                        <ComboBoxItem Content="Date, Page 1" Tag="&amp;[Date], Page &amp;[Page]"/>
                        <ComboBoxItem Content="File path" Tag="&amp;[Path]&amp;[File]"/>
                        <ComboBoxItem Content="File name" Tag="&amp;[File]"/>
                    </ComboBox>

                    <GroupBox Grid.Row="2" Grid.ColumnSpan="2" Header="Preview" Margin="0,2,0,10">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Header:" FontWeight="SemiBold" Margin="0,0,8,6"/>
                            <TextBlock x:Name="HeaderPreviewText" Grid.Row="0" Grid.Column="1" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Footer:" FontWeight="SemiBold" Margin="0,0,8,0"/>
                            <TextBlock x:Name="FooterPreviewText" Grid.Row="1" Grid.Column="1" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </GroupBox>

                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="CustomHeaderButton" Content="Custom _Header..." Width="128" Margin="0,0,8,0" Click="CustomHeaderFooterButton_Click"/>
                        <Button x:Name="CustomFooterButton" Content="Custom _Footer..." Width="128" Click="CustomHeaderFooterButton_Click"/>
                    </StackPanel>

                    <CheckBox x:Name="DifferentFirstPageBox" Grid.Row="4" Grid.Column="1" Content="_Different first page" Margin="0,0,0,8"/>
                    <CheckBox x:Name="DifferentOddEvenBox" Grid.Row="5" Grid.Column="1" Content="Different _odd and even pages" Margin="0,0,0,8"/>
                    <StackPanel Grid.Row="6" Grid.Column="1">
                        <CheckBox x:Name="ScaleWithDocumentBox" Content="_Scale with document" Margin="0,0,0,8"/>
                        <CheckBox x:Name="AlignWithMarginsBox" Content="_Align with page margins"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem x:Name="SheetTab" Header="_Sheet">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Print _area:" Target="{Binding ElementName=PrintAreaBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="PrintAreaBox" Grid.Row="0" Grid.Column="1" Margin="0,0,6,8"/>
                    <Button x:Name="PrintAreaPickerButton" Grid.Row="0" Grid.Column="2" Content="..." Width="24" Height="22" Margin="0,0,0,8"
                            Tag="PrintAreaBox" Click="RangePickerButton_Click"
                            ToolTip="Collapse dialog and select the print area."
                            AutomationProperties.Name="Select print area"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="_Rows to repeat at top:" Target="{Binding ElementName=RowsRepeatBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="RowsRepeatBox" Grid.Row="1" Grid.Column="1" Margin="0,0,6,8"/>
                    <Button x:Name="RowsRepeatPickerButton" Grid.Row="1" Grid.Column="2" Content="..." Width="24" Height="22" Margin="0,0,0,8"
                            Tag="RowsRepeatBox" Click="RangePickerButton_Click"
                            ToolTip="Collapse dialog and select rows to repeat at top."
                            AutomationProperties.Name="Select rows to repeat"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="_Columns to repeat at left:" Target="{Binding ElementName=ColumnsRepeatBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox x:Name="ColumnsRepeatBox" Grid.Row="2" Grid.Column="1" Margin="0,0,6,8"/>
                    <Button x:Name="ColumnsRepeatPickerButton" Grid.Row="2" Grid.Column="2" Content="..." Width="24" Height="22" Margin="0,0,0,8"
                            Tag="ColumnsRepeatBox" Click="RangePickerButton_Click"
                            ToolTip="Collapse dialog and select columns to repeat at left."
                            AutomationProperties.Name="Select columns to repeat"/>
                    <CheckBox x:Name="PrintGridlinesBox" Grid.Row="3" Grid.Column="1" Content="_Print gridlines" Margin="0,0,0,8"/>
                    <CheckBox x:Name="PrintHeadingsBox" Grid.Row="4" Grid.Column="1" Content="Print row and column _headings" Margin="0,0,0,8"/>
                    <Label Grid.Row="5" Grid.Column="0" Content="Pa_ge order:" Target="{Binding ElementName=PageOrderBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="PageOrderBox" Grid.Row="5" Grid.Column="1">
                        <ComboBoxItem Content="Down, then over" Tag="DownThenOver"/>
                        <ComboBoxItem Content="Over, then down" Tag="OverThenDown"/>
                    </ComboBox>
                    <CheckBox x:Name="PrintBlackAndWhiteBox" Grid.Row="6" Grid.Column="1" Content="_Black and white" Margin="0,8,0,8"/>
                    <CheckBox x:Name="PrintDraftQualityBox" Grid.Row="7" Grid.Column="1" Content="_Draft quality"/>
                    <Label Grid.Row="8" Grid.Column="0" Content="Cell _errors as:" Target="{Binding ElementName=PrintErrorValueBox}" Padding="0" VerticalAlignment="Center" Margin="0,8,8,0"/>
                    <ComboBox x:Name="PrintErrorValueBox" Grid.Row="8" Grid.Column="1" Margin="0,8,0,0">
                        <ComboBoxItem Content="Displayed" Tag="Displayed"/>
                        <ComboBoxItem Content="Blank" Tag="Blank"/>
                        <ComboBoxItem Content="--" Tag="Dash"/>
                        <ComboBoxItem Content="#N/A" Tag="NotAvailable"/>
                    </ComboBox>
                    <Label Grid.Row="9" Grid.Column="0" Content="Co_mments:" Target="{Binding ElementName=PrintCommentsBox}" Padding="0" VerticalAlignment="Center" Margin="0,8,8,0"/>
                    <ComboBox x:Name="PrintCommentsBox" Grid.Row="9" Grid.Column="1" Margin="0,8,0,0">
                        <ComboBoxItem Content="None" Tag="None"/>
                        <ComboBoxItem Content="At end of sheet" Tag="AtEnd"/>
                        <ComboBoxItem Content="As displayed on sheet" Tag="AsDisplayed"/>
                    </ComboBox>
                </Grid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="1" Margin="0,12,0,0">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="_Print..." Width="86" Margin="0,0,8,0" Click="PrintButton_Click"/>
                <Button Content="Print Pre_view" Width="104" Margin="0,0,8,0" Click="PrintPreviewButton_Click"/>
                <Button Content="_Options..." Width="86" Click="OptionsButton_Click"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="_OK" Width="72" Margin="0,0,8,0" Click="OkButton_Click" IsDefault="True"/>
                <Button Content="_Cancel" Width="72" IsCancel="True"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
