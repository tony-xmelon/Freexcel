<Window x:Class="Freexcel.App.Host.PivotValueFieldSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Value Field Settings"
        Width="430"
        Height="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="OkButton"
                    Content="_OK"
                    Width="78"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Content="_Cancel"
                    Width="78"
                    IsCancel="True"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="118"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0"
                       Content="Custom _Name:"
                       Target="{Binding ElementName=CustomNameBox}"
                       VerticalAlignment="Center"
                       Padding="0"
                       Margin="0,0,8,0"/>
                <TextBox x:Name="CustomNameBox"
                         Grid.Column="1"
                         AutomationProperties.Name="Custom name"/>
            </Grid>

            <TabControl Grid.Row="1">
                <TabItem Header="_Summarize Values By">
                    <StackPanel Margin="10">
                        <Label Content="_Summarize value field by:"
                               Target="{Binding ElementName=SummaryFunctionBox}"
                               Padding="0"
                               Margin="0,0,0,6"/>
                        <ComboBox x:Name="SummaryFunctionBox"
                                  Height="24"
                                  AutomationProperties.Name="Summarize value field by"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Show _Values As">
                    <StackPanel Margin="10">
                        <Label Content="Show values _as:"
                               Target="{Binding ElementName=ShowValuesAsBox}"
                               Padding="0"
                               Margin="0,0,0,6"/>
                        <ComboBox x:Name="ShowValuesAsBox"
                                  Height="24"
                                  AutomationProperties.Name="Show values as"/>
                        <Label Content="_Base field:"
                               Target="{Binding ElementName=BaseFieldBox}"
                               Padding="0"
                               Margin="0,10,0,6"/>
                        <ComboBox x:Name="BaseFieldBox"
                                  Height="24"
                                  AutomationProperties.Name="Base field"/>
                        <Label Content="Base _item:"
                               Target="{Binding ElementName=BaseItemBox}"
                               Padding="0"
                               Margin="0,10,0,6"/>
                        <TextBox x:Name="BaseItemBox"
                                 Height="24"
                                 AutomationProperties.Name="Base item"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="_Number Format">
                    <StackPanel Margin="10">
                        <Label Content="_Format preset:"
                               Target="{Binding ElementName=NumberFormatPresetBox}"
                               Padding="0"
                               Margin="0,0,0,6"/>
                        <ComboBox x:Name="NumberFormatPresetBox"
                                  Height="24"
                                  AutomationProperties.Name="Number format preset"
                                  SelectionChanged="NumberFormatPresetBox_SelectionChanged"/>
                        <Label Content="Number format _ID:"
                               Target="{Binding ElementName=NumberFormatBox}"
                               Padding="0"
                               Margin="0,10,0,6"/>
                        <TextBox x:Name="NumberFormatBox"
                                 Height="24"
                                 AutomationProperties.Name="Number format ID"/>
                        <Label Content="Custom format _code:"
                               Target="{Binding ElementName=NumberFormatCodeBox}"
                               Padding="0"
                               Margin="0,10,0,6"/>
                        <TextBox x:Name="NumberFormatCodeBox"
                                 Height="24"
                                 AutomationProperties.Name="Custom format code"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
