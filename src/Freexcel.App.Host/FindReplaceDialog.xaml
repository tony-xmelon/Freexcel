<Window x:Class="Freexcel.App.Host.FindReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find &amp; Replace"
        Width="560" Height="430"
        MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="FindReplaceTabs" Grid.Row="0" Margin="0,0,0,10">
            <TabItem x:Name="FindTab" Header="_Find">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="_Find what:" Target="{Binding ElementName=FindBox}" VerticalAlignment="Center"/>
                    <TextBox x:Name="FindBox" Grid.Column="1" MinWidth="260" KeyDown="FindBox_KeyDown"/>
                    <Button x:Name="FindFormatButton" Content="For_mat..." Grid.Column="2" Width="84" Margin="8,0,0,0" Click="FindFormatButton_Click"/>
                    <Button x:Name="FindClearFormatButton" Content="_Clear" Grid.Column="3" Width="52" Margin="6,0,0,0" Visibility="Collapsed" Click="FindClearFormatButton_Click"/>
                </Grid>
            </TabItem>

            <TabItem x:Name="ReplaceTab" Header="_Replace">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="_Find what:" Target="{Binding ElementName=ReplaceFindBox}" VerticalAlignment="Center"/>
                        <TextBox x:Name="ReplaceFindBox" Grid.Column="1" MinWidth="260" KeyDown="FindBox_KeyDown"/>
                        <Button x:Name="ReplaceFindFormatButton" Content="For_mat..." Grid.Column="2" Width="84" Margin="8,0,0,0" Click="FindFormatButton_Click"/>
                        <Button x:Name="ReplaceFindClearFormatButton" Content="_Clear" Grid.Column="3" Width="52" Margin="6,0,0,0" Visibility="Collapsed" Click="FindClearFormatButton_Click"/>
                    </Grid>

                    <Grid x:Name="ReplaceRow" Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="_Replace with:" Target="{Binding ElementName=ReplaceBox}" VerticalAlignment="Center"/>
                        <TextBox x:Name="ReplaceBox" Grid.Column="1" MinWidth="260"/>
                        <Button x:Name="ReplaceWithFormatButton" Grid.Column="2" Content="For_mat..." Width="84" Margin="8,0,0,0" Click="ReplaceWithFormatButton_Click"/>
                        <Button x:Name="ReplaceWithClearFormatButton" Grid.Column="3" Content="_Clear" Width="52" Margin="6,0,0,0" Visibility="Collapsed" Click="ReplaceWithClearFormatButton_Click"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Expander x:Name="OptionsExpander"
                  Grid.Row="1"
                  Header="_Options &gt;&gt;"
                  IsExpanded="False"
                  Expanded="OptionsExpander_Expanded"
                  Collapsed="OptionsExpander_Collapsed"
                  Margin="0,0,0,10">
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="_Within:" Target="{Binding ElementName=WithinCombo}" VerticalAlignment="Center"/>
                <ComboBox x:Name="WithinCombo" Grid.Column="1" SelectedIndex="0" Margin="0,0,12,6">
                    <ComboBoxItem Content="Workbook"/>
                    <ComboBoxItem Content="Sheet"/>
                </ComboBox>

                <Label Content="_Search:" Target="{Binding ElementName=SearchCombo}" Grid.Column="2" VerticalAlignment="Center"/>
                <ComboBox x:Name="SearchCombo" Grid.Column="3" SelectedIndex="0" Margin="0,0,0,6">
                    <ComboBoxItem Content="By Rows"/>
                    <ComboBoxItem Content="By Columns"/>
                </ComboBox>

                <Label Content="_Look in:" Target="{Binding ElementName=LookInCombo}" Grid.Row="1" VerticalAlignment="Center"/>
                <ComboBox x:Name="LookInCombo" Grid.Row="1" Grid.Column="1" SelectedIndex="0" Margin="0,0,12,6">
                    <ComboBoxItem Content="Formulas"/>
                    <ComboBoxItem Content="Values"/>
                    <ComboBoxItem Content="Notes"/>
                    <ComboBoxItem Content="Comments"/>
                </ComboBox>

                <CheckBox x:Name="MatchCaseBox" Grid.Row="2" Grid.ColumnSpan="2" Content="Match _case" Margin="0,2,12,0"/>
                <CheckBox x:Name="MatchEntireBox" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Content="Match entire cell _contents" Margin="0,2,0,0"/>
            </Grid>
        </Expander>

        <DataGrid x:Name="FindResultsGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  MinHeight="120"
                  Margin="0,0,0,8"
                  SelectionChanged="FindResultsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Book" Binding="{Binding Book}" Width="110"/>
                <DataGridTextColumn Header="Sheet" Binding="{Binding Sheet}" Width="100"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="90"/>
                <DataGridTextColumn Header="Cell" Binding="{Binding Cell}" Width="70"/>
                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                <DataGridTextColumn Header="Formula" Binding="{Binding Formula}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatusLabel" Grid.Row="3" Foreground="#555" FontSize="11" MinHeight="18" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="FindAllBtn" Content="Find _All" Width="76" Margin="0,0,8,0" Click="FindAll_Click"/>
            <Button x:Name="FindNextBtn" Content="_Find Next" Width="80" Margin="0,0,8,0" Click="FindNext_Click"/>
            <Button x:Name="ReplaceBtn" Content="_Replace" Width="76" Margin="0,0,8,0" Click="Replace_Click"/>
            <Button x:Name="ReplaceAllBtn" Content="_Replace All" Width="88" Margin="0,0,8,0" Click="ReplaceAll_Click"/>
            <Button Content="_Close" Width="60" IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
