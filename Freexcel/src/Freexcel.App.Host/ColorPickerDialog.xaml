<Window x:Class="Freexcel.App.Host.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Color"
        Width="500"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="NoColorButton"
                    MinWidth="76"
                    Margin="0,0,8,0"
                    Content="_No Color"
                    Click="NoColorButton_Click"/>
            <Button MinWidth="76"
                    Margin="0,0,8,0"
                    Content="_OK"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button MinWidth="76"
                    Content="_Cancel"
                    IsCancel="True"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0">
                <TabItem Header="_Standard">
                    <StackPanel Margin="8">
                        <TextBlock Text="Theme Colors" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <UniformGrid x:Name="ThemeColorsPanel"
                                     Columns="10"
                                     Rows="6"
                                     Margin="0,0,0,12"/>

                        <TextBlock Text="Standard Colors" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <UniformGrid x:Name="StandardColorsPanel"
                                     Columns="10"
                                     Rows="1"
                                     Margin="0,0,0,12"/>
                    </StackPanel>
                </TabItem>

                <TabItem Header="_Custom">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0"
                               Content="Custom _color"
                               Target="{Binding ElementName=CustomColorTextBox}"
                               FontWeight="SemiBold"
                               Padding="0"
                               Margin="0,0,0,6"/>

                        <Border Grid.Row="1"
                                Grid.RowSpan="4"
                                Grid.Column="0"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1"
                                Padding="4"
                                Margin="0,0,0,6">
                            <UniformGrid x:Name="CustomSpectrumPanel"
                                         Columns="8"
                                         Rows="6"/>
                        </Border>

                        <TextBlock Grid.Row="5" Grid.Column="0"
                                   Text="Luminosity"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <Slider x:Name="CustomLuminositySlider"
                                Grid.Row="6"
                                Grid.Column="0"
                                Minimum="0"
                                Maximum="100"
                                Value="100"
                                TickFrequency="10"
                                IsSnapToTickEnabled="False"
                                ValueChanged="CustomLuminositySlider_ValueChanged"
                                Margin="0,0,0,6"/>

                        <Label Grid.Row="0" Grid.Column="2" Content="_Hex:" Target="{Binding ElementName=CustomColorTextBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <TextBox x:Name="CustomColorTextBox" Grid.Row="0" Grid.Column="3" TextChanged="CustomColorTextBox_TextChanged" Margin="0,0,0,6"/>
                        <Label Grid.Row="1" Grid.Column="2" Content="_Red:" Target="{Binding ElementName=CustomRedTextBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <TextBox x:Name="CustomRedTextBox" Grid.Row="1" Grid.Column="3" TextChanged="CustomRgbTextBox_TextChanged" Margin="0,0,0,6"/>
                        <Label Grid.Row="2" Grid.Column="2" Content="_Green:" Target="{Binding ElementName=CustomGreenTextBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <TextBox x:Name="CustomGreenTextBox" Grid.Row="2" Grid.Column="3" TextChanged="CustomRgbTextBox_TextChanged" Margin="0,0,0,6"/>
                        <Label Grid.Row="3" Grid.Column="2" Content="_Blue:" Target="{Binding ElementName=CustomBlueTextBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <TextBox x:Name="CustomBlueTextBox" Grid.Row="3" Grid.Column="3" TextChanged="CustomRgbTextBox_TextChanged" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="4" Grid.Column="3" Text="#RRGGBB or RGB values from 0 to 255"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   FontSize="11"/>
                    </Grid>
                </TabItem>
            </TabControl>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Current" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Border Height="54"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CurrentForegroundPreview"
                                       Grid.Column="0"
                                       Text="Text"
                                       Background="White"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       VerticalAlignment="Stretch"
                                       Padding="4,16,4,0"/>
                            <Border x:Name="CurrentBackgroundPreview"
                                    Grid.Column="1">
                                <TextBlock x:Name="CurrentBackgroundText"
                                           Text="Fill"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           VerticalAlignment="Stretch"
                                           Padding="4,16,4,0"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="New" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Border Height="54"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NewForegroundPreview"
                                       Grid.Column="0"
                                       Text="Text"
                                       Background="White"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       VerticalAlignment="Stretch"
                                       Padding="4,16,4,0"/>
                            <Border x:Name="NewBackgroundPreview"
                                    Grid.Column="1">
                                <TextBlock x:Name="NewBackgroundText"
                                           Text="Fill"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           VerticalAlignment="Stretch"
                                           Padding="4,16,4,0"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
