<Window x:Class="FreeX.App.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:FreeX.App.UI;assembly=FreeX.App.UI"
        xmlns:local="clr-namespace:FreeX.App.Host"
        mc:Ignorable="d"
        Title="FreeX"
        Icon="Resources/FreeX.ico"
        Height="720" Width="1280"
        WindowState="Maximized"
        Background="{DynamicResource FreeXSheetSurfaceBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        AllowDrop="True"
        DragOver="MainWindow_DragOver"
        Drop="MainWindow_Drop">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary Source="Resources/MainWindowResources.xaml"/>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <!-- Title / quick-access bar (QAT) -->
            <RowDefinition Height="Auto"/>
            <!-- Ribbon (tab strip + tab content) -->
            <RowDefinition Height="Auto"/>
            <!-- Formula bar -->
            <RowDefinition Height="Auto"/>
            <!-- Spreadsheet grid -->
            <RowDefinition Height="*"/>
            <!-- Sheet tabs -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 0  Title bar / Quick Access Toolbar
             ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="TitleBarRoot" Grid.Row="0" Background="{StaticResource FreeXTitleBarBrush}" BorderBrush="{StaticResource FreeXAccentDarkBrush}"
                BorderThickness="0,0,0,1" Padding="6,3">
            <DockPanel>
                <!-- App icon -->
                <Border x:Name="TitleBarAppIcon"
                        DockPanel.Dock="Left"
                        Width="22" Height="22"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Background="{StaticResource FreeXAccentDarkBrush}"
                        BorderBrush="#66FFFFFF"
                        BorderThickness="1"
                        CornerRadius="2"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                    <Grid SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          TextOptions.TextFormattingMode="Display"
                          TextOptions.TextRenderingMode="ClearType"
                          TextOptions.TextHintingMode="Fixed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="TitleBarAppFreeBand"
                                Grid.Row="0"
                                Background="#0F7E9B"
                                CornerRadius="1,1,0,0"
                                Margin="0"/>
                        <TextBlock x:Name="TitleBarAppXOutlineTop"
                                   Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Panel.ZIndex="3"
                                   Text="X"
                                   Foreground="#10253A"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="14.5"
                                   Margin="0,-3,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TitleBarAppXOutlineBottom"
                                   Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Panel.ZIndex="3"
                                   Text="X"
                                   Foreground="#10253A"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="14.5"
                                   Margin="0,-1,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TitleBarAppXOutlineLeft"
                                   Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Panel.ZIndex="3"
                                   Text="X"
                                   Foreground="#10253A"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="14.5"
                                   Margin="-1,-2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TitleBarAppXOutlineRight"
                                   Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Panel.ZIndex="3"
                                   Text="X"
                                   Foreground="#10253A"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="14.5"
                                   Margin="1,-2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TitleBarAppX"
                                   Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Panel.ZIndex="4"
                                   Text="X"
                                   Foreground="{StaticResource FreeXWhiteBrush}"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="14.5"
                                   Margin="0,-2,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="FREE"
                                   Grid.Row="0"
                                   Panel.ZIndex="2"
                                   Foreground="{StaticResource FreeXWhiteBrush}"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="6.6"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                    </Grid>
                </Border>
                <!-- QAT buttons -->
                <Button x:Name="SaveQatBtn" DockPanel.Dock="Left" Width="26" Height="22" Margin="0,0,2,0"
                        Style="{StaticResource TitleBarQatButton}" FontSize="13"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_Save}"
                        Click="SaveButton_Click"
                        local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Save}"
                        local:RibbonTooltip.KeyTip="1"
                        local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_SaveTheWorkbook}" local:RibbonMetadata.CommandName="Save">
                    <local:RibbonIcon Kind="Save" IconSize="16"
                                      Foreground="{StaticResource FreeXWhiteBrush}"/>
                </Button>
                <Button x:Name="UndoQatBtn" DockPanel.Dock="Left" Width="26" Height="22" Margin="0,0,2,0"
                        Style="{StaticResource TitleBarQatButton}" FontSize="14"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_Undo}"
                        Click="UndoQatBtn_Click"
                        local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Undo}"
                        local:RibbonTooltip.KeyTip="2"
                        local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_UndoTheLastAction}" local:RibbonMetadata.CommandName="Undo">
                    <local:RibbonIcon Kind="Undo" IconSize="16"
                                      Foreground="{StaticResource FreeXWhiteBrush}"/>
                </Button>
                <Button x:Name="RedoQatBtn" DockPanel.Dock="Left" Width="26" Height="22" Margin="0,0,8,0"
                        Style="{StaticResource TitleBarQatButton}" FontSize="14"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_Redo}"
                        Click="RedoQatBtn_Click"
                        local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Redo}"
                        local:RibbonTooltip.KeyTip="3"
                        local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_RedoTheLastUndoneAction}" local:RibbonMetadata.CommandName="Redo">
                    <local:RibbonIcon Kind="Redo" IconSize="16"
                                      Foreground="{StaticResource FreeXWhiteBrush}"/>
                </Button>
                <!-- System buttons — must be docked Right before the fill element -->
                <!-- Order in XAML (Right-docked) is right-to-left, so Close first -->
                <Button x:Name="CloseSysBtn"    DockPanel.Dock="Right"
                        Style="{StaticResource CloseSysBtnStyle}" Click="CloseSysBtn_Click"
                        AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_Close}">
                    <local:RibbonIcon Kind="WindowClose" IconSize="18"
                                      Foreground="{StaticResource FreeXWhiteBrush}"/>
                </Button>
                <Button x:Name="MaxRestoreBtn"  DockPanel.Dock="Right"
                        Style="{StaticResource SysBtnStyle}"      Click="MaxRestoreBtn_Click"
                        AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_MaximizeOrRestore}">
                    <local:RibbonIcon x:Name="MaxRestoreIcon" Kind="WindowMaximize" IconSize="18"
                                      Foreground="{StaticResource FreeXWhiteBrush}"/>
                </Button>
                <Button                         DockPanel.Dock="Right"
                        Style="{StaticResource SysBtnStyle}"      Click="MinimizeBtn_Click"
                        AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_Minimize}">
                    <local:RibbonIcon Kind="WindowMinimize" IconSize="18"
                                      Foreground="{StaticResource FreeXWhiteBrush}"/>
                </Button>
                <!-- Workbook name centred -->
                <TextBlock x:Name="WorkbookNameText"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource FreeXWhiteBrush}" FontWeight="SemiBold"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 1  Ribbon  (tabbed, groups with labels)
             ═══════════════════════════════════════════════════════════════ -->
        <TabControl x:Name="RibbonTabs" Grid.Row="1" Background="{StaticResource FreeXRibbonSurfaceBrush}"
                    BorderThickness="0,0,0,1" BorderBrush="{StaticResource FreeXBorderBrush}"
                    Padding="0" TabStripPlacement="Top" SelectedIndex="1" MinHeight="132"
                    Focusable="True" IsTabStop="True"
                    KeyboardNavigation.TabNavigation="Continue"
                    KeyboardNavigation.ControlTabNavigation="Continue"
                    KeyboardNavigation.DirectionalNavigation="Contained"
                    SelectionChanged="RibbonTabs_SelectionChanged">

            <!-- ── FILE — clicking opens the overlay; handler immediately switches back to Home -->
            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>
            <TabItem x:Name="FileTab" Header="{local:Loc Key=MainWindow_Header_File}" local:RibbonTooltip.KeyTip="F" local:RibbonMetadata.CatalogId="FileTab"/>

            <!-- HOME -->
            <TabItem Header="{local:Loc Key=MainWindow_Header_Home}" local:RibbonTooltip.KeyTip="H" local:RibbonMetadata.CatalogId="HomeTab">
                <Border Background="{StaticResource FreeXRibbonSurfaceBrush}" Padding="6,4,6,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="RibbonScroll_PreviewMouseWheel">
                    <StackPanel x:Name="HomeRibbonPanel" Orientation="Horizontal" MinHeight="88">

                        <!-- ▌Clipboard ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}" local:RibbonMetadata.CatalogId="HomeClipboardGroup">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="18"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Click="PasteBtn_Click"
                                        Style="{StaticResource RibbonLargeButton}"
                                        local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Paste}"
                                        local:RibbonTooltip.KeyTip="V"
                                        local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_PasteTheContentsOfTheClipboardCtrlV}" local:RibbonMetadata.CommandName="Paste">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{local:Loc Key=MainWindow_Header_Paste}" InputGestureText="P"
                                                      local:RibbonTooltip.KeyTip="P"
                                                      Click="PasteMenuItem_Click" local:RibbonMetadata.CommandName="Paste"/>
                                            <MenuItem Header="{local:Loc Key=MainWindow_Header_Values}" InputGestureText="V"
                                                      local:RibbonTooltip.KeyTip="V"
                                                      Click="PasteValuesMenuItem_Click" local:RibbonMetadata.CommandName="Paste Values"/>
                                            <MenuItem Header="{local:Loc Key=MainWindow_Header_Formulas}" InputGestureText="F"
                                                      local:RibbonTooltip.KeyTip="F"
                                                      Click="PasteFormulasMenuItem_Click" local:RibbonMetadata.CommandName="Paste Formulas"/>
                                            <MenuItem Header="{local:Loc Key=MainWindow_Header_Formatting}" InputGestureText="R"
                                                      local:RibbonTooltip.KeyTip="R"
                                                      Click="PasteFormattingMenuItem_Click" local:RibbonMetadata.CommandName="Paste Formatting"/>
                                            <MenuItem Header="{local:Loc Key=MainWindow_Header_Transpose}" InputGestureText="T"
                                                      local:RibbonTooltip.KeyTip="T"
                                                      Click="PasteTransposeMenuItem_Click" local:RibbonMetadata.CommandName="Transpose Paste"/>
                                            <Separator/>
                                            <MenuItem Header="{local:Loc Key=MainWindow_Header_PasteSpecial}" InputGestureText="S"
                                                      local:RibbonTooltip.KeyTip="S"
                                                      Click="PasteSpecialBtn_Click" local:RibbonMetadata.CommandName="Paste Special"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel>
                                        <local:RibbonIcon Kind="Paste" IconSize="22"
                                                          HorizontalAlignment="Center"/>
                                        <TextBlock Text="{local:Loc Key=MainWindow_Text_Paste}" local:RibbonMetadata.Role="CommandLabel" FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>
                                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="2,1,0,0">
                                    <Button Content="{local:Loc Key=MainWindow_Content_Cut}" Click="CutBtn_Click" Width="126" Height="20" Margin="1,0"
                                            Style="{StaticResource RibbonBtn}" HorizontalContentAlignment="Left"
                                            local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Cut}"
                                            local:RibbonTooltip.KeyTip="X"
                                            local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_CutTheSelectionAndPutItOnTheClipboardCtrlX}" local:RibbonMetadata.CommandName="Cut"/>
                                    <Button Content="{local:Loc Key=MainWindow_Content_Copy}" Click="CopyBtn_Click" Width="126" Height="20" Margin="1,1,0,0"
                                            Style="{StaticResource RibbonBtn}" HorizontalContentAlignment="Left"
                                            local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Copy}"
                                            local:RibbonTooltip.KeyTip="C"
                                            local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_CopyTheSelectionAndPutItOnTheClipboardCtrlC}" local:RibbonMetadata.CommandName="Copy"/>
                                    <Button Content="{local:Loc Key=MainWindow_Content_FormatPainter}" Click="FormatPainterBtn_Click" PreviewMouseLeftButtonDown="FormatPainterBtn_PreviewMouseLeftButtonDown" Width="126" Height="20" Margin="1,1,0,0"
                                            Style="{StaticResource RibbonBtn}" HorizontalContentAlignment="Left"
                                            local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_FormatPainter}"
                                            local:RibbonTooltip.KeyTip="FP"
                                            local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_CopyFormattingFromOnePlaceAndApplyItToAnother}" local:RibbonMetadata.CommandName="Format Painter"/>
                                </StackPanel>
                            </Grid>
                            <Border Grid.Row="1" Style="{StaticResource RibbonGroupLabelBorder}">
                                <TextBlock Text="{local:Loc Key=MainWindow_Text_Clipboard}" Style="{StaticResource GroupLbl}"/>
                            </Border>
                        </Grid>

                        <Rectangle Style="{StaticResource RibbonGroupDivider}"/>

                        <!-- ▌Font ▌ -->
                        <Grid Style="{StaticResource RibbonGroupPanel}" local:RibbonMetadata.CatalogId="HomeFontGroup">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="18"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="0,2,2,0">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="FontNameBox" Width="110" Height="22" Margin="1" IsEditable="True" IsTextSearchEnabled="True" Background="White"
                                              SelectionChanged="FontNameBox_SelectionChanged"
                                              KeyDown="FontNameBox_KeyDown"
                                              LostKeyboardFocus="FontNameBox_LostKeyboardFocus"
                                              AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_Font}"
                                              local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Font}"
                                              local:RibbonTooltip.KeyTip="FF"
                                              local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_ChangeTheFontOfTheSelectedCells}" local:RibbonMetadata.CommandName="Font"/>
                                    <ComboBox x:Name="FontSizeBox" Width="40" Height="22" Margin="1" IsEditable="True" Background="White"
                                              SelectionChanged="FontSizeBox_SelectionChanged"
                                              KeyDown="FontSizeBox_KeyDown"
                                              LostKeyboardFocus="FontSizeBox_LostKeyboardFocus"
                                              AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_FontSize}"
                                              local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_FontSize}"
                                              local:RibbonTooltip.KeyTip="FS"
                                              local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_ChangeTheFontSizeOfTheSelectedCells}" local:RibbonMetadata.CommandName="Font Size"/>
                                    <Button Width="30" Height="22" Style="{StaticResource RibbonIconButton}"
                                            Click="IncreaseFontSizeBtn_Click"
                                            local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_IncreaseFontSize}"
                                            local:RibbonTooltip.KeyTip="FG"
                                            local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_MakeTheFontLarger}" local:RibbonMetadata.CommandName="Increase Font Size">
                                        <Grid Width="26" Height="18" SnapsToDevicePixels="True">
                                            <TextBlock Text="A" FontFamily="Segoe UI" FontSize="20" FontWeight="Normal" Margin="0,-2,8,0"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       TextAlignment="Center"/>
                                            <Path Data="M 21 15 V 4 M 17 8 L 21 4 L 25 8" Stroke="#1F6AA5" StrokeThickness="1"
                                                  StrokeStartLineCap="Square" StrokeEndLineCap="Square" StrokeLineJoin="Miter"/>
                                        </Grid>
                                    </Button>
                                    <Button Width="30" Height="22" Style="{StaticResource RibbonIconButton}"
                                            Click="DecreaseFontSizeBtn_Click"
                                            local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_DecreaseFontSize}"
                                            local:RibbonTooltip.KeyTip="FK"
                                            local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_MakeTheFontSmaller}" local:RibbonMetadata.CommandName="Decrease Font Size">
                                        <Grid Width="26" Height="18" SnapsToDevicePixels="True">
                                            <TextBlock Text="A" FontFamily="Segoe UI" FontSize="17" FontWeight="Normal" Margin="0,-1,8,0"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       TextAlignment="Center"/>
                                            <Path Data="M 21 3 V 14 M 17 10 L 21 14 L 25 10" Stroke="#1F6AA5" StrokeThickness="1"
                                                  StrokeStartLineCap="Square" StrokeEndLineCap="Square" StrokeLineJoin="Miter"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <ToggleButton x:Name="BoldButton"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="BoldButton_Click"
                                                  local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Bold}"
                                                  local:RibbonTooltip.KeyTip="1"
                                                  local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_MakeTheSelectedTextBoldCtrlB}" local:RibbonMetadata.CommandName="Bold">
                                        <TextBlock Text="B" FontFamily="Segoe UI" FontSize="19" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <ToggleButton x:Name="ItalicButton"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="ItalicButton_Click"
                                                  local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Italic}"
                                                  local:RibbonTooltip.KeyTip="2"
                                                  local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_ItalicizeTheSelectedTextCtrlI}" local:RibbonMetadata.CommandName="Italic">
                                        <TextBlock Text="I" FontFamily="Segoe UI" FontSize="19" FontStyle="Italic" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <ToggleButton x:Name="UnderlineButton"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="UnderlineButton_Click"
                                                  local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Underline}"
                                                  local:RibbonTooltip.KeyTip="3"
                                                  local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_UnderlineTheSelectedTextCtrlU}" local:RibbonMetadata.CommandName="Underline">
                                        <Grid Width="20" Height="18" SnapsToDevicePixels="True">
                                            <TextBlock Text="U" FontFamily="Segoe UI" FontSize="17" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                            <Rectangle Width="13" Height="1" Fill="#242424"
                                                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                        </Grid>
                                    </ToggleButton>
                                    <ToggleButton x:Name="StrikeButton"
                                                  Style="{StaticResource RibbonIconToggleButton}"
                                                  Click="StrikeButton_Click"
                                                  local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Strikethrough}"
                                                  local:RibbonTooltip.KeyTip="4"
                                                  local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_DrawALineThroughTheMiddleOfTheSelectedText}" local:RibbonMetadata.CommandName="Strikethrough">
                                        <TextBlock Text="S" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.TextDecorations>
                                                <TextDecorationCollection>
                                                    <TextDecoration Location="Strikethrough"/>
                                                </TextDecorationCollection>
                                            </TextBlock.TextDecorations>
                                        </TextBlock>
                                    </ToggleButton>
                                    <Rectangle Width="1" Fill="#CCCCCC" Margin="3,3"/>
                                    <Button Width="30" Height="22" Style="{StaticResource RibbonIconButton}"
                                            Click="BorderPickerBtn_Click"
                                            local:RibbonTooltip.Title="{local:Loc Key=MainWindow_TooltipTitle_Borders}"
                                            local:RibbonTooltip.KeyTip="B"
                                            local:RibbonTooltip.Description="{local:Loc Key=MainWindow_TooltipDescription_ApplyOrChangeBordersOnTheSelectedCells}" local:RibbonMetadata.CommandName="Borders">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_AllBorders}"          local:RibbonTooltip.KeyTip="A" Click="BorderAllMenuItem_Click" local:RibbonMetadata.CommandName="All Borders">
                                                    <MenuItem.Icon><local:BorderMenuIcon Kind="All"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_OutsideBorders}"      local:RibbonTooltip.KeyTip="O" Click="BorderOutsideMenuItem_Click" local:RibbonMetadata.CommandName="Outside Borders">
                                                    <MenuItem.Icon><local:BorderMenuIcon Kind="Outside"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_InsideBorders}"       local:RibbonTooltip.KeyTip="I" Click="BorderInsideMenuItem_Click" local:RibbonMetadata.CommandName="Inside Borders">
                                                    <MenuItem.Icon><local:BorderMenuIcon Kind="Inside"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_NoBorder}"            local:RibbonTooltip.KeyTip="N" Click="BorderNoneMenuItem_Click" local:RibbonMetadata.CommandName="No Border">
                                                    <MenuItem.Icon><local:BorderMenuIcon Kind="None"/></MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_BottomBorder}"        local:RibbonTooltip.KeyTip="B" Click="BorderBottomMenuItem_Click" local:RibbonMetadata.CommandName="Bottom Border">
                                                    <MenuItem.Icon><local:BorderMenuIcon Kind="Bottom"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_TopBorder}"           local:RibbonTooltip.KeyTip="T" Click="BorderTopMenuItem_Click" local:RibbonMetadata.CommandName="Top Border">
                                                    <MenuItem.Icon><local:BorderMenuIcon Kind="Top"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_LeftBorder}"          local:RibbonTooltip.KeyTip="L" Click="BorderLeftMenuItem_Click" local:RibbonMetadata.CommandName="Left Border">
                                                    <MenuItem.Icon><local:BorderMenuIcon Kind="Left"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_RightBorder}"         local:RibbonTooltip.KeyTip="R" Click="BorderRightMenuItem_Click" local:RibbonMetadata.CommandName="Right Border">
                                                    <MenuItem.Icon><local:BorderMenuIcon Kind="Right"/></MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_ThickBottomBorder}"  local:RibbonTooltip.KeyTip="K" Click="BorderThickBottomMenuItem_Click" local:RibbonMetadata.CommandName="Thick Bottom Border">
                                                    <MenuItem.Icon><local:BorderMenuIcon Kind="ThickBottom"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{local:Loc Key=MainWindow_Header_BottomDoubleBorder}" local:RibbonTooltip.KeyTip="D" Click="BorderBottomDoubleMenuItem_Click" local:RibbonMetadata.CommandName="Bottom Double Border">
                                                    <MenuItem.Icon><local:BorderMenuIcon Kind="BottomDouble"/></MenuItem.Icon>
