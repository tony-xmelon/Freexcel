<Window x:Class="FreeX.App.Host.CustomViewsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FreeX.App.Host"
        Title="{local:Loc Key=CustomViews_CustomViews}"
        Width="640" Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="{local:Loc Key=CustomViews_Views}">
            <ListView x:Name="ViewsList" SelectionChanged="ViewsList_SelectionChanged"
                      MouseDoubleClick="ViewsList_MouseDoubleClick"
                      AutomationProperties.Name="{local:Loc Key=CustomViews_CustomViews}"
                      AutomationProperties.AutomationId="CustomViewsList"
                      AutomationProperties.HelpText="{local:Loc Key=CustomViews_ShowsSavedWorkbookViewsThatCanBeShownOrDeleted}">
                <ListView.View>
                        <GridView>
                        <GridViewColumn Header="{local:Loc Key=CustomViews_Name}" Width="200" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="{local:Loc Key=CustomViews_Sheets}" Width="70" DisplayMemberBinding="{Binding SheetCount}"/>
                        <GridViewColumn Header="{local:Loc Key=CustomViews_PrintSettings}" Width="110" DisplayMemberBinding="{Binding PrintSettingsIndicator}"/>
                        <GridViewColumn Header="{local:Loc Key=CustomViews_HiddenRowsColumnsAndFilterSettings}" Width="210" DisplayMemberBinding="{Binding FilterSettingsIndicator}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ShowButton" Content="{local:Loc Key=CustomViews_Show}" Width="72" Margin="0,0,8,0" IsDefault="True" Click="ShowButton_Click"
                    AutomationProperties.AutomationId="CustomViewsShowButton"
                    AutomationProperties.HelpText="{local:Loc Key=CustomViews_ApplySelectedCustomView}"/>
            <Button Content="{local:Loc Key=CustomViews_Add}" Width="72" Margin="0,0,8,0" Click="AddButton_Click"
                    AutomationProperties.AutomationId="CustomViewsAddButton"
                    AutomationProperties.HelpText="{local:Loc Key=CustomViews_CreateNewCustomViewFromCurrentWorkbookState}"/>
            <Button x:Name="DeleteButton" Content="{local:Loc Key=CustomViews_Delete}" Width="72" Margin="0,0,8,0" Click="DeleteButton_Click"
                    AutomationProperties.AutomationId="CustomViewsDeleteButton"
                    AutomationProperties.HelpText="{local:Loc Key=CustomViews_DeleteSelectedCustomView}"/>
            <Button Content="{local:Loc Key=CustomViews_Close}" Width="72" IsCancel="True" Click="CloseButton_Click"
                    AutomationProperties.AutomationId="CustomViewsCloseButton"
                    AutomationProperties.HelpText="{local:Loc Key=CustomViews_CloseCustomViewsDialog}"/>
        </StackPanel>
    </Grid>
</Window>
