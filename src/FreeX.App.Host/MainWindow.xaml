                         TextOptions.TextHintingMode="Fixed"
                         VerticalContentAlignment="Center"
                         BorderBrush="#C0C0C0" Padding="5,3"
                         AutomationProperties.Name="{local:Loc Key=MainWindow_AutomationName_NameBox}"
                         AutomationProperties.AutomationId="CellAddressBox"
