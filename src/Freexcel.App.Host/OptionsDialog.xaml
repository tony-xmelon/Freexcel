<Window x:Class="Freexcel.App.Host.OptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Freexcel Options"
        Width="760" Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="OptionTabItem" TargetType="ListBoxItem">
            <Setter Property="Padding"  Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#A0A0A0"/>
                                <Setter TargetName="bg" Property="Background" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bg" Property="Background" Value="#DCDCDC"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left sidebar ───────────────────────────────────── -->
            <Border Grid.Column="0" Background="#F5F5F5"
                    BorderThickness="0,0,1,0" BorderBrush="#C8C8C8">
                <ListBox x:Name="TabList" BorderThickness="0" Background="Transparent"
                         Margin="0,8,0,0"
                         SelectionChanged="TabList_SelectionChanged"
                         ItemContainerStyle="{StaticResource OptionTabItem}">
                    <ListBoxItem Content="_General"/>
                    <ListBoxItem Content="_Formulas"/>
                    <ListBoxItem Content="_Proofing"/>
                    <ListBoxItem Content="_Save"/>
                    <ListBoxItem Content="_Language"/>
                    <ListBoxItem Content="_Ease of Access"/>
                    <ListBoxItem Content="_Advanced"/>
                    <ListBoxItem Content="_Customize Ribbon"/>
                    <ListBoxItem Content="_Quick Access Toolbar"/>
                    <ListBoxItem Content="_Add-ins"/>
                    <ListBoxItem Content="_Trust Center"/>
                    <ListBoxItem Content="_View"/>
                </ListBox>
            </Border>

            <!-- ── Right content area ─────────────────────────────── -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                          Padding="28,20,28,20">
                <Grid>

                    <!-- ═══ GENERAL ═══════════════════════════════════════ -->
                    <StackPanel x:Name="PanelGeneral">

                        <TextBlock Text="General options for working with Freexcel."
                                   FontSize="12" Foreground="#555" Margin="0,0,0,18"/>

                        <!-- User Interface options -->
                        <TextBlock Text="User Interface options"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <CheckBox x:Name="OptCollapseRibbon"
                                  Content="_Collapse the ribbon automatically"
                                  Margin="0,0,0,6" FontSize="12"/>
                        <CheckBox x:Name="OptShowScreenTips"
                                  Content="Show feature descriptions in _ScreenTips"
                                  Margin="0,0,0,4" FontSize="12"/>

                        <!-- When creating new workbooks -->
                        <TextBlock Text="When creating new workbooks"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="Default _font:"
                                   Target="{Binding ElementName=OptDefaultFont}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <ComboBox x:Name="OptDefaultFont" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="Font _size:"
                                   Target="{Binding ElementName=OptDefaultFontSize}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <ComboBox x:Name="OptDefaultFontSize" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"
                                      IsEditable="True"/>
                        </Grid>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="Include this many _sheets:"
                                   Target="{Binding ElementName=OptSheetCount}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <TextBox x:Name="OptSheetCount" Grid.Column="1"
                                     Height="24" VerticalContentAlignment="Center"
                                     Padding="6,0" FontSize="12"/>
                        </Grid>

                        <!-- Personalize -->
                        <TextBlock Text="Personalize your copy of Freexcel"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="User _name:"
                                   Target="{Binding ElementName=OptUserName}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <TextBox x:Name="OptUserName" Grid.Column="1"
                                     Height="24" VerticalContentAlignment="Center"
                                     Padding="6,0" FontSize="12"/>
                        </Grid>
                    </StackPanel>

                    <!-- ═══ FORMULAS ══════════════════════════════════════ -->
                    <StackPanel x:Name="PanelFormulas" Visibility="Collapsed">

                        <TextBlock Text="Calculation options"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <TextBlock Text="Workbook Calculation" FontSize="12"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <RadioButton x:Name="OptCalcAuto" Content="_Automatic"
                                     GroupName="CalcMode" FontSize="12"
                                     Margin="0,0,0,6"/>
                        <RadioButton x:Name="OptCalcManual" Content="_Manual"
                                     GroupName="CalcMode" FontSize="12"
                                     Margin="0,0,0,4"/>
                        <TextBlock Text="In Manual mode, press F9 to recalculate the workbook."
                                   FontSize="11" Foreground="#777" Margin="18,4,0,0"/>

                        <TextBlock Text="Working with formulas"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <CheckBox x:Name="OptR1C1" Content="Use _R1C1 reference style"
                                  FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox x:Name="OptFormulasAutocomplete"
                                  Content="Enable _AutoComplete for cell values"
                                  FontSize="12" Margin="0,0,0,4"/>

                        <TextBlock Text="Error Checking Rules"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <TextBlock Text="Enable background error checks for:"
                                   FontSize="12" Foreground="#555" Margin="0,0,0,8"/>
                        <StackPanel x:Name="OptErrorCheckingRules"/>
                    </StackPanel>

                    <!-- PROOFING -->
                    <StackPanel x:Name="PanelProofing" Visibility="Collapsed">
                        <TextBlock Text="AutoCorrect options"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <CheckBox Content="_Check spelling as you type" IsChecked="True"
                                  FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="Ignore words in _UPPERCASE"
                                  FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="Flag repeated _words"
                                  FontSize="12" Margin="0,0,0,12"/>
                        <Button Content="AutoCorrect _Options..." Width="150" Height="26"
                                HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- VIEW -->
                    <StackPanel x:Name="PanelView" Visibility="Collapsed">

                        <TextBlock Text="Workbook view options"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <CheckBox x:Name="OptShowFormulaBar"
                                  Content="Show formula _bar"
                                  FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox x:Name="OptFormulaBarExpanded"
                                  Content="Expand formula ba_r"
                                  FontSize="12" Margin="0,0,0,4"/>
                    </StackPanel>

                    <!-- LANGUAGE -->
                    <StackPanel x:Name="PanelLanguage" Visibility="Collapsed">
                        <TextBlock Text="Choose editing languages"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <TextBlock Text="Editing language: English (United States)"
                                   FontSize="12" Margin="0,0,0,8"/>
                        <Button Content="_Add a Language..." Width="150" Height="26"
                                HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- EASE OF ACCESS -->
                    <StackPanel x:Name="PanelEaseOfAccess" Visibility="Collapsed">
                        <TextBlock Text="Ease of Access options"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <CheckBox Content="Provide feedback with _sound"
                                  FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="Show _Quick Analysis options on selection"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="Optimize display for _accessibility"
                                  FontSize="12" Margin="0,0,0,6"/>
                    </StackPanel>

                    <!-- ADVANCED -->
                    <StackPanel x:Name="PanelAdvanced" Visibility="Collapsed">
                        <TextBlock Text="Editing options"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <CheckBox x:Name="OptMoveAfterEnter"
                                  Content="After pressing Enter, _move selection"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,8"/>
                        <Grid Margin="18,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="_Direction:"
                                   Target="{Binding ElementName=OptAfterEnterDirection}"
                                   Padding="0" VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="OptAfterEnterDirection" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"/>
                        </Grid>
                        <CheckBox Content="Enable fill _handle and cell drag-and-drop"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="Enable _AutoComplete for cell values"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,6"/>

                        <TextBlock Text="Display options for this workbook"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <CheckBox x:Name="OptShowGridlines" Content="Show _gridlines"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox x:Name="OptShowHeadings" Content="Show row and column _headings"
                                  IsChecked="True" FontSize="12" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="For _objects, show:"
                                   Target="{Binding ElementName=OptObjectsDisplay}"
                                   Padding="0" VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="OptObjectsDisplay" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- ═══ SAVE ═══════════════════════════════════════════ -->
                    <StackPanel x:Name="PanelSave" Visibility="Collapsed">

                        <TextBlock Text="Save workbooks"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="Save files in this _format:"
                                   Target="{Binding ElementName=OptDefaultFormat}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <ComboBox x:Name="OptDefaultFormat" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="File locations"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="Recent files _location:"
                                   Target="{Binding ElementName=OptRecentFilesPath}"
                                   Padding="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                            <TextBox x:Name="OptRecentFilesPath" Grid.Column="1"
                                     Height="24" IsReadOnly="True"
                                     VerticalContentAlignment="Center"
                                     Padding="6,0" FontSize="11" Foreground="#666"/>
                        </Grid>
                    </StackPanel>

                    <!-- CUSTOMIZE RIBBON -->
                    <StackPanel x:Name="PanelCustomizeRibbon" Visibility="Collapsed">
                        <TextBlock Text="Customize the Ribbon"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <TextBlock Text="Choose commands from: Popular Commands"
                                   FontSize="12" Margin="0,0,0,8"/>
                        <Button Content="_Import/Export..." Width="130" Height="26"
                                HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- QUICK ACCESS TOOLBAR -->
                    <StackPanel x:Name="PanelQuickAccessToolbar" Visibility="Collapsed">
                        <TextBlock Text="Customize the Quick Access Toolbar"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <CheckBox Content="Show Quick Access Toolbar _below the Ribbon"
                                  FontSize="12" Margin="0,0,0,8"/>
                        <Button Content="_Reset..." Width="90" Height="26"
                                HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- ADD-INS -->
                    <StackPanel x:Name="PanelAddIns" Visibility="Collapsed">
                        <TextBlock Text="View and manage Add-ins"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <TextBlock Text="Active Application Add-ins"
                                   FontSize="12" Margin="0,0,0,8"/>
                        <Button Content="_Go..." Width="70" Height="26"
                                HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- TRUST CENTER -->
                    <StackPanel x:Name="PanelTrustCenter" Visibility="Collapsed">
                        <TextBlock Text="Trust Center"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>
                        <TextBlock Text="Security and privacy settings for Freexcel."
                                   FontSize="12" Foreground="#555" Margin="0,0,0,12"/>
                        <Button Content="Trust Center _Settings..." Width="170" Height="26"
                                HorizontalAlignment="Left"/>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ── OK / Cancel ──────────────────────────────────────────── -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#C8C8C8"
                Padding="16,10" Background="#F5F5F5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="OkBtn" Content="_OK" Width="80" Height="26"
                        Margin="0,0,8,0" IsDefault="True" Click="OkBtn_Click"/>
                <Button Content="_Cancel" Width="80" Height="26"
                        IsCancel="True" Click="CancelBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
