<Window x:Class="Freexcel.App.Host.OptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Freexcel Options"
        Width="680" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="OptionTabItem" TargetType="ListBoxItem">
            <Setter Property="Padding"  Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#A0A0A0"/>
                                <Setter TargetName="bg" Property="Background" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bg" Property="Background" Value="#DCDCDC"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left sidebar ───────────────────────────────────── -->
            <Border Grid.Column="0" Background="#F5F5F5"
                    BorderThickness="0,0,1,0" BorderBrush="#C8C8C8">
                <ListBox x:Name="TabList" BorderThickness="0" Background="Transparent"
                         Margin="0,8,0,0"
                         SelectionChanged="TabList_SelectionChanged"
                         ItemContainerStyle="{StaticResource OptionTabItem}">
                    <ListBoxItem Content="General"/>
                    <ListBoxItem Content="Formulas"/>
                    <ListBoxItem Content="Save"/>
                </ListBox>
            </Border>

            <!-- ── Right content area ─────────────────────────────── -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                          Padding="28,20,28,20">
                <Grid>

                    <!-- ═══ GENERAL ═══════════════════════════════════════ -->
                    <StackPanel x:Name="PanelGeneral">

                        <TextBlock Text="General options for working with Freexcel."
                                   FontSize="12" Foreground="#555" Margin="0,0,0,18"/>

                        <!-- User Interface options -->
                        <TextBlock Text="User Interface options"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <CheckBox x:Name="OptCollapseRibbon"
                                  Content="Collapse the ribbon automatically"
                                  Margin="0,0,0,6" FontSize="12"/>
                        <CheckBox x:Name="OptShowScreenTips"
                                  Content="Show feature descriptions in ScreenTips"
                                  Margin="0,0,0,4" FontSize="12"/>

                        <!-- When creating new workbooks -->
                        <TextBlock Text="When creating new workbooks"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Use this as the default font:"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="OptDefaultFont" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Font size:"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="OptDefaultFontSize" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"
                                      IsEditable="True"/>
                        </Grid>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Include this many sheets:"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <TextBox x:Name="OptSheetCount" Grid.Column="1"
                                     Height="24" VerticalContentAlignment="Center"
                                     Padding="6,0" FontSize="12"/>
                        </Grid>

                        <!-- Personalize -->
                        <TextBlock Text="Personalize your copy of Freexcel"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="User name:"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <TextBox x:Name="OptUserName" Grid.Column="1"
                                     Height="24" VerticalContentAlignment="Center"
                                     Padding="6,0" FontSize="12"/>
                        </Grid>
                    </StackPanel>

                    <!-- ═══ FORMULAS ══════════════════════════════════════ -->
                    <StackPanel x:Name="PanelFormulas" Visibility="Collapsed">

                        <TextBlock Text="Calculation options"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <TextBlock Text="Workbook Calculation" FontSize="12"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <RadioButton x:Name="OptCalcAuto" Content="Automatic"
                                     GroupName="CalcMode" FontSize="12"
                                     Margin="0,0,0,6"/>
                        <RadioButton x:Name="OptCalcManual" Content="Manual"
                                     GroupName="CalcMode" FontSize="12"
                                     Margin="0,0,0,4"/>
                        <TextBlock Text="In Manual mode, press F9 to recalculate the workbook."
                                   FontSize="11" Foreground="#777" Margin="18,4,0,0"/>

                        <TextBlock Text="Working with formulas"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <CheckBox x:Name="OptR1C1" Content="Use R1C1 reference style (not yet implemented)"
                                  FontSize="12" IsEnabled="False" Margin="0,0,0,6"/>
                        <CheckBox x:Name="OptFormulasAutocomplete"
                                  Content="Enable AutoComplete for cell values"
                                  FontSize="12" Margin="0,0,0,4"/>
                    </StackPanel>

                    <!-- ═══ SAVE ═══════════════════════════════════════════ -->
                    <StackPanel x:Name="PanelSave" Visibility="Collapsed">

                        <TextBlock Text="Save workbooks"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Save files in this format:"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="OptDefaultFormat" Grid.Column="1"
                                      Height="24" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="File locations"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,5"/>
                        <Rectangle Height="1" Fill="#D4D4D4" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Recent files location:"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <TextBox x:Name="OptRecentFilesPath" Grid.Column="1"
                                     Height="24" IsReadOnly="True"
                                     VerticalContentAlignment="Center"
                                     Padding="6,0" FontSize="11" Foreground="#666"/>
                        </Grid>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ── OK / Cancel ──────────────────────────────────────────── -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#C8C8C8"
                Padding="16,10" Background="#F5F5F5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="OkBtn" Content="OK" Width="80" Height="26"
                        Margin="0,0,8,0" IsDefault="True" Click="OkBtn_Click"/>
                <Button Content="Cancel" Width="80" Height="26"
                        IsCancel="True" Click="CancelBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
