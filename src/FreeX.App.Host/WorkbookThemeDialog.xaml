<Window x:Class="FreeX.App.Host.WorkbookThemeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FreeX.App.Host"
        Title="{local:Loc Key=WorkbookTheme_CustomizeTheme}"
        Width="620"
        Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="SaveButton"
                    Content="{local:Loc Key=WorkbookTheme_Save}"
                    Width="86"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="SaveButton_Click"/>
            <Button Content="{local:Loc Key=Common_Cancel}"
                    Width="86"
                    IsCancel="True"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{local:Loc Key=WorkbookTheme_Theme}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,14"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,14">
                    <Button x:Name="OfficePresetButton"
                            Content="{local:Loc Key=WorkbookTheme_Office}"
                            Width="92"
                            Margin="0,0,8,0"
                            Click="OfficePresetButton_Click"/>
                    <Button x:Name="ColorfulPresetButton"
                            Content="{local:Loc Key=WorkbookTheme_FreeXColorful}"
                            Width="126"
                            Margin="0,0,8,0"
                            Click="ColorfulPresetButton_Click"/>
                    <Button x:Name="GrayscalePresetButton"
                            Content="{local:Loc Key=WorkbookTheme_Grayscale}"
                            Width="92"
                            Click="GrayscalePresetButton_Click"/>
                </StackPanel>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="{local:Loc Key=WorkbookTheme_Name}" Target="{Binding ElementName=ThemeNameBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,10,8"/>
                    <TextBox x:Name="ThemeNameBox"
                             Grid.Row="0"
                             Grid.Column="1"
                             Margin="0,0,0,8"
                             AutomationProperties.Name="{local:Loc Key=WorkbookTheme_ThemeName}"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="{local:Loc Key=WorkbookTheme_HeadingFont}" Target="{Binding ElementName=HeadingFontBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,10,8"/>
                    <ComboBox x:Name="HeadingFontBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,0,0,8"
                              IsEditable="True"
                              AutomationProperties.Name="{local:Loc Key=WorkbookTheme_HeadingFont2}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="{local:Loc Key=WorkbookTheme_BodyFont}" Target="{Binding ElementName=BodyFontBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,10,8"/>
                    <ComboBox x:Name="BodyFontBox"
                              Grid.Row="2"
                              Grid.Column="1"
                              Margin="0,0,0,8"
                              IsEditable="True"
                              AutomationProperties.Name="{local:Loc Key=WorkbookTheme_BodyFont2}"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="{local:Loc Key=WorkbookTheme_Effects}" Target="{Binding ElementName=EffectsBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="EffectsBox"
                              Grid.Row="3"
                              Grid.Column="1"
                              IsEditable="True"
                              AutomationProperties.Name="{local:Loc Key=WorkbookTheme_Effects2}"/>
                </Grid>

                <TextBlock Text="{local:Loc Key=WorkbookTheme_ThemeColors}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <Border x:Name="ThemePreviewPane"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,14"
                        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <StackPanel>
                        <TextBlock Text="{local:Loc Key=WorkbookTheme_Sample}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="PreviewHeadingText"
                                   Text="{local:Loc Key=WorkbookTheme_Heading}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="PreviewBodyText"
                                   Text="{local:Loc Key=WorkbookTheme_BodyTextAndHyperlinks}"
                                   Margin="0,2,0,10"/>
                        <UniformGrid x:Name="PreviewAccentStrip"
                                     Columns="6"
                                     Height="22"/>
                    </StackPanel>
                </Border>

                <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,10,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_Dark1}" Target="{Binding ElementName=Dark1ColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="Dark1ColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="Dark1ColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickDark1Color}"/>
                            <TextBox x:Name="Dark1ColorBox"/>
                        </DockPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_Light1}" Target="{Binding ElementName=Light1ColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="Light1ColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="Light1ColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickLight1Color}"/>
                            <TextBox x:Name="Light1ColorBox"/>
                        </DockPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_Dark2}" Target="{Binding ElementName=Dark2ColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="Dark2ColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="Dark2ColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickDark2Color}"/>
                            <TextBox x:Name="Dark2ColorBox"/>
                        </DockPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_Light2}" Target="{Binding ElementName=Light2ColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="Light2ColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="Light2ColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickLight2Color}"/>
                            <TextBox x:Name="Light2ColorBox"/>
                        </DockPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_Accent1}" Target="{Binding ElementName=Accent1ColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="Accent1ColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="Accent1ColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickAccent1Color}"/>
                            <TextBox x:Name="Accent1ColorBox"/>
                        </DockPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_Accent2}" Target="{Binding ElementName=Accent2ColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="Accent2ColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="Accent2ColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickAccent2Color}"/>
                            <TextBox x:Name="Accent2ColorBox"/>
                        </DockPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_Accent3}" Target="{Binding ElementName=Accent3ColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="Accent3ColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="Accent3ColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickAccent3Color}"/>
                            <TextBox x:Name="Accent3ColorBox"/>
                        </DockPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_Accent4}" Target="{Binding ElementName=Accent4ColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="Accent4ColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="Accent4ColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickAccent4Color}"/>
                            <TextBox x:Name="Accent4ColorBox"/>
                        </DockPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_Accent5}" Target="{Binding ElementName=Accent5ColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="Accent5ColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="Accent5ColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickAccent5Color}"/>
                            <TextBox x:Name="Accent5ColorBox"/>
                        </DockPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_Accent6}" Target="{Binding ElementName=Accent6ColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="Accent6ColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="Accent6ColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickAccent6Color}"/>
                            <TextBox x:Name="Accent6ColorBox"/>
                        </DockPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_Hyperlink}" Target="{Binding ElementName=HyperlinkColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="HyperlinkColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="HyperlinkColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickHyperlinkColor}"/>
                            <TextBox x:Name="HyperlinkColorBox"/>
                        </DockPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <Label Content="{local:Loc Key=WorkbookTheme_FollowedHyperlink}" Target="{Binding ElementName=FollowedHyperlinkColorBox}" Padding="0"/>
                        <DockPanel>
                            <Button x:Name="FollowedHyperlinkColorPickerButton"
                                    Content=""
                                    ToolTip="{local:Loc Key=WorkbookTheme_PickColor}"
                                    Width="28"
                                    Margin="0,0,6,0"
                                    Tag="FollowedHyperlinkColorBox"
                                    Click="ThemeColorPickerButton_Click"
                                    AutomationProperties.Name="{local:Loc Key=WorkbookTheme_PickFollowedHyperlinkColor}"/>
                            <TextBox x:Name="FollowedHyperlinkColorBox"/>
                        </DockPanel>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
