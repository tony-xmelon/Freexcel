<Window x:Class="Freexcel.App.Host.DataValidationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Data Validation"
        Width="480" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Type row -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Validation type:" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox x:Name="TypeCombo" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                  SelectionChanged="TypeCombo_SelectionChanged">
            <ComboBoxItem Content="Any Value" Tag="Any"/>
            <ComboBoxItem Content="List" Tag="List"/>
            <ComboBoxItem Content="Whole Number" Tag="WholeNumber"/>
            <ComboBoxItem Content="Decimal" Tag="Decimal"/>
            <ComboBoxItem Content="Date" Tag="Date"/>
            <ComboBoxItem Content="Time" Tag="Time"/>
            <ComboBoxItem Content="Text Length" Tag="TextLength"/>
            <ComboBoxItem Content="Custom" Tag="Custom"/>
        </ComboBox>

        <!-- Operator row (hidden for Any and List) -->
        <TextBlock x:Name="OperatorLabel" Grid.Row="1" Grid.Column="0" Text="Operator:" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox x:Name="OperatorCombo" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
            <ComboBoxItem Content="Between" Tag="Between"/>
            <ComboBoxItem Content="Not Between" Tag="NotBetween"/>
            <ComboBoxItem Content="Equal To" Tag="Equal"/>
            <ComboBoxItem Content="Not Equal To" Tag="NotEqual"/>
            <ComboBoxItem Content="Greater Than" Tag="GreaterThan"/>
            <ComboBoxItem Content="Less Than" Tag="LessThan"/>
            <ComboBoxItem Content="Greater Than Or Equal" Tag="GreaterThanOrEqual"/>
            <ComboBoxItem Content="Less Than Or Equal" Tag="LessThanOrEqual"/>
        </ComboBox>

        <!-- Formula1 row -->
        <TextBlock x:Name="Formula1Label" Grid.Row="2" Grid.Column="0" Text="Minimum:" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
            <Button x:Name="UseSelectionButton" DockPanel.Dock="Right"
                    Content="Use Selection" Width="96" Margin="6,0,0,0"
                    Click="UseSelectionButton_Click"/>
            <TextBox x:Name="Formula1Box"/>
        </DockPanel>

        <!-- Formula2 row (only for Between) -->
        <TextBlock x:Name="Formula2Label" Grid.Row="3" Grid.Column="0" Text="Maximum:" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
            <Button x:Name="UseSelection2Button" DockPanel.Dock="Right"
                    Content="Use Selection" Width="96" Margin="6,0,0,0"
                    Click="UseSelection2Button_Click"/>
            <TextBox x:Name="Formula2Box"/>
        </DockPanel>

        <!-- In-cell dropdown (List only) -->
        <CheckBox x:Name="ShowDropdownBox" Grid.Row="4" Grid.Column="1" Content="In-cell dropdown" IsChecked="True" Margin="0,0,0,8"/>

        <!-- Allow Blank -->
        <CheckBox x:Name="AllowBlankBox" Grid.Row="5" Grid.Column="1" Content="Allow blank" IsChecked="True" Margin="0,0,0,8"/>

        <!-- Alert style -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Alert style:" VerticalAlignment="Top" Margin="0,0,8,8"/>
        <ComboBox x:Name="AlertStyleCombo" Grid.Row="6" Grid.Column="1" Margin="0,0,0,8">
            <ComboBoxItem Content="Stop" Tag="Stop"/>
            <ComboBoxItem Content="Warning" Tag="Warning"/>
            <ComboBoxItem Content="Information" Tag="Information"/>
        </ComboBox>

        <CheckBox x:Name="ShowInputMessageBox" Grid.Row="7" Grid.Column="1" Content="Show input message when cell is selected" IsChecked="True" Margin="0,0,0,8"/>
        <CheckBox x:Name="ShowErrorMessageBox" Grid.Row="8" Grid.Column="1" Content="Show error alert after invalid data is entered" IsChecked="True" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Input title:" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox x:Name="PromptTitleBox" Grid.Row="9" Grid.Column="1" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="10" Grid.Column="0" Text="Input message:" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox x:Name="PromptMessageBox" Grid.Row="10" Grid.Column="1" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="11" Grid.Column="0" Text="Error title:" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox x:Name="ErrorTitleBox" Grid.Row="11" Grid.Column="1" Margin="0,0,0,8"/>

        <!-- Error message -->
        <TextBlock Grid.Row="12" Grid.Column="0" Text="Error message:" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox x:Name="ErrorMessageBox" Grid.Row="12" Grid.Column="1" Margin="0,0,0,8"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Clear All" Width="72" Margin="0,0,16,0" Click="ClearAllButton_Click"/>
            <Button Content="OK" Width="72" Margin="0,0,8,0" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="72" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
