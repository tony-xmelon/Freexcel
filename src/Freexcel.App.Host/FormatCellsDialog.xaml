<Window x:Class="Freexcel.App.Host.FormatCellsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Format Cells" Width="620" Height="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="Tabs" Grid.Row="0">
            <!-- Number -->
            <TabItem Header="_Number">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <Label Content="_Category:" Target="{Binding ElementName=NumberCategoryList}" Padding="0" Margin="0,4,0,2"/>
                        <ListBox x:Name="NumberCategoryList" Height="355"
                                 SelectionChanged="NumberCategoryList_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Sample" FontWeight="SemiBold" Margin="0,4,0,2"/>
                        <Border BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1"
                                Padding="8"
                                Margin="0,0,0,10">
                            <TextBlock x:Name="NumberPreview" FontWeight="Bold" Text="1234.56"/>
                        </Border>

                        <Label Content="_Type:" Target="{Binding ElementName=NumberFormatCombo}" Padding="0" Margin="0,0,0,2"/>
                        <ComboBox x:Name="NumberFormatCombo" IsEditable="True" Height="24"
                                  SelectionChanged="NumberFormatCombo_SelectionChanged"/>

                        <Label Content="_Decimal places:" Target="{Binding ElementName=NumberDecimalPlacesBox}" Padding="0" Margin="0,10,0,2"/>
                        <TextBox x:Name="NumberDecimalPlacesBox" Height="24" Text="2"
                                 TextChanged="NumberFormatControl_Changed"/>

                        <Label Content="_Symbol:" Target="{Binding ElementName=NumberSymbolCombo}" Padding="0" Margin="0,10,0,2"/>
                        <ComboBox x:Name="NumberSymbolCombo" Height="24"
                                  SelectionChanged="NumberFormatControl_Changed"/>

                        <Label Content="_Negative numbers:" Target="{Binding ElementName=NumberNegativeNumbersList}" Padding="0" Margin="0,10,0,2"/>
                        <ListBox x:Name="NumberNegativeNumbersList" Height="82"
                                 SelectionChanged="NumberFormatControl_Changed"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Alignment -->
            <TabItem Header="_Alignment">
                <StackPanel Margin="8">
                    <Label Content="_Horizontal alignment:" Target="{Binding ElementName=DlgHAlignBox}" Padding="0" Margin="0,4,0,2"/>
                    <ComboBox x:Name="DlgHAlignBox" Height="24"/>
                    <Label Content="_Vertical alignment:" Target="{Binding ElementName=DlgVAlignBox}" Padding="0" Margin="0,8,0,2"/>
                    <ComboBox x:Name="DlgVAlignBox" Height="24"/>
                    <CheckBox x:Name="DlgWrapTextCheck" Content="_Wrap text" Margin="0,8,0,0"/>
                    <CheckBox x:Name="DlgShrinkToFitCheck" Content="S_hrink to fit" Margin="0,6,0,0"/>
                    <Label Content="_Indent level (0-15):" Target="{Binding ElementName=DlgIndentLevelBox}" Padding="0" Margin="0,8,0,2"/>
                    <TextBox x:Name="DlgIndentLevelBox" Height="24"/>
                    <Label Content="Text _rotation (-90 to 90, or 255):" Target="{Binding ElementName=DlgTextRotationBox}" Padding="0" Margin="0,8,0,2"/>
                    <TextBox x:Name="DlgTextRotationBox" Height="24"/>
                </StackPanel>
            </TabItem>

            <!-- Font -->
            <TabItem Header="_Font">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.25*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="108"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="_Font:" Target="{Binding ElementName=DlgFontNameBox}" Padding="0" Margin="0,4,8,2"/>
                    <Label Grid.Row="0" Grid.Column="1" Content="Font _style:" Target="{Binding ElementName=DlgFontStyleList}" Padding="0" Margin="0,4,8,2"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="_Size:" Target="{Binding ElementName=DlgFontSizeBox}" Padding="0" Margin="0,4,0,2"/>
                    <ComboBox x:Name="DlgFontNameBox" Grid.Row="1" Grid.Column="0" Height="24" VerticalAlignment="Top" Margin="0,0,8,0"
                              SelectionChanged="FontPreviewInput_Changed"/>
                    <ListBox x:Name="DlgFontStyleList" Grid.Row="1" Grid.Column="1" Height="96" Margin="0,0,8,0"
                             SelectionChanged="FontStyleList_SelectionChanged"/>
                    <ComboBox x:Name="DlgFontSizeBox" Grid.Row="1" Grid.Column="2" IsEditable="True" Height="24" VerticalAlignment="Top"
                              SelectionChanged="FontPreviewInput_Changed" TextBoxBase.TextChanged="FontPreviewInput_Changed"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="_Underline:" Target="{Binding ElementName=DlgUnderlineStyleBox}" Padding="0" Margin="0,6,8,2"/>
                    <Label Grid.Row="2" Grid.Column="1" Content="_Color:" Target="{Binding ElementName=DlgFontColorBox}" Padding="0" Margin="0,6,8,2"/>
                    <ComboBox x:Name="DlgUnderlineStyleBox" Grid.Row="3" Grid.Column="0" Height="24" Margin="0,0,8,0"
                              SelectionChanged="UnderlineStyleBox_SelectionChanged"/>
                    <DockPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2">
                        <Button x:Name="DlgFontColorPickerButton" DockPanel.Dock="Right" Content="_Pick" Width="54" Margin="6,0,0,0" Click="DlgFontColorPickerButton_Click"/>
                        <TextBox x:Name="DlgFontColorBox" Height="24" Text="0,0,0" TextChanged="FontPreviewInput_Changed"/>
                    </DockPanel>

                    <GroupBox x:Name="DlgFontEffectsGroup" Grid.Row="4" Grid.Column="0" Margin="0,10,8,0">
                        <GroupBox.Header>
                            <TextBlock Text="Effects"/>
                        </GroupBox.Header>
                        <WrapPanel Margin="8,6,8,4">
                            <CheckBox x:Name="DlgDoubleUnderlineCheck" Content="_Double underline" Margin="0,0,12,6" Checked="FontPreviewInput_Changed" Unchecked="FontPreviewInput_Changed"/>
                            <CheckBox x:Name="DlgStrikeCheck"    Content="_Strikethrough"    Margin="0,0,12,6" Checked="FontPreviewInput_Changed" Unchecked="FontPreviewInput_Changed"/>
                            <CheckBox x:Name="DlgSuperscriptCheck" Content="Super_script"     Margin="0,0,12,6" Checked="FontPreviewInput_Changed" Unchecked="FontPreviewInput_Changed"/>
                            <CheckBox x:Name="DlgSubscriptCheck" Content="Su_bscript" Checked="FontPreviewInput_Changed" Unchecked="FontPreviewInput_Changed"/>
                        </WrapPanel>
                    </GroupBox>

                    <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,10,0,0">
                        <TextBlock Text="Sample" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <Border BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1" Height="92" Padding="10" Background="White">
                            <TextBlock x:Name="DlgFontSamplePreview" Text="AaBbCcYyZz" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Fill -->
            <TabItem Header="F_ill">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Background Color:" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <UniformGrid x:Name="DlgFillPalettePanel" Columns="6" Rows="2" Margin="0,0,0,8">
                            <Button Width="28" Height="22" ToolTip="No Fill" Tag="" Click="DlgFillSwatchButton_Click" Background="White" BorderBrush="Gray"/>
                            <Button Width="28" Height="22" ToolTip="White" Tag="255,255,255" Click="DlgFillSwatchButton_Click" Background="White" BorderBrush="Gray"/>
                            <Button Width="28" Height="22" ToolTip="Yellow" Tag="255,255,0" Click="DlgFillSwatchButton_Click" Background="Yellow" BorderBrush="Gray"/>
                            <Button Width="28" Height="22" ToolTip="Green" Tag="146,208,80" Click="DlgFillSwatchButton_Click" Background="#92D050" BorderBrush="Gray"/>
                            <Button Width="28" Height="22" ToolTip="Blue" Tag="91,155,213" Click="DlgFillSwatchButton_Click" Background="#5B9BD5" BorderBrush="Gray"/>
                            <Button Width="28" Height="22" ToolTip="Red" Tag="255,0,0" Click="DlgFillSwatchButton_Click" Background="Red" BorderBrush="Gray"/>
                            <Button Width="28" Height="22" ToolTip="Orange" Tag="237,125,49" Click="DlgFillSwatchButton_Click" Background="#ED7D31" BorderBrush="Gray"/>
                            <Button Width="28" Height="22" ToolTip="Purple" Tag="112,48,160" Click="DlgFillSwatchButton_Click" Background="#7030A0" BorderBrush="Gray"/>
                            <Button Width="28" Height="22" ToolTip="Light gray" Tag="217,217,217" Click="DlgFillSwatchButton_Click" Background="#D9D9D9" BorderBrush="Gray"/>
                            <Button Width="28" Height="22" ToolTip="Dark gray" Tag="89,89,89" Click="DlgFillSwatchButton_Click" Background="#595959" BorderBrush="Gray"/>
                            <Button Width="28" Height="22" ToolTip="Black" Tag="0,0,0" Click="DlgFillSwatchButton_Click" Background="Black" BorderBrush="Gray"/>
                            <Button Width="28" Height="22" ToolTip="More Colors" Click="DlgFillColorPickerButton_Click" Content="..."/>
                        </UniformGrid>
                        <Label Content="_Background Color:" Target="{Binding ElementName=DlgFillColorBox}" Padding="0" Margin="0,0,0,2"/>
                        <DockPanel>
                            <Button x:Name="DlgFillColorPickerButton" DockPanel.Dock="Right" Content="_Pick" Width="54" Margin="6,0,0,0" Click="DlgFillColorPickerButton_Click"/>
                            <TextBox x:Name="DlgFillColorBox" Height="24" TextChanged="FillPreviewInput_Changed"/>
                        </DockPanel>
                        <Border x:Name="DlgFillBackgroundPreview" Height="22" Margin="0,4,60,0"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1" Background="White"/>

                        <CheckBox x:Name="DlgClearFillCheck" Content="_Clear fill" Margin="0,12,0,0" Checked="FillPreviewInput_Changed" Unchecked="FillPreviewInput_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Sample" FontWeight="SemiBold" Margin="0,4,0,2"/>
                        <Border x:Name="DlgFillSamplePreview"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1" Height="96" Padding="8" Background="White">
                            <TextBlock Text="Sample" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Border -->
            <TabItem Header="_Border">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Margin="0,0,12,0">
                        <TextBlock Text="Presets" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <Button x:Name="DlgBorderPresetNoneButton" Content="_None" Height="28" Margin="0,0,0,6" Click="DlgBorderPresetNoneButton_Click"/>
                        <Button x:Name="DlgBorderPresetOutlineButton" Content="_Outline" Height="28" Margin="0,0,0,6" Click="DlgBorderPresetOutlineButton_Click"/>
                        <Button x:Name="DlgBorderPresetInsideButton" Content="_Inside" Height="28" Click="DlgBorderPresetInsideButton_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Line" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <Label Content="_Style:" Target="{Binding ElementName=DlgBorderLineStyleBox}" Padding="0" Margin="0,0,0,2"/>
                        <ComboBox x:Name="DlgBorderLineStyleBox" Height="24" SelectionChanged="BorderPreviewInput_Changed"/>
                        <Label Content="_Color:" Target="{Binding ElementName=DlgBorderLineColorBox}" Padding="0" Margin="0,8,0,2"/>
                        <DockPanel>
                            <Button x:Name="DlgBorderLineColorPickerButton" DockPanel.Dock="Right" Content="P_ick" Width="54" Margin="6,0,0,0" Click="DlgBorderLineColorPickerButton_Click"/>
                            <TextBox x:Name="DlgBorderLineColorBox" Height="24" TextChanged="BorderPreviewInput_Changed"/>
                        </DockPanel>
                        <UniformGrid Columns="5" Rows="1" Margin="0,6,0,0">
                            <Button Width="24" Height="20" ToolTip="Black border" Tag="0,0,0" Click="DlgBorderLineColorSwatchButton_Click" Background="Black" BorderBrush="Gray"/>
                            <Button Width="24" Height="20" ToolTip="Red border" Tag="255,0,0" Click="DlgBorderLineColorSwatchButton_Click" Background="Red" BorderBrush="Gray"/>
                            <Button Width="24" Height="20" ToolTip="Blue border" Tag="0,112,192" Click="DlgBorderLineColorSwatchButton_Click" Background="#0070C0" BorderBrush="Gray"/>
                            <Button Width="24" Height="20" ToolTip="Green border" Tag="0,176,80" Click="DlgBorderLineColorSwatchButton_Click" Background="#00B050" BorderBrush="Gray"/>
                            <Button Width="24" Height="20" ToolTip="Gray border" Tag="128,128,128" Click="DlgBorderLineColorSwatchButton_Click" Background="Gray" BorderBrush="Gray"/>
                        </UniformGrid>
                        <Border x:Name="DlgBorderLineColorPreview" Height="20" Margin="0,6,0,0"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1" Background="Black"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Border" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,4"/>
                        <Grid Width="190" Height="126" HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="70"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="122"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="DlgBorderPreviewTopButton" Grid.Row="0" Grid.Column="1" Content="To_p" Click="DlgBorderPreviewTopButton_Click"/>
                            <Button x:Name="DlgBorderPreviewLeftButton" Grid.Row="1" Grid.Column="0" Content="L_eft" Click="DlgBorderPreviewLeftButton_Click"/>
                            <Border x:Name="DlgBorderPreviewArea" Grid.Row="1" Grid.Column="1"
                                    BorderBrush="Black" BorderThickness="1" Background="White">
                                <TextBlock Text="Text" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Button x:Name="DlgBorderPreviewRightButton" Grid.Row="1" Grid.Column="2" Content="Ri_ght" Click="DlgBorderPreviewRightButton_Click"/>
                            <Button x:Name="DlgBorderPreviewBottomButton" Grid.Row="2" Grid.Column="1" Content="Botto_m" Click="DlgBorderPreviewBottomButton_Click"/>
                        </Grid>
                    </StackPanel>

                    <Expander Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Header="Individual border _details" Margin="0,14,0,0" IsExpanded="True">
                        <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Style" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Color (R,G,B)" Margin="0,0,0,4"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="_Top:" Target="{Binding ElementName=DlgBorderTopStyleBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <ComboBox x:Name="DlgBorderTopStyleBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,0,8,6"/>
                        <DockPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,6">
                            <Button x:Name="DlgBorderTopColorPickerButton" DockPanel.Dock="Right" Content="P_ick" Width="54" Margin="6,0,0,0" Click="DlgBorderTopColorPickerButton_Click"/>
                            <TextBox x:Name="DlgBorderTopColorBox" Height="24" AutomationProperties.Name="Top border color (R,G,B)"/>
                        </DockPanel>

                        <Label Grid.Row="2" Grid.Column="0" Content="_Right:" Target="{Binding ElementName=DlgBorderRightStyleBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <ComboBox x:Name="DlgBorderRightStyleBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,0,8,6"/>
                        <DockPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,6">
                            <Button x:Name="DlgBorderRightColorPickerButton" DockPanel.Dock="Right" Content="P_ick" Width="54" Margin="6,0,0,0" Click="DlgBorderRightColorPickerButton_Click"/>
                            <TextBox x:Name="DlgBorderRightColorBox" Height="24" AutomationProperties.Name="Right border color (R,G,B)"/>
                        </DockPanel>

                        <Label Grid.Row="3" Grid.Column="0" Content="_Bottom:" Target="{Binding ElementName=DlgBorderBottomStyleBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <ComboBox x:Name="DlgBorderBottomStyleBox" Grid.Row="3" Grid.Column="1" Height="24" Margin="0,0,8,6"/>
                        <DockPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,6">
                            <Button x:Name="DlgBorderBottomColorPickerButton" DockPanel.Dock="Right" Content="P_ick" Width="54" Margin="6,0,0,0" Click="DlgBorderBottomColorPickerButton_Click"/>
                            <TextBox x:Name="DlgBorderBottomColorBox" Height="24" AutomationProperties.Name="Bottom border color (R,G,B)"/>
                        </DockPanel>

                        <Label Grid.Row="4" Grid.Column="0" Content="_Left:" Target="{Binding ElementName=DlgBorderLeftStyleBox}" Padding="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="DlgBorderLeftStyleBox" Grid.Row="4" Grid.Column="1" Height="24" Margin="0,0,8,0"/>
                        <DockPanel Grid.Row="4" Grid.Column="2">
                            <Button x:Name="DlgBorderLeftColorPickerButton" DockPanel.Dock="Right" Content="P_ick" Width="54" Margin="6,0,0,0" Click="DlgBorderLeftColorPickerButton_Click"/>
                            <TextBox x:Name="DlgBorderLeftColorBox" Height="24" AutomationProperties.Name="Left border color (R,G,B)"/>
                        </DockPanel>
                    </Grid>
                    </Expander>
                </Grid>
            </TabItem>

            <!-- Protection -->
            <TabItem Header="_Protection">
                <StackPanel Margin="8">
                    <CheckBox x:Name="DlgLockedCheck" Content="_Locked" Margin="0,4,0,0"/>
                    <CheckBox x:Name="DlgHiddenCheck" Content="_Hidden" Margin="0,6,0,0"/>
                    <TextBlock Text="Locking cells or hiding formulas has no effect until you protect the worksheet."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="_OK"     Width="70" Height="26" Margin="4,0" IsDefault="True" Click="OkButton_Click"/>
            <Button Content="_Cancel" Width="70" Height="26" Margin="4,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
